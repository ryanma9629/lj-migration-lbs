<?xml version="1.0" encoding="UTF-8"?>
<applications xmlns="http://www.wabacus.com"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.wabacus.com ../xsd/wabacus.applications.xsd">
	<!--第三方认领 -->
<page id="claim_thd"
	js="/webresources/script/validate.js,/js/demo.js,/js/common.js"><!-- /webresources/script/validate.js -->

	<header>${top.header}</header>
	<vpanel id="common_vpanel" width="1300px" align="center" title="">
		
		<!-- 按凭证号查询 -->
		<report id="list" title="认领信息" type="listform" personalizeclass="default" width="1300px" scrollwidth="1300px"  pagesize="10|20|-1"
			interceptor="com.customer.interceptor.InterceptorClaimThd" 
			top="10px"
			>
		
			<display>
			    <col column="{sequence:1}" label="序号" width="40px"></col>
				<col column="SCURT_AC" label="证券资金账号"></col>
				<col column="VUCH_NBR" label="签约卡号" ></col>
				<col column="BIZ_TYPE_NM" label="业务类型"></col>
				<col column="CST_NM" label="客户名"></col>
				<col column="ORG_NM" label="签约机构"></col>
				<col column="OPEN_DT" label="签约日期"></col>
				<col column="EMP_ID" label="认领人工号" ></col>
				<col column="EMP_NM" label="认领人姓名"></col>	
				<col column="EMP_ORG_ID" label="认领人机构号" displaytype="hidden"></col>
				<col column="EMP_ORG_NM" label="认领人机构"></col>
				<col column="CLAIM_STATUS_ID" label="认领状态ID" displaytype="hidden"></col>
				<col column="CLAIM_STATUS_NM" label="认领状态"></col>
				<col column="CLAIM_DT" label="认领日期" br="true"></col>
				<col column="VERIFY_DT" label="审批日期" displaytype="hidden"></col>
				<col column="VERIFY_EMP_ID" label="审批人" displaytype="hidden"></col>
				<col column="TXN_RUN_NBR" label="流水号" displaytype="hidden"></col>
			</display>

			<sql datasource="ds_db2">
				<select>
					<value><![CDATA[
						select thd.*,s.CLAIM_STATUS_NM
						from IBS.T1_THD_EMP_RELA thd
						left join IBS.T9_CLAIM_STATUS_TYPE S ON S.CLAIM_STATUS_ID=thd.CLAIM_STATUS_ID	
						WHERE {#condition#}
					    ]]>
					</value>
					<condition name="SCURT_AC" label="证券资金账号">
						<value><![CDATA[thd.SCURT_AC='#data#']]></value>
					</condition>
				</select>
			</sql>

			<format>
				<imports>
					<import>com.ljbank.util.*</import>
					<import>java.util.*</import>
					<import>java.text.*</import>
					<import>com.wabacus.system.*</import>
				</imports>
				<value>
				<![CDATA[
						
				]]>
		  		</value>
			</format>
		</report>
        <!-- 填写认领信息 -->
		<report id="dtl" title="认领信息" type="form" personalizeclass="default"
			servervalidateclass="com.ljbank.market.Servervalidate_ClaimGold;com.ljbank.market.Util"
			depends="list" dependsparams="TXN_RUN_NBR=@{TXN_RUN_NBR}" top="10px"
			refreshid="dtl">
			<buttons align="right">
				<button name="sub" position="title" positionorder="2"
					extends="${wabacus.button2.default}" label="提交"
					confirmessage="提交前请确认数据已经保存。提交后数据将不能修改，是否确认提交?">
					<params>
						<param name="user_id" value="session{user_id}"></param>
					</params>
					invokeServerActionForComponent('claim_thd', 'dtl',
					'com.customer.util.SubmitClaimThd',
					{},true,refreshComponentDisplay('claim_thd','dtl',true))
				</button>
			</buttons>
			<display>
				<col column="SCURT_AC" label="证券资金账号" ></col>
				<col column="VUCH_NBR" label="凭证号" ></col>
				<col column="BIZ_TYPE_NM" label="业务类型"></col>
				<col column="CST_NM" label="客户名"></col>
				<col column="ORG_NM" label="签约机构" ></col>					
				<col column="OPEN_DT" label="签约日期" br="true"></col>
				<col column="EMP_ID" label="认领人工号" ></col>
				<col column="EMP_NM" label="认领人姓名"></col>	
				<col column="EMP_ORG_NM" label="认领人机构"></col>
				<col column="CLAIM_STATUS_NM" label="认领状态"></col>
				<col column="CLAIM_DT" label="认领日期" br="true"></col>
				<col column="REMARK1" label="备注" datatype="varchar"
						valuestyleproperty="colspan='11';align='left'" br="true">
					<inputbox type="textareabox" styleproperty="style='width:99%',rows='3'"/>		
				</col>
				<col column="ORG_ID" label="签约构号"  displaytype="hidden"></col>
				<col column="EMP_ORG_ID" label="认领人机构号" displaytype="hidden"></col>
				<col column="VERIFY_DT" label="审批日期" displaytype="hidden"></col>
				<col column="VERIFY_EMP_ID" label="审批人" displaytype="hidden"></col>
				<col column="TXN_RUN_NBR" label="流水号" displaytype="hidden"></col>
			</display>

			<sql datasource="ds_db2">
				<select>
					<value><![CDATA[
						select thd.*,s.CLAIM_STATUS_NM
						from IBS.T1_THD_EMP_RELA thd
						left join IBS.T9_CLAIM_STATUS_TYPE S ON S.CLAIM_STATUS_ID=thd.CLAIM_STATUS_ID	
						WHERE thd.CLAIM_STATUS_ID in ('0','7') AND {#condition#}
					    ]]>
					</value>
					<condition name="TXN_RUN_NBR" hidden="true" >
						<value><![CDATA[thd.TXN_RUN_NBR = '#data#']]></value>
					</condition>
				</select>

				<update confirmessage="保存">
					<params>
						<param name="user_id" value="session{user_id}"></param>
						<param name="user_name" value="session{user_name}"></param>
						<param name="usr_org_id" value="session{usr_org_id}"></param>
						<param name="usr_org_nm" value="session{usr_org_nm}"></param>
						<param name="current_time" value="now{}" datatype="timestamp{yyyy-MM-dd}"></param>
						<param name="current_time1" value="now{}"
							datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
					</params>
					<value>
						<![CDATA[
							update IBS.T1_THD_EMP_RELA
							set CLAIM_STATUS_ID='0'
								,EMP_ID = #{user_id}
								,EMP_NM = #{user_name}
								,EMP_ORG_ID = #{usr_org_id}
								,EMP_ORG_NM = #{usr_org_nm}
								,CLAIM_DT=#{current_time}
							where TXN_RUN_NBR=@{TXN_RUN_NBR__old}
						]]>
					</value>
				</update>
			</sql>

			<format>
				<imports>
					<import>com.ljbank.util.*</import>
					<import>java.util.*</import>
					<import>java.text.*</import>
					<import>com.wabacus.system.*</import>
				</imports>
				<value>
				<![CDATA[
					String user_id = (String) rrequest.getRequest().getSession().getAttribute("user_id");
					String user_name = (String) rrequest.getRequest().getSession().getAttribute("user_name");
					String usr_org_nm = (String) rrequest.getRequest().getSession().getAttribute("usr_org_nm");
		        	EMP_ID=user_id;
		        	EMP_NM=user_name;
		        	EMP_ORG_NM=usr_org_nm;
		        	
				    rrequest.getRequest().getSession().setAttribute("TXN_RUN_NBR", TXN_RUN_NBR);
				    rrequest.getRequest().getSession().setAttribute("SCURT_AC", SCURT_AC);
				    
				]]>
		  		</value>
			</format>
		</report>
		<footer><![CDATA[
			<tr><td height="20px"></td></tr>
			<div style='float:left'>
				<font color='green'>提示：1-只能够填写本人认领信息，不可以代人认领。</font>
			</div>
			<tr><td height="20px"></td></tr>
			]]>
			</footer>
		</vpanel>
	</page>


</applications>
