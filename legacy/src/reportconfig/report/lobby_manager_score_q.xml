	<!-- 大堂经理服务质量打分 总行 -->
	<page id="lobby_manager_score_q" js="/webresources/script/validate.js">
		<interceptor>
			<imports>
				<import>java.lang</import>
				<import>com.wabacus.util</import>
				<import>java.sql.Connection</import>
				<import>java.sql.PreparedStatement</import>
				<import>java.sql.ResultSet</import>
				<import>javax.servlet.http.HttpSession</import>
				<import>javax.util</import>
				<import>javax.text</import>
				<import>com.ljbank.market.MyMath</import>
				<import>java.util.Date</import>
				<import>java.text.SimpleDateFormat</import>
			</imports>
			<preaction>
				<![CDATA[
						String beginTime = rrequest.getStringAttribute("MEASURE_DT", "");// 取出输入的查询时间
						System.out.println("beginTime:" + beginTime);
						if (beginTime.equals("")) 
						{
							Connection conn = rrequest.getConnection();
							PreparedStatement pstmt = null;
							try {
									String SQL = "Select DATA_DT from IBS.T8_DATA_DT";
									pstmt = conn.prepareStatement(SQL);
									ResultSet resultSet = pstmt.executeQuery();
									while (resultSet.next()) {
					                     String date=resultSet.getString("DATA_DT");
					                     rrequest.setAttribute("MEASURE_DT", date);
				                    }
									
									System.out.println("beginTime处理后时间为:" + beginTime);
									resultSet.close();
									pstmt.close();
								} 
							catch (Exception e) {
									e.printStackTrace();
							}
                        }
                    
				]]>
			</preaction>
		</interceptor>
		<header>${top.header}</header>
		<vpanel id="common_vpanel" width="1000px" align="center" title="">
			<report id="title" extends="title.report1" width="1300px"></report>
			<report id="report" type="listform" pagesize="15|20|-1" dataexport="richexcel"  width="1300px"
				personalizeclass="default" servervalidateclass="com.ljbank.market.Util">
				<display>
					<col column="{sequence:1}" label="序号" width="40px"></col>
					<col column="MEASURE_DT" label="统计日期" width="80px"></col>
					<col column="EMP_ID" width="60px" label="员工号" align="center"
						valuestyleproperty="style='mso-number-format:\@'" clickorderby="true">
					</col>
					<col column="EMP_NM" label="员工姓名" width="60px"></col>
					<col column="ORG_ID" label="机构号" width="60px" clickorderby="false"
						valuestyleproperty="style='mso-number-format:\@'"></col>
					<col column="ORG_NM" label="机构名" width="100px"></col>
					<col column="BRANCH_ORG_ID" label="分行机构号" width="60px"
						displaytype="hidden"></col>
					<col column="BRANCH_ORG_NM" label="分行机构名" width="100px"></col>
					<col column="PSTN_TYPE" label="主考核类别" width="80px" displaytype="hidden"></col>
					<col column="PSTN_TYPE_NM" label="主考核类别" width="100px"></col>
					<col column="SUB_PSTN_TYPE" label="子考核类别" width="40px"
						displaytype="hidden"></col>
					<col column="SUB_PSTN_TYPE_NM" label="子考核类别" width="120px"></col>

					<col column="SCORE" label="服务质量得分" align="center" width="120px"
						clickorderby="true">
						<inputbox type="textbox" styleproperty="style='width:100px'"></inputbox>
					</col>
				</display>

				<sql>
					<select>

						<value><![CDATA[
								SELECT   MEASURE_DT
										,EMP_ID
										,EMP_NM
										,ORG_ID
										,ORG_NM
										,BRANCH_ORG_ID
										,BRANCH_ORG_NM
										,POSITION_ID
										,POSITION_NM
										,PSTN_TYPE
										,PSTN_TYPE_NM
										,SUB_PSTN_TYPE
										,SUB_PSTN_TYPE_NM
										,SCORE
								FROM    IBS.T5_LOBBY_MANAGER_SCORE_Q
								WHERE  {#condition#}
						        ORDER BY MEASURE_DT DESC, BRANCH_ORG_ID, ORG_ID, EMP_ID
						]]>
						</value>
						<condition name="MEASURE_DT" label="日期" labelposition="left">
							<value>
						 	<![CDATA[(MEASURE_DT='#data#')]]>
							</value>
							<inputbox type="datepicker" styleproperty="style='width:120px'"
								jsvalidate="isDate(#label#格式为yyyy-MM-dd)">
							</inputbox>
						</condition>
						<condition name="EMP_ID" label="工号" labelposition="left">
							<value>
							 		<![CDATA[EMP_ID='#data#']]>
							</value>
							<inputbox styleproperty="style='width:100px'">
								<typeprompt width="300" count="10">
									<promptcol label="EMP_ID" value="EMP_ID" title="认领工号"
										matchmode="anywhere" casesensitive="false" />
									<promptcol label="EMP_NM" value="EMP_NM" title="姓名"
										matchmode="anywhere" casesensitive="false" />
									<datasource>
										<option
											source="@{Select DISTINCT EMP_ID, EMP_NM from IBS.T5_EMP  WHERE   {#matchcondition#}} " />
									</datasource>
								</typeprompt>
							</inputbox>
						</condition>
						<condition name="EMP_NM" label="姓名" labelposition="left">
							<value>
							 		<![CDATA[EMP_NM='#data#']]>
							</value>
							<inputbox styleproperty="style='width:100px'">
								<typeprompt width="300" count="10">
									<promptcol label="EMP_ID" value="EMP_ID" title="认领工号"
										matchmode="anywhere" casesensitive="false" />
									<promptcol label="EMP_NM" value="EMP_NM" title="姓名"
										matchmode="anywhere" casesensitive="false" />
									<datasource>
										<option
											source="@{Select DISTINCT EMP_ID, EMP_NM from IBS.T5_EMP  WHERE   {#matchcondition#}} " />
									</datasource>
								</typeprompt>
							</inputbox>
						</condition>
						<condition name="ORG_ID1" labelposition="left" label="分行" >
							<value>
							<![CDATA[(BRANCH_ORG_ID='#data#')]]>
							</value>
							<inputbox type="selectbox" styleproperty="style='width:150px'">
								<option label="全部" value=""></option>
								<option
									source="@{SELECT DISTINCT BRANCH_ORG_ID , CASE WHEN ORG_LEVEL_ID='2' THEN BRANCH_ORG_NM ELSE BRANCH_ORG_NM||'机关' END AS BRANCH_ORG_NM FROM IBS.T5_ORG WHERE ORG_TYPE_ID='EO' AND ORG_LEVEL_ID IN ('2','3') ORDER BY BRANCH_ORG_ID}"
									label="BRANCH_ORG_NM" value="BRANCH_ORG_ID" />
							</inputbox>
						</condition>
						<condition name="ORG_ID2" labelposition="left" label="支行">
							<value>
							<![CDATA[(ORG_ID='#data#')]]>
							</value>
							<inputbox type="selectbox" depends="ORG_ID1"
								styleproperty="style='width:150px'">
								<option label="全部" value=""></option>
								<option label="无" value="" type="false"></option>
								<option
									source="@{SELECT DISTINCT ORG_ID, ORG_NM FROM IBS.T5_ORG WHERE BRANCH_ORG_ID='#ORG_ID1#' and ORG_TYPE_ID='EO' AND ORG_LEVEL_ID IN ('1','2') ORDER BY ORG_ID}"
									label="ORG_NM" value="ORG_ID" />
							</inputbox>
						</condition>

					</select>
					

				</sql>
			</report>
		</vpanel>
	</page>
	
