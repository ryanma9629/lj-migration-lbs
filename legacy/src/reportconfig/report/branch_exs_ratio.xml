<page id="branch_exsRatio_query" js="/webresources/script/validate.js,/js/demo.js,/js/common.js">
	<interceptor>
		<imports>
			<import>com.ljbank.market.Util</import>
		</imports>
		<preaction>
	<![CDATA[
	Util u=new Util();
	String ip=u.getRemoteIP(rrequest);
	rrequest.getRequest().setAttribute("reqKey2", ip);
	]]>
</preaction>
	</interceptor>

	<header>${top.header}</header>

	<vpanel id="common_vpanel" width="1200px" align="center" title="">
		<report id="title" extends="title.report1" width="1200px"></report>
		<report id="select" type="listform" title="存量维护比例" width="1200px" pagesize="15|20|-1" rowselect="single" dataexport="richexcel"
			top="10px" personalizeclass="default" servervalidateclass="com.ljbank.market.Util" >

			<display>
				<col column="EXAM_YEAR" label="考核年度" width="70px"></col>
				<col column="EXAM_Q" label="季度" width="100px" displaytype="hidden"></col>
				<col column="QTD_NM" label="季度" width="100px"></col>
				<col column="BRANCH_ORG_NM" label="分行"  ></col>
				<col column="BRANCH_ORG_ID" displaytype="hidden"  ></col>
				<col column="act_bzjx" label="应发定量薪酬总额" datatype="double{#,###0.00}"></col>
				<col column="EXS_RATIO" label="存量维护比例" datatype="double{#,###0.00}"></col>
				<!-- <col column="exs_bzjx" label="季度存量维护薪酬" datatype="double{#,###0.00}" ></col> -->
				<col column="DIS_SCORE" label="二次分配额" datatype="double{#,###0.00}"></col>
				<col column="exs_bzjx_sum" label="应发存量维护薪酬总额" datatype="double{#,###0.00}"></col>
				<col column="STUS" label="状态" ></col>
			</display>
			<subdisplay>
				<statitems>
					<statitem property="item1" value="sum(act_bzjx)" datatype="float" statiscope="page|report" />
					<statitem property="item2" value="sum(EXS_RATIO)" datatype="float" statiscope="page|report"/>
					<!-- <statitem property="item3" value="sum(exs_bzjx)" datatype="float" statiscope="page|report" /> -->
					<statitem property="item4" value="sum(DIS_SCORE)" datatype="float" statiscope="page|report"/>
					<statitem property="item5" value="sum(exs_bzjx_sum)" datatype="float" statiscope="page|report"/>
				</statitems>
				<subrow>
					<subcol property="sprop1" colspan="3" valuestyleproperty="bgcolor='#CCFAFF' align='center'" />
					<subcol property="sprop2" colspan="1" valuestyleproperty="bgcolor='#CCFAFF' align='center'" />
					<subcol property="sprop3" colspan="1" valuestyleproperty="bgcolor='#CCFAFF' align='center'" />
					<!-- <subcol property="sprop4" colspan="1" valuestyleproperty="bgcolor='#CCFAFF' align='center'" />	 -->
					<subcol property="sprop5" colspan="1" valuestyleproperty="bgcolor='#CCFAFF' align='center'" />
					<subcol property="sprop6" colspan="1" valuestyleproperty="bgcolor='#CCFAFF' align='center'" />	
					<subcol property="sprop7" colspan="1" valuestyleproperty="bgcolor='#CCFAFF' align='center'" />	
				</subrow>
				<format>
				<imports>
					<import>com.wabacus.util.*</import>
				</imports>
					<value>
					<![CDATA[
						
						sprop1="合计";
						sprop2=Tools.formatDouble(String.valueOf(item1),"#,##0.00");
						sprop3=Tools.formatDouble(String.valueOf(item2),"#,##0.00");
						//sprop4=Tools.formatDouble(String.valueOf(item3),"#,##0.00");
						sprop5=Tools.formatDouble(String.valueOf(item4),"#,##0.00");
						sprop6=Tools.formatDouble(String.valueOf(item5),"#,##0.00");
						sprop7="";
					]]>
					</value>
				</format>
			</subdisplay>
			<sql>
				<select>
					<value><![CDATA[
							select es.MEASURE_DT
								,es.EXAM_YEAR
								,es.EXAM_Q
								,q.QTD_NM
								,es.BRANCH_ORG_ID
								,es.BRANCH_ORG_NM
								,es.EXS_RATIO
								,es.MODIFY_PEOPLE
								,es.MODIFY_TIME
								,es.MODIFY_IP
								,es.VERIFY_PEOPLE
								,es.VERIFY_TIME
								,es.VERIFY_IP
								,es.VERIFY_REMARK
								,es.STUS
								,coalesce(jx.bzjx,0) bzjx
								,coalesce(rt.RATION,0) RATION
								,coalesce(ds.DIS_SCORE,0) DIS_SCORE
								,round(coalesce(jx.bzjx,0)*coalesce(rt.RATION,0)*0.8,2) as act_bzjx
							,round(coalesce(jx.bzjx,0)*coalesce(rt.RATION,0)*0.8*coalesce(EXS_RATIO,0)/100.0,2) as exs_bzjx
							,round(coalesce(jx.bzjx,0)*coalesce(rt.RATION,0)*0.8*coalesce(EXS_RATIO,0)/100.0,2)+coalesce(ds.DIS_SCORE,0) as exs_bzjx_sum
							from IBS.T3_BRANCH_EXS_RATIO es
							inner join (
								Select MEASURE_DT 
								,jx.BRANCH_ORG_ID
								,jx.BRANCH_ORG_NM
								,ou.HEAD_ORG_ID
								,sum(BZJX) as bzjx
								from IBS.T5_EMP_BZJX jx
								inner join (
									select distinct BRANCH_ORG_ID , BRANCH_ORG_NM , HEAD_ORG_ID , HEAD_ORG_NM 
									from ibs.T5_ORG
									where ORG_TYPE_ID='EO'
								) ou on ou.BRANCH_ORG_ID=jx.BRANCH_ORG_ID
								where IS_EXAM='1' and EMP_TYPE<>'过渡期' and {#condition#}
								group by MEASURE_DT 
								,jx.BRANCH_ORG_ID
								,jx.BRANCH_ORG_NM
								,ou.HEAD_ORG_ID
							)jx on jx.MEASURE_DT=es.MEASURE_DT and jx.BRANCH_ORG_ID=es.BRANCH_ORG_ID and es.STUS='3'
							
							left join IBS.T3_branch_RATIO rt on rt.MEASURE_DT=jx.MEASURE_DT and rt.BRANCH_ORG_ID=jx.BRANCH_ORG_ID and rt.EFF_FLAG='1'
							left join ibs.T3_BRANCH_SEC_DISTRIBUTION ds on ds.MEASURE_DT=jx.MEASURE_DT and jx.BRANCH_ORG_ID=ds.BRANCH_ORG_ID and ds.DIS_TYP_CD='02' and ds.STUS='3'
							left join ibs.T9_YEAR_Q q on q.QTD=es.EXAM_Q
							order by es.MEASURE_DT desc,es.EXAM_YEAR desc,es.BRANCH_ORG_ID 							       
					]]>
					</value>
					<condition name="ORG_ID0" labelposition="left" label="用户机构" source="session{org_id}" hidden="true">
						<value>
						<![CDATA[(jx.BRANCH_ORG_ID='#data#' or ou.HEAD_ORG_ID='#data#')]]>
						</value>
					</condition>
					<condition name="EXAM_YEAR" label="考核年度" labelposition="left" defaultvalue="session{exam_year}">
						<value> 
							<![CDATA[jx.EXAM_YEAR = '#data#']]>
						</value>
						   <inputbox type="datepicker" styleproperty="style='width:100px'" dateformat="yyyy" jsvalidate="isNotEmpty(#label# 不允许为空);" ></inputbox>
					</condition>
					<condition name="EXAM_Q" label="考核季度"
						labelposition="left">
						<value> 
 									<![CDATA[jx.EXAM_Q = '#data#']]>
						</value>
						<inputbox type="selectbox" styleproperty="style='width:120px'">
							<option label="全部" value=""></option>
							<option label="一季度" value="01"></option>
							<option label="二季度" value="02"></option>
							<option label="三季度" value="03"></option>
							<option label="四季度" value="04"></option>
						</inputbox>
					</condition>
					<condition name="ORG_ID1" labelposition="left" label="分行">
						<value>
						<![CDATA[jx.BRANCH_ORG_ID='#data#']]>
						</value>
						<inputbox type="selectbox" styleproperty="style='width:150px'" depends="ORG_ID0">
							<option label="全部" value=""></option>
							<option
								source="@{SELECT DISTINCT BRANCH_ORG_ID , CASE WHEN ORG_LEVEL_ID='2' THEN BRANCH_ORG_NM ELSE BRANCH_ORG_NM||'机关' END AS BRANCH_ORG_NM 
								FROM IBS.T5_ORG 
								WHERE ORG_TYPE_ID='EO' AND ORG_LEVEL_ID IN ('2','3') and (ORG_ID='#ORG_ID0#' or HEAD_ORG_ID='#ORG_ID0#')  
								ORDER BY BRANCH_ORG_ID}"
								label="BRANCH_ORG_NM" value="BRANCH_ORG_ID" />
						</inputbox>
					</condition>
				</select>
			</sql>
			
		<format>
			<imports>
				<import>com.customer.util.*</import>
				<import>java.util.*</import>
				<import>java.text.*</import>
				<import>com.wabacus.system.*</import>
			</imports>
			<value>
			<![CDATA[
				if(STUS.equals("0")) STUS="保存";
				if(STUS.equals("1")) STUS="等待审核";
				if(STUS.equals("2")) STUS="审核不通过";
				if(STUS.equals("3")) STUS="审核通过";
			]]>
			</value>
		</format>
		<footer>
			<![CDATA[
			]]>
		</footer>
		</report>
	</vpanel>
</page>




