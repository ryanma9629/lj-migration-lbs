					<select>
						<value><![CDATA[
							SELECT
							     smy.RNK
							    ,smy.EMP_ID
							    ,smy.MEASURE_DT
							    ,smy.EMP_NM
							    ,smy.ORG_ID
							    ,smy.ORG_NM
							    ,smy.BRANCH_ORG_ID
							    ,smy.BRANCH_ORG_NM
							    ,smy.PSTN_TYPE
							    ,smy.PSTN_TYPE_NM
							    ,smy.SUB_PSTN_TYPE
							    ,smy.SUB_PSTN_TYPE_NM
							    ,smy.CCY_ID
							    ,smy.MTD_AMT
							    ,smy.QTD_AMT
							    ,smy.YTD_AMT
							    ,smy.CLS_BAL
							    ,smy.MTD_AVG_BAL
							    ,smy.QTD_AVG_BAL
							    ,smy.YTD_AVG_BAL
							    ,smy.MTD_BONUS
							    ,smy.QTD_BONUS
							    ,smy.YTD_BONUS
							    ,og.HEAD_ORG_ID
							FROM IBS.T2_EMP_FNC_PD_BONUS_SMY smy
							inner join IBS.T5_ORG og on og.ORG_ID=smy.ORG_ID and og.ORG_TYPE_ID='EO'
							WHERE   {#condition#}
							ORDER BY smy.RNK
						    ]]>
						</value>
						<condition name="EMP_ID" label="认领工号" labelposition="left">
