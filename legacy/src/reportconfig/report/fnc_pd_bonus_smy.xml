					<col column="MTD_AVG_BAL" label="月日均 " width="100px" align="right" datatype="double{0.00}" displaytype="hidden"></col>
					<col column="QTD_AVG_BAL" label="季日均 " width="100px" align="right" datatype="double{0.00}" displaytype="hidden"></col>
					<col column="YTD_AVG_BAL" label="年日均 " width="100px" align="right" datatype="double{0.00}" displaytype="hidden"></col>
