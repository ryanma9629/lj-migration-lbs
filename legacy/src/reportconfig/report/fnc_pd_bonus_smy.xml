							<![CDATA[(smy.BRANCH_ORG_ID='#data#')]]>
							</value>
							<inputbox type="selectbox" styleproperty="style='width:150px'" depends="ORG_ID0">
								<option label="全部" value=""></option>
								<option
									source="@{SELECT DISTINCT BRANCH_ORG_ID , CASE WHEN ORG_LEVEL_ID='2' THEN BRANCH_ORG_NM ELSE BRANCH_ORG_NM||'机关' END AS BRANCH_ORG_NM FROM IBS.T5_ORG WHERE ORG_TYPE_ID='EO' AND ORG_LEVEL_ID IN ('2','3') and HEAD_ORG_ID='#ORG_ID0#' ORDER BY BRANCH_ORG_ID}"
									label="BRANCH_ORG_NM" value="BRANCH_ORG_ID" />
							</inputbox>
						</condition>
						<condition name="ORG_ID2" labelposition="left" label="支行">
							<value>
							<![CDATA[(smy.ORG_ID='#data#')]]>
							</value>
							<inputbox type="selectbox" depends="ORG_ID1"
