<?xml version="1.0" encoding="UTF-8"?>
<applications xmlns="http://www.wabacus.com"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.wabacus.com ../xsd/wabacus.applications.xsd">

<!--公积金认领 -->
<page id="claim_hpf_txn"
	js="/webresources/script/validate.js,/js/demo.js,/js/common.js"><!-- /webresources/script/validate.js -->

	<header>${top.header}</header>
	<vpanel id="common_vpanel" width="1300px" align="center" title="">
		
		<report id="list" title="凭证信息" type="list" personalizeclass="default" 
		servervalidateclass="com.ljbank.market.Servervalidate_Fund;com.ljbank.market.Util"
		interceptor="com.customer.interceptor.InterceptorClaimHpfTxn" top="10px" >
		
			<display>
				<col column="TXN_DT" label="确认日期" ></col>
				<col column="TXN_NO" label="流水号" ></col>
				<col column="VUCH_NBR" label="凭证号" ></col>
				
				<col column="PRD_CD" label="产品代码"></col>
				<col column="PRD_NM" label="产品名称"></col>
				
				<col column="CST_NM" label="客户名称"></col>
				<col column="TXN_AMT" label="交易金额"></col>
				<col column="ORG_ID" label="交易机构号"  displaytype="hidden"></col>
				<col column="ORG_NM" label="交易机构" ></col>
				<col column="EMP_ORG_NM" label="认领人机构" ></col>					
				<col column="BIZ_TYPE_NM" label="业务类型" ></col>
				<col column="CLAIM_STATUS_NM" label="认领状态" ></col>
				<col column="RATIO_DFAULT" label="*认领比例(%)">
					<inputbox styleproperty="style='width:90%'"
						jsvalidate="isNumeric(不是合法数字);isNotEmpty(不可以为空值)"
						servervalidate="isClaimTxnRatio()" 
						/>
				</col>
				<col column="REMARK1" label="备注" datatype="varchar"
						valuestyleproperty="align='left'">
					<inputbox type="textareabox" styleproperty="style='width:99%'"/>		
				</col>
				<col column="EMP_ID" label="认领人" displaytype="hidden"></col>
                
			</display>
			<sql datasource="ds_db2">
				<select>
					<value><![CDATA[
						Select RE.*,S.CLAIM_STATUS_NM,(CASE WHEN RATIO=0 THEN 100 ELSE RATIO END) as RATIO_DFAULT
						from IBS.T1_FNC_TXN_EMP_RELA re
						left join IBS.T9_CLAIM_STATUS_TYPE S ON S.CLAIM_STATUS_ID=RE.CLAIM_STATUS_ID	
						WHERE RE.CLAIM_STATUS_ID in ('0','7') 
						AND {#condition#}
						
					    ]]>
					</value>
					<condition name="TXN_DT_ST"  label="确认日期" >
						<value><![CDATA[TXN_DT >= '#data#']]></value>
						<inputbox type="datepicker" styleproperty="style='width:120px'"
								jsvalidate="isDate(#label#格式为yyyy-MM-dd)">
							</inputbox>
					</condition>
					<condition name="TXN_DT_END"  label="至" >
						<value><![CDATA[TXN_DT <= '#data#']]></value>
						<inputbox type="datepicker" styleproperty="style='width:120px'"
								jsvalidate="isDate(#label#格式为yyyy-MM-dd)">
							</inputbox>
					</condition>
					<condition name="VUCH_NBR" label="凭证号">
						<value><![CDATA[VUCH_NBR='#data#']]></value>
					</condition>
					<condition name="TXN_NO" label="流水号">
						<value><![CDATA[TXN_NO='#data#']]></value>
					</condition>
				</select>
			</sql>

			
		</report>
		
		<!-- 填写认领信息 -->
		<report id="dtl" title="认领信息" type="form" personalizeclass="default"
			servervalidateclass="com.ljbank.market.Servervalidate_ClaimFncTxn;com.ljbank.market.Util"
			depends="list" dependsparams="txnNoPam=@{TXN_NO};empIdPam=@{EMP_ID};txnDtPam=@{TXN_DT}" top="10px"
			refreshid="dtl"  interceptor="com.customer.interceptor.InterceptorClaimFncDitlTxn">
			<buttons align="right">
				<button name="sub" position="title" positionorder="2"
					extends="${wabacus.button2.default}" label="提交"
					confirmessage="提交前请确认数据已经保存。提交后数据将不能修改，是否确认提交?">
					<params>
						<param name="user_id" value="session{user_id}"></param>
					</params>
					invokeServerActionForComponent('claim_hpf_txn', 'dtl',
					'com.customer.util.SubmitClaimFncTxn',
					{},true,refreshComponentDisplay('claim_hpf_txn','dtl',true))
				</button>
			</buttons>
			<display>
				<col column="TXN_NO" label="流水号" valuestyleproperty="style='width:150px'"></col>
				<col column="VUCH_NBR" label="凭证号" valuestyleproperty="style='width:150px'"></col>
				<col column="BIZ_TYPE_NM" label="业务类型"></col>
				<col column="CST_NM" label="客户名"></col>
				<col column="TXN_AMT" label="交易金额"></col>
				<col column="ORG_ID" label="交易机构号"  displaytype="hidden"></col>
				<col column="ORG_NM" label="交易机构" displaytype="hidden"></col>					
				<col column="TXN_DT" label="交易日期" br="true"></col>
				
				<col column="EMP_ID" label="认领人工号" displaytype="hidden"></col>
				<col column="EMP_ID_Hid" label="认领人工号2" displaytype="hidden"></col>
				<col column="EMP_NM" label="认领人姓名" displaytype="hidden"></col>	
				<col column="EMP_ORG_ID" label="认领人机构号" displaytype="hidden"></col>
				<col column="EMP_ORG_NM" label="认领人机构" displaytype="hidden"></col>
				<col column="RATIO" label="*认领比例(%)">
					<inputbox styleproperty="style='width:90%'"
						servervalidate="isClaimRatio()" 
						/>
				</col>
				<!--  
				<col column="CLAIM_STATUS_NM" label="认领状态"></col>
				<col column="CLAIM_DT" label="认领日期" br="true"></col>
				-->
				<col column="REMARK1" label="备注" datatype="varchar" valuestyleproperty="align='left';colspan='5'" >
					<inputbox type="textareabox"  />		
				</col>
				<col column="VERIFY_DT" label="审批日期" displaytype="hidden"></col>
				<col column="VERIFY_EMP_ID" label="审批人" displaytype="hidden"></col>
			</display>

			<sql datasource="ds_db2">
				<select>
					<value><![CDATA[
						Select RE.*,S.CLAIM_STATUS_NM,re.EMP_ID as EMP_ID_Hid
						from IBS.T1_FNC_TXN_EMP_RELA re
						left join IBS.T9_CLAIM_STATUS_TYPE S ON S.CLAIM_STATUS_ID=RE.CLAIM_STATUS_ID	
						WHERE RE.CLAIM_STATUS_ID in ('0','7') AND {#condition#}
						order by VUCH_NBR,RE.CLAIM_STATUS_ID,TXN_DT DESC
						
					    ]]>
					</value>
					<condition name="txnNoPam" hidden="true">
						<value><![CDATA[TXN_NO='#data#']]></value>
					</condition>
					<condition name="empIdPam" hidden="true" >
						<value><![CDATA[EMP_ID = '#data#']]></value>
					</condition>
					<condition name="txnDtPam" hidden="true">
						<value><![CDATA[TXN_DT='#data#']]></value>
					</condition>
				</select>

				<update confirmessage="保存">
					<params>
						<param name="user_id" value="session{user_id}"></param>
						<param name="user_name" value="session{user_name}"></param>
						<param name="usr_org_id" value="session{usr_org_id}"></param>
						<param name="usr_org_nm" value="session{usr_org_nm}"></param>
						<param name="current_time" value="now{}" datatype="timestamp{yyyy-MM-dd}"></param>
						<param name="current_time1" value="now{}"
							datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
					</params>
					<value>
						<![CDATA[
							update IBS.T1_FNC_TXN_EMP_RELA
							set RATIO = @{RATIO},REMARK1=@{REMARK1}
								,CLAIM_STATUS_ID='0'
								,EMP_ID = #{user_id}
								,EMP_NM = #{user_name}
								,EMP_ORG_ID = #{usr_org_id}
								,EMP_ORG_NM = #{usr_org_nm}
								,CLAIM_DT=#{current_time}
							where TXN_NO=@{TXN_NO}
							and EMP_ID=@{EMP_ID_Hid}
							and TXN_DT=@{TXN_DT}
						]]>
					</value>
				</update>
			</sql>

			<format>
				<imports>
					<import>com.ljbank.util.*</import>
					<import>java.util.*</import>
					<import>java.text.*</import>
					<import>com.wabacus.system.*</import>
				</imports>
				<value>
				<![CDATA[
					String user_id = (String) rrequest.getRequest().getSession().getAttribute("user_id");
					String user_name = (String) rrequest.getRequest().getSession().getAttribute("user_name");
					String usr_org_nm = (String) rrequest.getRequest().getSession().getAttribute("usr_org_nm");
		        	EMP_ID=user_id;
		        	EMP_NM=user_name;
		        	EMP_ORG_NM=usr_org_nm;
				    rrequest.getRequest().getSession().setAttribute("txn_nbr", TXN_NO);
				    rrequest.getRequest().getSession().setAttribute("EMP_ID", EMP_ID);
				    rrequest.getRequest().getSession().setAttribute("txn_dtr", TXN_DT);
				    rrequest.getRequest().getSession().setAttribute("RATIO", RATIO);
				    rrequest.getRequest().getSession().setAttribute("VUCH_NBR", VUCH_NBR);
				    rrequest.getRequest().getSession().setAttribute("REMARK1", REMARK1);
				]]>
		  		</value>
			</format>

		<footer><![CDATA[
			<tr><td height="20px"></td></tr>
			<div style='float:left'>
				<font color='green'>提示：1-只能够填写本人认领信息，不可以代人认领。</font>
			</div>
			<tr><td height="20px"></td></tr>
			]]>
			</footer>
			</report>
		</vpanel>
	</page>
	


</applications>
