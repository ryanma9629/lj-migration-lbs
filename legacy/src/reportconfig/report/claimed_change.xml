				</display>
				<sql datasource="ds_db2"><!-- beforesave="ChangeRatio(请核对认领比例)" beforesave="ChangeRatio" -->
					<select>
						<value><![CDATA[
							SELECT   re.VUCH_NBR                        
									,re.VUCH_NBR as VUCH_NBR_1
									,re.EMP_ID                
									,re.EMP_NM                
									,coalesce(re.RVS_RATIO,re.RATIO) as RATIO
									,re.RATIO as RATIO_Y
								    ,re.CLAIM_STATUS_ID as CLAIM_STATUS_ID_xs
								    ,re.CLAIM_STATUS_ID
									,re.CLAIM_DT 
									,re.VERIFY_DT             
									,re.VERIFY_EMP_ID      
									,C.EMP_NM AS VERIFY_EMP_NM
							  	    ,re.REMARK   
							  	    ,re.ORG_ID
									,re.ORG_NM
									,re.CST_NM
									,re.BIZ_TYPE_NM
									,re.VUCH_STATUS_NM
									,re.OPEN_DT
									,re.EMP_ORG_ID
									,re.EMP_ORG_NM 
									,coalesce(rs.RVS_STATUS_NM,st.CLAIM_STATUS_NM) as CLAIM_STATUS_NM 
									,re.RVS_STATUS_ID
							FROM     IBS.T1_VUCH_EMP_RELA re            
							LEFT JOIN IBS.T5_EMP C ON re.VERIFY_EMP_ID=C.EMP_ID
							left join ibs.T9_CLAIM_STATUS_TYPE st on st.CLAIM_STATUS_ID=re.CLAIM_STATUS_ID
							left join IBS.T9_RVS_STATUS_TYPE rs on rs.RVS_STATUS_ID=re.RVS_STATUS_ID
							where (re.CLAIM_STATUS_ID in ('2', '5', '6') and coalesce(re.RVS_STATUS_ID,'') not in ('1','21'))
							AND COALESCE(re.MARKETING_NO,'') not in ('2016qq')
							and {#condition#}
							  
						    ]]>
						</value>
						<condition name="txtvuch" hidden="true">
							<value><![CDATA[re.VUCH_NBR='#data#']]></value>
						</condition>
						<condition name="EMP_ID" hidden="true" source="session{user_id}">
							<value><![CDATA[re.EMP_ID='#data#']]></value>
						</condition>
					</select>

					<update>
						<params>
							<param name="user_id" value="session{user_id}"></param>
							<param name="user_nm" value="session{user_name}"></param>
							<param name="current_time" value="now{}" datatype="timestamp{yyyy-MM-dd}"></param>
							<param name="current_tm" value="now{}" datatype="time{HH:mm:ss}"></param>
							<param name="current_dt" value="now{}" datatype="date{yyyy-MM-dd}"></param>
							<param name="txtvuch" value="url{txtvuch}"></param>
						</params>
						<value>
							<![CDATA[
							update IBS.T1_VUCH_EMP_RELA 
							set 
									 
								  EMP_ORG_ID = @{EMP_ORG_ID}     
						         ,EMP_ORG_NM =@{EMP_ORG_NM}       
							     ,RVS_STATUS_ID='0'
							     ,RVS_EMP_ID=#{user_id}
							     ,RVS_EMP_NM=#{user_nm}
							     ,RVS_DT=#{current_time}
							     ,RVS_RATIO=@{RATIO}
							where EMP_ID = @{EMP_ID__old}      
							and   VUCH_NBR = @{VUCH_NBR}
							 
							;
							update IBS.T6_VUCH_EMP_RELA_CHANGE_LOG set CHANGE_FLAG='1'
							where VUCH_NBR= @{VUCH_NBR} 
							and NEW_EMP_ID=@{EMP_ID__old}
							AND CHANGE_FLAG='0' and NEW_CLAIM_STATUS_ID='2'
							;
							
							delete from IBS.T6_VUCH_EMP_RELA_CHANGE_LOG 
							where VUCH_NBR= @{VUCH_NBR} 
							and NEW_EMP_ID=@{EMP_ID__old}
							AND CHANGE_FLAG='0' 	
							;
													
							Insert into IBS.T6_VUCH_EMP_RELA_CHANGE_LOG
							(
								 VUCH_NBR              
								,OLD_EMP_ID           
								,OLD_RATIO            
								,OLD_CLAIM_STATUS_ID  
								,OLD_CLAIM_DT         
								,OLD_VERIFY_DT        
								,OLD_VERIFY_EMP_ID    
								,OLD_REMARK           
								,NEW_EMP_ID           
								,NEW_RATIO            
								,NEW_CLAIM_STATUS_ID  
								,NEW_CLAIM_DT         
								      
								,NEW_REMARK 
								,CHANGE_TYPE 
								,CHANGE_FLAG         
							)      
							Values
							(
								 #{txtvuch}
								,@{EMP_ID__old}
								,@{RATIO_Y}
								,@{CLAIM_STATUS_ID}
								,@{CLAIM_DT__old}
								,@{VERIFY_DT__old}
								,@{VERIFY_EMP_ID__old}
								,@{REMARK__old}
								,@{EMP_ID__old}
								,@{RATIO}
								,'0'
								,#{current_time}
								
								,' 调整人工号'||#{user_id}||' 姓名'||#{user_nm}||' 时间'||#{current_dt}||' '||#{current_tm}||' 备注认领调整。'
								,'U'
								,'0'
							)
							;
							

							]]>
						</value>
					</update>
