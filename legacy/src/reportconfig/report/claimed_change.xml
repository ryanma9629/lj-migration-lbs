	<!-- 认领调整：发起 -->
	<page id="claimed_change" js="/webresources/script/validate.js">


		<header>${top.header}</header>
		<vpanel id="common_vpanel" width="1300px" align="center" title="">

			<report id="title" extends="title.report1" width="1300px"></report>
			<report id="select" type="listform" title="账户信息" width="1300px"
				top="10px" personalizeclass="default"
				interceptor="com.customer.interceptor.InterceptorClaimedChange" rowselect="single"><!-- InterceptorClaimedChange -->


				<display><!--displaytype="hidden" -->
					<col column="{sequence:1}" label="序号" width="40px"></col>
					<col column="VUCH_NBR" label="凭证号" width="150px"
						valuestyleproperty="style='mso-nubmer-format:\@'"></col>
					<col column="CST_NM" label="客户名" width="250px"></col>
					<col column="ORG_NM" label="开户机构名" width="150px"></col>
					<col column="OPEN_DT" label="开户日期" width="80px"></col>
					<col column="VUCH_STATUS_NM" label="凭证状态名称" width="80px"></col>
					<col column="BIZ_TYPE_NM_NEW" label="业务类型名称" width="80px"></col>
					<col column="SUM" label="可调整的认领比例" width="100px" datatype="int"></col>
					
				</display>

				<sql datasource="ds_db2">
					<select>
						<value><![CDATA[
							SELECT   re.VUCH_NBR,
							         re.CST_NM,
							         re.ORG_ID,
							         re.ORG_NM,
							         re.OPEN_DT,
							         bt.BIZ_TYPE_NM_NEW,
							         re.VUCH_STATUS_NM,
							         (100-coalesce(t.OTHER_RATION,0)) AS SUM
							FROM IBS.T1_VUCH_EMP_RELA re
							inner join IBS.T9_BIZ_TYPE bt on bt.BIZ_TYPE_NM=re.BIZ_TYPE_NM
							LEFT JOIN (
								select VUCH_NBR,sum(RATIO) as OTHER_RATION,BIZ_TYPE_NM
								from IBS.T1_VUCH_EMP_RELA
								where CLAIM_STATUS_ID in ('2', '1', '21')
								and EMP_ID <> {#EMP_ID#}
								group by VUCH_NBR,BIZ_TYPE_NM
							)t on t.VUCH_NBR=re.VUCH_NBR 
							WHERE {#condition#} 
							AND COALESCE(MARKETING_NO,'') not in ('2016qq')
							AND re.CLAIM_STATUS_ID in ('2', '5', '6','1')  
							ORDER BY bt.BIZ_TYPE_NM_NEW, re.VUCH_NBR
						    ]]>
						</value>
						<condition name="EMP_ID" label="员工号" labelposition="left" hidden="true" source="session{user_id}">
							<value><![CDATA[re.EMP_ID = '#data#']]></value>
						</condition>
						<condition name="VUCH_NBR" label="凭证号" labelposition="left">
							<value><![CDATA[re.VUCH_NBR='#data#']]></value>
						</condition>
						<condition name="CST_NM" label="客户名称" labelposition="left">
							<value><![CDATA[re.CST_NM like '#data#%']]></value>
						</condition>
						
						<condition name="BIZ_TYPE_NM" labelposition="left" label="业务类型">
							<value>
							<![CDATA[bt.BIZ_TYPE_NM_NEW='#data#']]>
							</value>
							<inputbox type="selectbox">
								<option label="全部" value=""></option>
								<option
									source="@{Select distinct BIZ_TYPE_NM_NEW from IBS.T9_BIZ_TYPE order by BIZ_TYPE_NM_NEW }"
									label="BIZ_TYPE_NM_NEW" value="BIZ_TYPE_NM_NEW" />
							</inputbox>
						</condition>
					</select>

				</sql>
			</report>
			<!-- 认领信息 -->
			<report id="other_dtl" title="认领信息" type="listform"
				interceptor="com.customer.interceptor.InterceptorClaimedChangeDtl"
				personalizeclass="default" depends="select" dependsparams="txtvuch=@{VUCH_NBR}"
				top="10px" rowselect="single">
				<display valuetdwidth="120px" labeltdwidth="80px">
					<col column="VUCH_NBR" label="凭证号隐藏" displaytype="hidden"
						valuestyleproperty="style='mso-nubmer-format:\@'" filter="condition{txtvuch}"></col>
					<col column="VUCH_NBR_1" label="凭证号" width="200px"
						valuestyleproperty="style='mso-nubmer-format:\@'"></col>
					<col column="EMP_ID" label="认领工号" clickorderby="true"
						valuestyleproperty="style='mso-nubmer-format:\@'"></col>
					<col column="EMP_NM" label="认领姓名"></col>
					<col column="RATIO" label="原认领比例(%)"></col>
					<col column="NEW_RATIO" label="调整后比例(%)"></col>
					<col column="CLAIM_STATUS_NM" label="认领状态"></col>
					<col column="CLAIM_DT" label="认领时间"></col>
					<col column="VERIFY_DT" label="审核时间"></col>
					<col column="VERIFY_EMP_NM" label="审核人" ></col>
					<col column="VERIFY_EMP_ID" label="审核人工号" displaytype="hidden"></col>
					<col column="REMARK" label="备注" displaytype="hidden"></col>
					
					
				</display>
				<sql datasource="ds_db2">
					<select>
						<value><![CDATA[
							SELECT  re.VUCH_NBR                        
								,re.VUCH_NBR as VUCH_NBR_1
								,re.EMP_ID                
								,re.EMP_NM                
								,re.RATIO as RATIO
								
								,re.CLAIM_STATUS_ID
								,re.CLAIM_DT 
								,re.VERIFY_DT             
								,re.VERIFY_EMP_ID      
								,C.EMP_NM AS VERIFY_EMP_NM
							    ,re.REMARK   
							    ,coalesce(rs.RVS_STATUS_NM,st.CLAIM_STATUS_NM) as CLAIM_STATUS_NM 
							    ,RVS_RATIO as NEW_RATIO  
							FROM IBS.T1_VUCH_EMP_RELA re            
							LEFT JOIN IBS.T5_EMP C ON re.VERIFY_EMP_ID=C.EMP_ID
							left join ibs.T9_CLAIM_STATUS_TYPE st on st.CLAIM_STATUS_ID=re.CLAIM_STATUS_ID
							left join IBS.T9_RVS_STATUS_TYPE rs on rs.RVS_STATUS_ID=re.RVS_STATUS_ID
							 
							where (re.CLAIM_STATUS_ID in ('1','21','2', '5', '6') or coalesce(re.RVS_STATUS_ID,'') in ('1','2','21')) 
							and COALESCE(re.MARKETING_NO,'') not in ('2016qq')
							and {#condition#}
							order by re.CLAIM_STATUS_ID,re.CLAIM_DT,re.VUCH_NBR 
						    ]]>
						</value>
						<condition name="txtvuch" hidden="true">
							<value><![CDATA[re.VUCH_NBR='#data#']]></value>
						</condition>
						<!-- 
						<condition name="EMP_ID" hidden="true" source="session{user_id}">
							<value><![CDATA[re.EMP_ID<>'#data#']]></value>
						</condition>
						 -->
					</select>
				</sql>
				<format>
					<imports>
						<import>com.ljbank.util.*</import>
						<import>java.util.*</import>
						<import>java.text.*</import>
						<import>com.wabacus.system.*</import>
					</imports>
					<value>
					<![CDATA[
					
					]]>
			  		</value>
				</format>
