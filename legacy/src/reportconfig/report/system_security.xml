<?xml version="1.0" encoding="UTF-8"?>
<applications xmlns="http://www.wabacus.com"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.wabacus.com ../xsd/wabacus.applications.xsd">

	<!-- page list 2012-5-8 -->
	<!-- table name: sys_c_sec_page -->
	<!--id,page_id,page_name,page_description,report_id,report_title,report_seq,report_type,lm_user,lm_time -->
	<page id="system_page_list" js="/webresources/script/validate.js">
		<header>${top.header}</header>
		<vpanel id="common_vpanel" align="center" width="1000px">
			<report id="report1" title="所有功能列表" type="listform" pagesize="10|20|-1"
				navigate="${navigatepagesizepage1.report3.navigate}" width="1000px"
				scrollheight="450px">
				<buttons>
					<button name="button1" position="title" extends="${add.button.default}"></button>
					<button name="button2" position="title" extends="${delete.button.default}"></button>
					<button name="button3" position="title" extends="${save.button.default}"></button>
				</buttons>
				<display colselect="false">
					<col column="{sequence:1}" label="序号" width="80px"></col>
					<col column="page_id" label="页面ID">
						<inputbox styleproperty="style='width:99%'"></inputbox>
					</col>
					<col column="page_name" label="页面名称" width="300px">
						<inputbox styleproperty="style='width:99%'"></inputbox>
					</col>
					<col column="page_description" label="页面描述" width="200px">
						<inputbox styleproperty="style='width:99%'"></inputbox>
					</col>
					<col column="hits" label="点击率" width="100px">
						<inputbox styleproperty="style='width:99%'"></inputbox>
					</col>
				</display>
				<sql>
					<select>
						<value>
						<![CDATA[select page_id,page_name,page_description,hits,
										lm_user,lm_time
										from cst.sys_c_sec_page where {#condition#} and service_id='060' order by page_id ]]>
					</value>
						<condition name="txt_page_id" label="页面ID">
							<value>
							<![CDATA[(page_id like  '%#data#%' )]]>
							</value>
						</condition>
					</select>
					<insert>
						<params>
							<param name="user_id" value="session{user_id}"></param>
							<param name="current_time" value="now{}"
								datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
						</params>
						<value>
						insert into
						cst.sys_c_sec_page(@{page_id},@{page_name},@{page_description},hits=0,lm_user=#{user_id},lm_time=#{current_time},service_id='060');
					</value>
					</insert>
					<update>
						<params>
							<param name="user_id" value="session{user_id}"></param>
							<param name="current_time" value="now{}"
								datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
						</params>
						<value>
						update
						cst.sys_c_sec_page(@{page_id},@{page_name},@{page_description},lm_user=#{user_id},lm_time=#{current_time})
						where page_id=@{page_id__old} and service_id='060';
					</value>
					</update>
					<delete>
						delete from cst.sys_c_sec_page where page_id=@{page_id} and
						service_id='060';
				</delete>
				</sql>
			</report>
		</vpanel>
	</page>


	<page id="system_group" js="/webresources/script/validate.js">
		<header>${top.header}</header>
		<vpanel id="common_vpanel" parenttitle="组" align="center"
			width="1000px">
			<report id="report1" title="组别" type="listform" cellresize="0"
				celldrag="0" pagesize="6|20|-1" navigate="${navigatepagesizepage1.report3.navigate}"
				width="1000px" scrollheight="200px">
				<display colselect="false">
					<col column="{sequence:1}" label="序号" width="100px" />
					<col column="group_id" label="组别" filter="condition{txt_group_id}"
						width="250px">
						<inputbox styleproperty="style='width:99%'"></inputbox>
					</col>
					<col column="group_description" label="描述">
						<inputbox styleproperty="style='width:99%'"></inputbox>
					</col>
				</display>
				<sql>
					<select>
						<value>
						<![CDATA[select group_id,group_description,lm_user,lm_time
										 from cst.sys_c_sec_grop where {#condition#} and service_id='060' order by group_description,group_id  ]]>
						</value>
						<condition name="txt_group_id" label="组别" hidden="true">
							<value>
							<![CDATA[(group_id =  '#data#' )]]>
							</value>
						</condition>
					</select>
					<insert>
						<params>
							<param name="user_id" value="session{user_id}"></param>
							<param name="current_time" value="now{}"
								datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
						</params>
						<value>
							insert into
							cst.sys_c_sec_grop(@{group_id},@{group_description},lm_user=#{user_id},lm_time=#{current_time},service_id='060');
						</value>
					</insert>
					<update>
						<params>
							<param name="user_id" value="session{user_id}"></param>
							<param name="current_time" value="now{}"
								datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
						</params>
						<value>
							update
							cst.sys_c_sec_grop(@{group_id},@{group_description},lm_user=#{user_id},lm_time=#{current_time})
							where group_id=@{group_id__old} and service_id='060';
							update cst.sys_c_sec_gppv (@{group_id}) where group_id=@{group_id__old} and service_id='060';
							update cst.sys_c_app_mnlt (@{group_id}) where group_id=@{group_id__old} ;
						</value>
					</update>
					<delete>
						delete from cst.sys_c_sec_grop where group_id=@{group_id}
						and service_id='060';
						delete from cst.sys_c_sec_gppv where
						group_id=@{group_id} and service_id='060';
						delete from
						cst.sys_c_app_mnlt where group_id=@{group_id};
					</delete>
				</sql>
			</report>
			<tabpanel id="tab1" titlealign="left" titlewidth="120px"
				titlestyle="2" top="1">
				<report id="report1_1" parenttitle="权限设置" title="url{txt_group_id} 权限设置"
					type="listform" depends="report1" dependsparams="txt_group_id=@{group_id}"
					pagesize="10|20|-1" navigate="${navigatepagesizepage1.report3.navigate}"
					cellresize="0" celldrag="0" width="1000px" scrollheight="270px">
					<display colselect="false" minrownum="1">
						<col column="{sequence:1}" label="序号" width="100px" />
						<col column="group_id" label="组别" displaytype="hidden">
						</col>
						<col column="privilege_id" label="权限" clickorderby="true"
							width="250px">
							<inputbox type="selectbox" jsvalidate="isNotEmpty(#label#列不允许为空)"
								styleproperty="style='width:99%'">
								<option lable="请选择权限..." value=""></option>
								<option
									source="@{ select privilege_id from cst.sys_c_sec_priv where service_id='060' order by privilege_id } "
									label="privilege_id" value="privilege_id">
								</option>
							</inputbox>
						</col>
						<col column="privilege_description" label="权限描述"></col>
						<!-- <col column="lm_user" label="修改人" clickorderby="true" /> <col 
							column="lm_time" label="修改时间" clickorderby="true" datatype="date{yyyy-MM-dd}"/> -->
					</display>
					<sql>
						<select>
							<value>
							<![CDATA[select gp.group_id,gp.privilege_id, gp.lm_user,gp.lm_time,p.privilege_description
											 from cst.sys_c_sec_gppv gp 
											 left join cst.sys_c_sec_priv p on gp.privilege_id=p.privilege_id
											 where {#condition#} and gp.service_id='060' order by group_id  ]]>
							</value>
							<condition name="txt_group_id" label="组别" hidden="true">
								<value>
								<![CDATA[(gp.group_id = '#data#' )]]>
								</value>
							</condition>
						</select>
						<insert>
							<params>
								<param name="user_id" value="session{user_id}"></param>
								<param name="current_time" value="now{}"
									datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
								<param name="url_group_id" value="url{txt_group_id}"></param>
							</params>
							<value>
								insert into
								cst.sys_c_sec_gppv(group_id=#{url_group_id},@{privilege_id},lm_user=#{user_id},lm_time=#{current_time}, service_id='060');
							</value>
						</insert>
						<update>
							<params>
								<param name="user_id" value="session{user_id}"></param>
								<param name="current_time" value="now{}"
									datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
							</params>
							<value>
								update
								cst.sys_c_sec_gppv(@{privilege_id},lm_user=#{user_id},lm_time=#{current_time})
								where group_id=@{group_id} and privilege_id=@{privilege_id__old} and service_id='060';
							</value>
						</update>
						<delete>
							delete from cst.sys_c_sec_gppv where group_id=@{group_id}
							and
							privilege_id=@{privilege_id} and service_id='060'; 
						</delete>
					</sql>
				</report>


				<report id="report1_2" parenttitle="用户设置" title="url{txt_group_id}用户设置"
					type="listform" depends="report1" dependsparams="txt_group_id=@{group_id}"
					pagesize="10|20|-1" navigate="${navigatepagesizepage1.report3.navigate}"
					cellresize="0" celldrag="0" width="1000px" scrollheight="270px">
					<display colselect="false" minrownum="1">
						<col column="{sequence:1}" label="序号" width="100px" />

						<col column="USER_ID" label="用户" clickorderby="true">
							<inputbox styleproperty="style='width:99%'">
								<autocomplete columns="USER_NAME;ORG_ID;ORG_NM"
									colvaluecondition="USER_ID like '%#USER_ID#%'"
									dataset="select a.user_id,a.user_name,b.ORG_ID,b.ORG_NM from CST.SYS_C_SEC_USER a left join IBS.T5_ORG b on a.ORG_ID=b.ORG_ID and b.ORG_TYPE_ID='EO' where 1=1 {#condition#} order by user_name"></autocomplete>
							</inputbox>
						</col>


						<col column="USER_NAME " label="用户姓名" clickorderby="true"
							width="150px">
							<inputbox></inputbox>
						</col>
						<col column="ORG_ID " label="机构号" clickorderby="true" width="150px">
							<inputbox></inputbox>
						</col>
						<col column="ORG_NM " label="机构" clickorderby="true" width="250px">
							<inputbox></inputbox>
						</col>
					</display>
					<sql>
						<select>
							<value>
							<![CDATA[

								select A.USER_ID,B.USER_NAME,D.ORG_ID,D.ORG_NM from cst.SYS_C_SEC_USER_GROUP a
								LEFT JOIN CST.SYS_C_SEC_USER B
								ON A.USER_ID =B.USER_ID
								LEFT JOIN CST.SYS_C_SEC_GROP C
								ON A.GROUP_ID=C.GROUP_ID
								LEFT JOIN IBS.T5_ORG D
								ON B.ORG_ID=D.ORG_ID AND D.ORG_TYPE_ID='EO'
								WHERE B.IS_ENABLE='Y' AND C.SERVICE_ID='060' AND {#condition#} 
								ORDER BY D.ORG_ID, A.USER_ID
							]]>
							</value>
							<condition name="txt_group_id" label="组别" hidden="true">
								<value>
								<![CDATA[(C.group_id = '#data#' )]]>
								</value>
							</condition>
						</select>
						<insert>
							<params>
								<param name="user_id1" value="session{user_id}"></param>
								<param name="current_time" value="now{}"
									datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
								<param name="url_group_id" value="url{txt_group_id}"></param>
							</params>
							<value>
								insert into
								cst.SYS_C_SEC_USER_GROUP(group_id=#{url_group_id},@{USER_ID},lm_user=#{user_id1},lm_time=#{current_time});
							</value>
						</insert>
						<update>
							<params>
								<param name="url_group_id" value="url{txt_group_id}"></param>
								<param name="user_id1" value="session{user_id}"></param>
								<param name="current_time" value="now{}"
									datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
							</params>
							<value>
								update
								cst.SYS_C_SEC_USER_GROUP(@{USER_ID},lm_user=#{user_id1},lm_time=#{current_time})
								where group_id=#{url_group_id};
							</value>
						</update>
						<delete>
							<params>

								<param name="url_group_id" value="url{txt_group_id}"></param>
							</params>
							delete from cst.SYS_C_SEC_USER_GROUP where
							group_id=#{url_group_id} AND USER_ID=@{USER_ID}
						</delete>
					</sql>
				</report>
				<!-- xbs add end -->
				<report id="report1_3" parenttitle="菜单设置" title="url{txt_group_id} 菜单设置"
					type="listform" depends="report1" dependsparams="txt_group_id=@{group_id}"
					pagesize="10|20|-1" navigate="${navigatepagesizepage1.report3.navigate}"
					width="1000px" scrollheight="270px">
					<display colselect="false" minrownum="1">
						<col column="{sequence:1}" label="序号" width="60px" />
						<col column="id" displaytype="hidden" />
						<col column="menu_id" displaytype="hidden"></col>
						<col column="menu_name" label="菜单" width="120px" updatecol="@{menu_id}"
							filter="true" filterwidth="120px">
							<inputbox type="selectbox" jsvalidate="isNotEmpty(#label#列不允许为空)"
								styleproperty="style='width:99%'">
								<option lable="请选择菜单..." value=""></option>
								<option
									source="@{ select menu_id,menu_name from cst.sys_c_app_menu where service_id='060' order by seq } "
									label="menu_name" value="menu_id">
								</option>
							</inputbox>
						</col>
						<col column="group_id" label="用户组" displaytype="hidden">
						</col>
						<col column="page_id" label="页面ID" clickorderby="true">
							<inputbox styleproperty="style='width:99%'">
								<autocomplete columns="page_name"
									colvaluecondition="page_id = '#page_id#'"
									dataset="select page_id,page_name from cst.sys_c_sec_page where  {#condition#} order by page_name"></autocomplete>
							</inputbox>
						</col>
						<col column="page_name" label="页面名称" width="160px">
							<inputbox styleproperty="style='width:99%'"></inputbox>
						</col>
						<col column="url_param" label="url参数" width="80px">
							<inputbox styleproperty="style='width:99%'"></inputbox>
						</col>
						<col column="seq" label="次序" width="5%">
							<inputbox styleproperty="style='width:99%'"></inputbox>
						</col>
						<col column="is_show" label="是否显示" width="100px">
							<inputbox type="selectbox" defaultvalue="Y"
								styleproperty="style='width:99%'">
								<option value="Y" label="Y"></option>
								<option value="N" label="N"></option>
							</inputbox>
						</col>
					</display>
					<sql>
						<select>
							<value>
							<![CDATA[select mt.id,mt.menu_id,mn.menu_name,mn.seq as menu_seq,mt.group_id,mt.page_id,mt.page_name,mt.url_param,mt.seq,mt.is_show,mt.lm_user,mt.lm_time
											 from cst.sys_c_app_mnlt mt
											 left join cst.sys_c_app_menu mn on mt.menu_id=mn.menu_id
											 where {#condition#}  and mn.service_id='060' order by menu_seq,mt.seq  ]]>
							</value>
							<condition name="txt_group_id" hidden="true">
								<value>
								<![CDATA[(mt.group_id = '#data#' )]]>
								</value>
							</condition>
						</select>
						<insert>
							<params>
								<param name="url_group_id" value="url{txt_group_id}"></param>
								<param name="user_id" value="session{user_id}"></param>
								<param name="current_time" value="now{}"
									datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
							</params>
							<value>
								insert into cst.sys_c_app_mnlt
								(id,group_id,menu_id,page_id,page_name,url_param,seq,is_show,lm_user,lm_time)
								values
								(uuid{},#{url_group_id},@{menu_id},@{page_id},@{page_name},@{url_param},
								case when @{seq}='' then null else @{seq} end,@{is_show},#{user_id},#{current_time});
							</value>
						</insert>
						<update>
							<params>
								<param name="user_id" value="session{user_id}"></param>
								<param name="current_time" value="now{}"
									datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
							</params>
							<value>
								update cst.sys_c_app_mnlt
								set menu_id=@{menu_id},
									page_id=@{page_id},
									page_name=@{page_name},
									url_param=@{url_param},
									seq=case when @{seq}='' then null else @{seq} end,
									is_show=@{is_show},
									lm_user=#{user_id},
									lm_time=#{current_time}
								where id=@{id__old};
							</value>
						</update>
						<delete>
							delete from cst.sys_c_app_mnlt where id=@{id};
						</delete>
					</sql>
				</report>
				<report id="report1_4" parenttitle="子组设置" title="url{txt_group_id} 子组设置"
					type="listform" depends="report1" dependsparams="txt_group_id=@{group_id}"
					pagesize="10|20|-1" navigate="${navigatepagesizepage1.report3.navigate}"
					cellresize="0" celldrag="0" width="1000px" scrollheight="270px">
					<display colselect="false" minrownum="1">
						<col column="{sequence:1}" label="序号" width="100px" />
						<col column="group_id" label="组别" displaytype="hidden">
						</col>
						<col column="CHLID_GROUP_ID" label="子组">
							<inputbox styleproperty="style='width:98%'"></inputbox>
						</col>
						<col column="seq" label="次序">
							<inputbox styleproperty="style='width:98%'"></inputbox>
						</col>
						<!-- <col column="lm_user" label="修改人" clickorderby="true" /> <col 
							column="lm_time" label="修改时间" clickorderby="true" datatype="date{yyyy-MM-dd}"/> -->
					</display>
					<sql>
						<select>
							<value>
							<![CDATA[
							select group_id,CHLID_GROUP_ID,seq,lm_user,lm_time 
							from cst.sys_c_sec_gppc
							where {#condition#} order by seq  ]]>
							</value>
							<condition name="txt_group_id" label="组别" hidden="true">
								<value>
								<![CDATA[group_id = '#data#']]>
								</value>
							</condition>
						</select>
						<insert>
							<params>
								<param name="user_id" value="session{user_id}"></param>
								<param name="current_time" value="now{}"
									datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
								<param name="url_group_id" value="url{txt_group_id}"></param>
							</params>
							<value>
								insert into cst.sys_c_sec_gppc
								(group_id,CHLID_GROUP_ID,seq,lm_user,lm_time)
								values
								(#{url_group_id},@{CHLID_GROUP_ID},case when @{seq}='' then null else @{seq} end,#{user_id},#{current_time});
							</value>
						</insert>
						<update>
							<params>
								<param name="user_id" value="session{user_id}"></param>
								<param name="current_time" value="now{}"
									datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
							</params>
							<value>
								update cst.sys_c_sec_gppc
								set CHLID_GROUP_ID=@{CHLID_GROUP_ID},
									seq=case when @{seq}='' then null else @{seq} end,
									lm_user=#{user_id},
									lm_time=#{current_time}
								where group_id=@{group_id__old} 
								and CHLID_GROUP_ID=@{CHLID_GROUP_ID__old} ;
							</value>
						</update>
						<delete>
							delete from cst.sys_c_sec_gppc where
							group_id=@{group_id__old} and
							CHLID_GROUP_ID=@{CHLID_GROUP_ID__old};
						</delete>
					</sql>
				</report>
				<report id="report1_5" parenttitle="权限详细列表" title="url{txt_group_id} 权限详细列表"
					type="list" depends="report1" dependsparams="txt_group_id=@{group_id}"
					pagesize="10|20|-1" navigate="${navigatepagesizepage1.report3.navigate}"
					width="1000px" scrollheight="270px">
					<display colselect="false" minrownum="1">
						<col column="{sequence:1}" label="序号" width="60px" />
						<col column="id" displaytype="hidden" />
						<col column="privilege_id" label="权限" width="100px" filter="true"
							filterwidth="100px" rowgroup="true"></col>
						<col column="page_id" label="页面ID" align="left" clickorderby="true"></col>
						<col column="component_id" label="组件ID" align="left" width="120px"></col>
						<col column="part_type" label="组件部分" width="120px"></col>
						<col column="part_id" label="组件元素" width="100px"></col>
						<col column="permission_type" label="权限类型" width="80px"></col>
						<col column="permission_value" label="权限值" width="80px"></col>
					</display>
					<sql>
						<select>
							<value>
							<![CDATA[select m.id,m.privilege_id,m.page_id,m.component_id,m.part_type,m.part_id,m.permission_type,m.permission_value,m.lm_user,m.lm_time
											from cst.sys_c_sec_pvlt m
											left join cst.sys_c_sec_gppv n on m.privilege_id=n.privilege_id 
											where {#condition#} and n.service_id='060' order by m.privilege_id,m.page_id  ]]>
							</value>
							<condition name="txt_group_id" hidden="true">
								<value>
								<![CDATA[(n.group_id =  '#data#' )]]>
								</value>
							</condition>
						</select>
					</sql>
				</report>
			</tabpanel>
		</vpanel>
	</page>


	<!-- 权限 -->
	<page id="system_privilege" js="/webresources/script/validate.js">
		<header>${top.header}</header>
		<vpanel id="common_vpanel" align="center" width="1000px">
			<report id="report1" title="权限" type="listform" pagesize="7|20|-1"
				navigate="${navigatepagesizepage1.report3.navigate}" cellresize="0"
				celldrag="0" width="1000px" scrollheight="200px">
				<display colselect="false">
					<col column="{sequence:1}" label="序号" width="100px" />
					<col column="privilege_id" label="权限"
						filter="condition{condition_privilege_id}" width="220px">
						<inputbox styleproperty="style='width:99%'"></inputbox>
					</col>
					<col column="priority" label="权限等级" width="120px">
						<inputbox jsvalidate="isNumeric({0}不是合法数字)"
							styleproperty="style='width:99%'"></inputbox>
					</col>
					<col column="privilege_description" label="描述">
						<inputbox styleproperty="style='width:99%'"></inputbox>
					</col>
				</display>
				<sql>
					<select>
						<value>
						<![CDATA[select privilege_id,priority,privilege_description,lm_user,lm_time
										 from cst.sys_c_sec_priv where {#condition#} and service_id='060' order by privilege_id  ]]>
						</value>
						<condition name="condition_privilege_id" hidden="true">
							<value>
							<![CDATA[(privilege_id =  '#data#' )]]>
							</value>
						</condition>
					</select>
					<insert>
						<params>
							<param name="user_id" value="session{user_id}"></param>
							<param name="current_time" value="now{}"
								datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
						</params>
						<value>
							insert into
							cst.sys_c_sec_priv(@{privilege_id},@{priority},@{privilege_description},lm_user=#{user_id},lm_time=#{current_time},service_id='060');
						</value>
					</insert>
					<update>
						<params>
							<param name="user_id" value="session{user_id}"></param>
							<param name="current_time" value="now{}"
								datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
						</params>
						<value>
							update
							cst.sys_c_sec_priv(@{privilege_id},@{priority},@{privilege_description},lm_user=#{user_id},lm_time=#{current_time})
							where privilege_id=@{privilege_id__old} and service_id='060';
							update cst.sys_c_sec_pvlt (@{privilege_id}) where privilege_id=@{privilege_id__old} ;
						</value>
					</update>
					<delete>
						delete from cst.sys_c_sec_priv where
						privilege_id=@{privilege_id} and service_id='060';
						delete from
						cst.sys_c_sec_pvlt where privilege_id=@{privilege_id};
					</delete>
				</sql>
			</report>
			<report id="report1_1" title="url{txt_privilege_id}权限详细列表"
				type="listform" depends="report1" dependsparams="txt_privilege_id=@{privilege_id}"
				pagesize="10|20|-1" navigate="${navigatepagesizepage1.report3.navigate}"
				width="1000px" scrollheight="270px">
				<display colselect="false" minrownum="1">
					<col column="{sequence:1}" label="序号" width="60px" />
					<col column="id" displaytype="hidden" />
					<col column="privilege_id" label="权限" displaytype="hidden"
						clickorderby="true">
						<inputbox type="selectbox" defaultvalue="url{txt_privilege_id}"
							styleproperty="style='width:99%'">
							<option
								source="@{ select privilege_id from cst.sys_c_sec_priv where {#condition#} order by privilege_id } "
								label="privilege_id" value="privilege_id">
								<condition name="txt_privilege_id">
									<value>
										privilege_id = '#data#'
									</value>
								</condition>
							</option>
						</inputbox>
					</col>
					<col column="page_id" label="页面ID" clickorderby="true">
						<inputbox styleproperty="style='width:99%'"></inputbox>
					</col>
					<col column="component_id" label="组件ID" clickorderby="true"
						width="120px">
						<inputbox styleproperty="style='width:99%'"></inputbox>
					</col>
					<col column="part_type" label="组件部分" clickorderby="true" width="220px">
						<inputbox styleproperty="style='width:99%'">
							<typeprompt count="15">
								<promptcol label="const_value" title="参数值"></promptcol>
								<promptcol label="const_name" value="const_value"
									title="名称" matchmode="anywhere"></promptcol>
								<datasource>
									<option
										source="@{select const_name,const_value,seq from cst.sys_c_app_consts where const_type='Consts.KEY' and {#matchcondition#} order by seq}"></option>
								</datasource>
							</typeprompt>
						</inputbox>
					</col>
					<col column="part_id" label="组件元素" clickorderby="true" width="130px">
						<inputbox styleproperty="style='width:99%'">
							<typeprompt count="15">
								<promptcol label="const_value" title="参数值" matchmode="anywhere"></promptcol>
								<datasource>
									<option
										source="@{select const_name,const_value,seq from cst.sys_c_app_consts where const_type in ('Consts.BUTTON_PART','Consts.NAVIGATE_PART') and {#matchcondition#} order by seq}"></option>
								</datasource>
							</typeprompt>
						</inputbox>
					</col>
					<col column="permission_type" label="权限类型" clickorderby="true"
						width="80px">
						<inputbox type="selectbox" styleproperty="style='width:99%'">
							<option label="display" value="display"></option>
							<option label="readonly" value="readonly"></option>
							<option label="disabled" value="disabled"></option>
						</inputbox>
					</col>
					<col column="permission_value" label="权限值" clickorderby="true"
						width="80px">
						<inputbox type="selectbox" styleproperty="style='width:99%'">
							<option label="true" value="true"></option>
							<option label="false" value="false"></option>
						</inputbox>
					</col>
				</display>
				<sql>
					<select>
						<value>
						<![CDATA[select id,privilege_id,page_id,component_id,part_type,part_id,permission_type,permission_value,lm_user,lm_time
										from cst.sys_c_sec_pvlt where {#condition#} order by page_id,component_id,part_type  ]]>
						</value>
						<condition name="txt_privilege_id" label="权限组" hidden="true">
							<value>
							<![CDATA[(privilege_id =  '#data#' )]]>
							</value>
						</condition>
					</select>
					<insert>
						<params>
							<param name="user_id" value="session{user_id}"></param>
							<param name="current_time" value="now{}"
								datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
							<param name="url_privilege_id" value="url{txt_privilege_id}"></param>
						</params>
						<value>
							insert into
							cst.sys_c_sec_pvlt(id=uuid{},privilege_id=#{url_privilege_id},@{page_id},@{component_id},@{part_type},@{part_id},
							@{permission_type},@{permission_value},lm_user=#{user_id},lm_time=#{current_time});
						</value>
					</insert>
					<update>
						<params>
							<param name="user_id" value="session{user_id}"></param>
							<param name="current_time" value="now{}"
								datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
						</params>
						<value>
							update
							cst.sys_c_sec_pvlt(@{page_id},@{component_id},@{part_type},@{part_id},
							@{permission_type},@{permission_value},lm_user=#{user_id},lm_time=#{current_time})
							where id=@{id__old};
						</value>
					</update>
					<delete>
						delete from cst.sys_c_sec_pvlt where id=@{id};
					</delete>
				</sql>
			</report>
		</vpanel>
	</page>
</applications>
