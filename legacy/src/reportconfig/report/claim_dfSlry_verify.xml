<?xml version="1.0" encoding="UTF-8"?>
<applications xmlns="http://www.wabacus.com"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.wabacus.com ../xsd/wabacus.applications.xsd">
	<!--代发工资认领审核 -->
	<page id="claim_dfSlry_verify"
		js="/webresources/script/validate.js,/js/demo.js,/js/common.js">

		<header>${top.header}</header>
		<vpanel id="common_vpanel" width="1300px" align="center" title="">

			<report id="select" type="editablelist" width="1500px" top="10px" scrollwidth="1300px"
				rowselect="multiple-checkbox" pagesize="15|20|-1" personalizeclass="default">

				<display>
					<col column="{col-rowselect}" label="选择" width="50px" />
					<col column="{sequence:1}" label="序号" width="40px"></col>
					
					<col column="AGENT_NO" label="代理号" valuestyleproperty="style='mso-number-format:\@'" displaytype="hidden"></col>
					<col column="ENT_ID" label="企业编号" valuestyleproperty="style='mso-number-format:\@'"></col>
					<col column="ENT_NM" label="企业名称"></col>
					<col column="BIZ_TYPE_NM" label="业务类型" displaytype="hidden"></col>
					<col column="ORG_NM" label="签约机构名"></col>
					<col column="BIZ_STS_NM" label="业务状态"></col>
					<col column="RGST_DT" label="注册日期" ></col>
					<col column="OPEN_DT" label="开通日期" ></col>					
					<col column="CNL_DT" label="取消日期" ></col>
					<col column="EMP_ID" label="认领人工号" ></col>
					<col column="EMP_ID_Hid" label="认领人工号2" displaytype="hidden"></col>
					<col column="EMP_NM" label="认领人姓名"></col>	
					<col column="EMP_ORG_ID" label="认领人机构号" displaytype="hidden"></col>
					<col column="EMP_ORG_NM" label="认领人机构名称"></col>
					<col column="RATIO" label="*认领比例(%)"></col>
					
					<col column="CLAIM_DT" label="认领日期" ></col>
					<col column="REMARK1" label="备注" >
						<inputbox type="textareabox" styleproperty="style='width:99%'" />
					</col>
					<col property="sh_zt_btn" column="{non-fromdb}" label="审核" width="180px"/>

				</display>
				<sql datasource="ds_db2">
					<select>
						<value><![CDATA[
							Select RE.*,S.CLAIM_STATUS_NM,re.EMP_ID as EMP_ID_Hid,ou.BRANCH_ORG_ID,ou.BRANCH_ORG_NM,ou.HEAD_ORG_ID
							from IBS.T1_DF_SLRY_EMP_RELA re
							inner join IBS.T5_ORG ou ON ou.ORG_ID=re.ORG_ID AND ou.ORG_TYPE_ID='AO'
							left join IBS.T9_CLAIM_STATUS_TYPE S ON S.CLAIM_STATUS_ID=RE.CLAIM_STATUS_ID	
							WHERE RE.CLAIM_STATUS_ID = '1' AND {#condition#}
							order by CLAIM_DT DESC,re.EMP_ORG_ID, ENT_ID
						    ]]>
						</value>
						<condition name="ORG_ID" source="session{org_id}" hidden="true">
							<value><![CDATA[(re.ORG_ID='#data#' OR ou.BRANCH_ORG_ID='#data#' OR ou.HEAD_ORG_ID='#data#' )]]></value>
						</condition>

						<condition name="ENT_NM" label="企业名称" labelposition="left">
							<value><![CDATA[re.ENT_NM like '%#data#%']]></value>
						</condition>
						<condition name="EMP_ID" label="认领工号" labelposition="left">
							<value>
							 		<![CDATA[re.EMP_ID='#data#']]>
							</value>
							<inputbox>
								<typeprompt width="200" count="10">
									<promptcol label="EMP_ID" value="EMP_ID" title="认领工号"
										matchmode="anywhere" casesensitive="false" />
									<promptcol label="EMP_NM" value="EMP_NM" title="姓名"
										matchmode="anywhere" casesensitive="false" />
									<datasource>
										<option
											source="@{Select DISTINCT EMP_ID, EMP_NM from IBS.T5_EMP  WHERE   {#matchcondition#}} " />
									</datasource>
								</typeprompt>
							</inputbox>
						</condition>
						<condition name="EMP_NM" label="姓名" labelposition="left">
							<value>
							 		<![CDATA[re.EMP_NM='#data#']]>
							</value>
							<inputbox styleproperty="style='width:150px'">
								<typeprompt width="300" count="10">
									<promptcol label="EMP_ID" value="EMP_ID" title="认领工号"
										matchmode="anywhere" casesensitive="false" />
									<promptcol label="EMP_NM" value="EMP_NM" title="姓名"
										matchmode="anywhere" casesensitive="false" />
									<datasource>
										<option
											source="@{Select DISTINCT EMP_ID, EMP_NM from IBS.T5_EMP  WHERE   {#matchcondition#}} " />
									</datasource>
								</typeprompt>
							</inputbox>
						</condition>
					</select>
				</sql>
				<buttons >
					<button name="button1" position="other" autoreportdata="false"
						positionorder="2" class="com.wabacus.system.buttons.ServerSQLActionButton"
						successprompt="提交成功" failedprompt="提交失败">
						<params>
							<param name="user_id" value="session{user_id}"></param>
							<param name="current_time" value="now{}" datatype="timestamp{yyyy-MM-dd}"></param>
							<param name="current_time1" value="now{}" datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
						</params>

						<value datasource="ds_db2">
							<![CDATA[

								UPDATE IBS.T1_DF_SLRY_EMP_RELA
								SET CLAIM_STATUS_ID='2'
									, VERIFY_DT=#{current_time}
									, VERIFY_EMP_ID=#{user_id}     
									, REMARK1=@{REMARK1}
									, REMARK=CONCAT(COALESCE(REMARK,''),'审批时间',#{current_time1},'审批工号',#{user_id},'审批理由页面批复通过。')                     
								WHERE CLAIM_STATUS_ID='1' 
								AND AGENT_NO=@{p_agent_no} AND EMP_ID=@{p_emp_id} AND CLAIM_DT=@{p_claim_dt}
								;
							]]>
						</value>
					</button>
					<button name="sub" position="title" positionorder="2" label="选中数据批量通过" 
						confirmessage="提交后数据将不能修改，是否确认提交?">
						invokeServerActionForReportData('claim_dfSlry_verify','select','com.customer.interceptor.ClaimVerifyDfSlryServerCallBack',{name:'SELECTEDROW',value:true},null,true,null,null);
					</button>
				</buttons>
				<format>
					<imports>
						<import>com.ljbank.util.*</import>
						<import>java.util.*</import>
						<import>java.text.*</import>
						<import>com.wabacus.system.*</import>
					</imports>
					<value>
						<![CDATA[
							String btnsh_ztCls="cls-button2";
							String btnUnsh_ztCls="cls-button2";
							
							String btnsh_ztEvent="if(confirm('提交后数据将不能修改，是否确认提交?')){invokeComponentSqlActionButton('claim_dfSlry_verify','select','button1',{p_agent_no:'"+AGENT_NO+"', p_emp_id:'"+EMP_ID+"', p_claim_dt:'"+CLAIM_DT+"'},true,refreshPage)}";
							String btnUnsh_ztEvent="wx_winpage('ShowReport.wx?PAGEID=claim_dfSlry_vfy_no&AGENT_NO="+AGENT_NO+"&EMP_ID="+EMP_ID+"&CLAIM_DT="+CLAIM_DT+"',{width:600,height:350});art.dialog.close();";
							
							sh_zt_btn="<input type=\"button\" class=\""+btnsh_ztCls+"\" value=\"通过\" onclick=\""+btnsh_ztEvent+"\">";
							sh_zt_btn=sh_zt_btn+"<input type=\"button\" class=\""+btnUnsh_ztCls+"\" value=\"不通过\"   onclick=\""+btnUnsh_ztEvent+"\">";
							
						]]>
					</value>
				</format>
				<footer><![CDATA[
				<div style='float:left'>
					<font color='red'>*审核不通过需逐条处理，并输入不通过理由。</font>
				</div>]]>
				</footer>
			</report>
		</vpanel>
	</page>

	<!-- 代发工资认领审核不通过弹窗页面 -->
	<page id="claim_dfSlry_vfy_no" js="/webresources/script/validate.js,/js/demo.js,/js/common.js" width="600px">
		<vpanel id="common_vpanel" align="center" >
			<report id="report" title="" type="form" width="500px" align="center"
				interceptor="com.customer.interceptor.InterceptorClaimDfSlryVerifyNo">
				<display 
					labelbgcolor="#f0f0f0" labelalign="left" valuealign="left">
					
					<col column="AGENT_NO" label="代理号" displaytype="hidden"></col>
					<col column="ENT_ID" label="企业编号" ></col>
					<col column="ENT_NM" label="企业名称" valuestyleproperty="colspan='3'" br="true"></col>
					
					<col column="BIZ_TYPE_NM" label="业务类型"></col>
					<col column="ORG_NM" label="签约机构名"></col>
					<col column="BIZ_STS_NM" label="业务状态" br="true"></col>
					
					<col column="EMP_ID" label="认领人工号" displaytype="hidden"></col>
					<col column="EMP_ID_Hid" label="认领人工号2" displaytype="hidden"></col>
					<col column="EMP_NM" label="认领人姓名"></col>	
					<col column="EMP_ORG_ID" label="认领人机构号" displaytype="hidden"></col>
					<col column="EMP_ORG_NM" label="认领人机构名称"></col>
					<col column="RATIO" label="*认领比例(%)" br="true" ></col>
					<col column="CLAIM_DT" label="认领日期"  displaytype="hidden"></col>
					<col column="REMARK1" label="备注(不通过理由)" datatype="varchar" align="left"  valuestyleproperty="colspan='5'" br="true">
						<inputbox type="textareabox" styleproperty="style='width:99%'"></inputbox>
					</col>
				</display>
				<sql aftersave="saveUpdate" datasource="ds_db2">
					<select>
						<value>
						<![CDATA[
							Select RE.*,S.CLAIM_STATUS_NM,re.EMP_ID as EMP_ID_Hid
							from IBS.T1_DF_SLRY_EMP_RELA re
							left join IBS.T9_CLAIM_STATUS_TYPE S ON S.CLAIM_STATUS_ID=RE.CLAIM_STATUS_ID	
							WHERE RE.CLAIM_STATUS_ID = '1' AND {#condition#}
							order by CLAIM_DT DESC,re.ORG_ID, ENT_ID
						    ]]>
						</value>
						
						<condition name="TXN_RUN_NBR" hidden="true">
							<value><![CDATA[re.AGENT_NO='#data#']]></value>
						</condition>
						<condition name="EMP_ID" hidden="true">
							<value><![CDATA[re.EMP_ID='#data#']]></value>
						</condition>
						<condition name="CLAIM_DT" hidden="true">
							<value><![CDATA[re.CLAIM_DT='#data#']]></value>
						</condition>
					</select>
					<update crosspage="true">
						<params>
							<param name="user_id" value="session{user_id}"></param>
							<param name="current_time" value="now{}" datatype="timestamp{yyyy-MM-dd}"></param>
							<param name="current_time1" value="now{}" datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
						</params>
					
							<![CDATA[
							UPDATE IBS.T1_DF_SLRY_EMP_RELA
							SET CLAIM_STATUS_ID='3'
								, VERIFY_DT=#{current_time}
								, VERIFY_EMP_ID=#{user_id}     
								, REMARK1=@{REMARK1}                 
								, REMARK=CONCAT(COALESCE(REMARK,''),'审批时间',#{current_time1},'审批工号',#{user_id},'审批未通过')
							WHERE CLAIM_STATUS_ID='1' 
							AND AGENT_NO=@{AGENT_NO__old} AND EMP_ID=@{EMP_ID__old} AND CLAIM_DT=@{CLAIM_DT__old}
							;
							]]>
					</update>
				</sql>
				<buttons>
					<button name="button2" label="提交" position="title"
						refreshpage="true" aftercallbackmethod="refreshPage"
						confirmessage="提交后数据将不能修改，是否确认提交?" successprompt="提交成功"
						failedprompt="提交失败" positionorder="2" extends="${save.button.default}">

						saveEditableReportData({pageid:'claim_dfSlry_vfy_no',savingReportIds:[{reportid:'report',updatetype:'save'}]});
						
					</button>
				</buttons>
			</report>
		</vpanel>
	</page>

</applications>
