			</imports>
			<preaction>
				<![CDATA[


 				 	  String EMP_ID=rrequest.getStringAttribute("EMP_ID","");
 				 	  if(EMP_ID.equals("")){
 				 	  		EMP_ID=(String)rrequest.getRequest().getSession().getAttribute("EMP_ID");
 				 	        System.out.println("1----获得工号为：EMP_ID="+EMP_ID); 
    		
 				 	   }
 				 	   else{
    				        rrequest.getRequest().getSession().setAttribute("EMP_ID", EMP_ID);
