									,EFF_F
									,CST_NM
									,INSUR_CORP_NM
									,INSUR_PROD_ID
									,ORG_ID
									,ORG_NM
									,BRANCH_ORG_ID
									,BRANCH_ORG_NM
									,INSUR_PREMIUM
									,PRICE
									,RATIO
									,BONUS
							FROM     IBS.T2_INSUR_BONUS_DETAIL
							WHERE {#condition#}
							order by BONUS desc, EFF_DT desc, EMP_ID
						    ]]>
						</value>
							<condition name="INSUR_PRINT_ID" label="保单印刷号"
							labelposition="left">
							<value><![CDATA[INSUR_PRINT_ID='#data#']]></value>
						</condition>
						<condition name="user_id" source="session{user_id}">
							<value><![CDATA[EMP_ID='#data#']]></value>
						</condition>
						<condition name="MEASURE_DT" label="统计日期" labelposition="left">
							<value>
							 	<![CDATA[MEASURE_DT = '#data#']]>
							</value>
							<inputbox type="datepicker" styleproperty="style='width:80px'"
								jsvalidate="isDate(#label#格式为yyyy-MM-dd)">
							</inputbox>
						</condition>
					</select>
				</sql>
			</report>
		</vpanel>
	</page>

</applications>
