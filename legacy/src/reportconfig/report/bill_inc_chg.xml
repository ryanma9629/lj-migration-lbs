						 		<![CDATA[EMP_NM='#data#']]>
						</value>
						<inputbox styleproperty="style='width:100px'">
							<typeprompt width="300" count="10">
								<promptcol label="EMP_ID" value="EMP_ID" title="认领工号"
									matchmode="anywhere" casesensitive="false" />
								<promptcol label="EMP_NM" value="EMP_NM" title="姓名"
									matchmode="anywhere" casesensitive="false" />
								<datasource>
									<option
										source="@{Select DISTINCT EMP_ID, EMP_NM from IBS.T5_EMP  WHERE   {#matchcondition#}} " />
								</datasource>
							</typeprompt>
						</inputbox>
					</condition>
					<condition name="ORG_ID0" source="session{org_id}"
						hidden="true">
						<value> 
 							<![CDATA[(org.BRANCH_ORG_ID = '#data#' or org.HEAD_ORG_ID='#data#' or org.ORG_ID='#data#')]]>
						</value>
					</condition>
					<condition name="ORG_ID1" labelposition="left" label="分行" >
						<value>
							<![CDATA[ org.BRANCH_ORG_ID='#data#' ]]>
						</value>
						<inputbox type="selectbox" styleproperty="style='width:150px'" depends="ORG_ID0">
							<option label="全部" value=""></option>
							<option
								source="@{SELECT DISTINCT BRANCH_ORG_ID,BRANCH_ORG_NM FROM IBS.T5_ORG WHERE ORG_TYPE_ID='EO' AND ORG_LEVEL_ID IN ('1','2','3') and (ORG_ID='#ORG_ID0#' or BRANCH_ORG_ID='#ORG_ID0#' or HEAD_ORG_ID='#ORG_ID0#') ORDER BY BRANCH_ORG_ID}"
								label="BRANCH_ORG_NM" value="BRANCH_ORG_ID" />
						</inputbox>
					</condition>
					<condition name="ORG_ID2" labelposition="left" label="支行">
						<value>
						<![CDATA[(bi.ORG_CD='#data#')]]>
						</value>
						<inputbox type="selectbox" depends="ORG_ID1;ORG_ID0"
							styleproperty="style='width:150px'">
							<option label="全部" value=""></option>
							<option label="无" value="" type="false"></option>
							<option
								source="@{SELECT DISTINCT ORG_ID, ORG_NM FROM IBS.T5_ORG WHERE ORG_TYPE_ID='EO' AND ORG_LEVEL_ID IN ('1','2') and BRANCH_ORG_ID='#ORG_ID1#' and (HEAD_ORG_ID='#ORG_ID0#' or BRANCH_ORG_ID='#ORG_ID0#' or ORG_ID='#ORG_ID0#') ORDER BY ORG_ID}"
								label="ORG_NM" value="ORG_ID" />
						</inputbox>
					</condition>
					<condition name="REMARK" label="调整期" labelposition="left" defaultvalue="session{exam_msr_dt_exam}">
						<value>
					 	<![CDATA[(CHG_DT='#data#')]]>
						</value>
						<inputbox type="selectbox" styleproperty="style='width:100px'" >
							<option
								source="@{Select MEASURE_DT , SWITCH_F , REMARK from IBS.T99_MIDDLE_INCOME_SWITCH ORDER BY MEASURE_DT DESC}"
								label="REMARK" value="MEASURE_DT" />
						</inputbox>
					</condition>
				</select>
			</sql>

			<footer><![CDATA[
			<tr><td height="20px"></td></tr>
			<div style='float:left'>
				<font color='green'>提示：</font>
			</div>
			<tr><td height="20px"></td></tr>
			<div style='float:left'>	
				 <font color='green'>1-分行有权人仅能维护录入本分行员工票据业绩调整，不能跨行录入。</font>
			</div>
			<tr><td height="20px"></td></tr>
			<div style='float:left'>	
