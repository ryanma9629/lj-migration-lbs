				<col column="SUB_PSTN_TYPE" label="子考核类别"  displaytype="hidden"></col>
				<col column="SUB_PSTN_TYPE_NM" label="子考核类别"  displaytype="hidden"></col>
				<col column="ORG_CD" label="机构" ></col>
