<sql aftersave="saveUpdate" datasource="ds_db2">
	<select>
		<value>
		<![CDATA[
			select 
				 xz.MEASURE_DT
				,xz.EXAM_YEAR
				,xz.EXAM_Q
				,xz.EMP_TYPE
				,xz.EMP_ID
				,xz.EMP_NM
				,xz.ORG_ID
				,xz.ORG_NM
