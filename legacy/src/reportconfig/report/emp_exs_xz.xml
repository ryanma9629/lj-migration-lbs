				,xz.HEAD_ORG_NM
				,xz.PSTN_TYPE
				,xz.PSTN_TYPE_NM
				,xz.SUB_PSTN_TYPE
				,xz.SUB_PSTN_TYPE_NM
				,xz.EXS_XZ
				,xz.MODIFY_PEOPLE
				,xz.MODIFY_TIME
				,xz.MODIFY_IP
				,xz.VERIFY_PEOPLE
				,xz.VERIFY_TIME
				,xz.VERIFY_IP
				,xz.VERIFY_REMARK
				,xz.STUS
				,q.QTD_NM
			from IBS.T5_EMP_BZJX xz
			left join ibs.T9_YEAR_Q q on q.QTD=xz.EXAM_Q
			where xz.PSTN_TYPE='04'
			and STUS in ('1','3')
			
			and {#condition#}
		 ]]>
		</value>
		<condition name="EXAM_YEAR" hidden="true" >
			<value><![CDATA[xz.EXAM_YEAR='#data#']]></value>
		</condition>
		<condition name="EXAM_Q" hidden="true">
			<value><![CDATA[xz.EXAM_Q='#data#']]></value>
		</condition>
		<condition name="EMP_ID" hidden="true">
			<value><![CDATA[xz.EMP_ID='#data#']]></value>
		</condition>
	</select>
	<update crosspage="true">
		<params>
			<param name="user_id" value="session{user_id}"></param>
			<param name="current_time" value="now{}" datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
			<param name="ip" value="session{ip}"></param>
		</params>
			<![CDATA[
			UPDATE IBS.T5_EMP_BZJX
			SET STUS='2'
				, VERIFY_TIME=#{current_time}
				, VERIFY_PEOPLE=#{user_id} 
				, VERIFY_IP= #{ip}   
				, VERIFY_REMARK=@{VERIFY_REMARK}                        					
			WHERE EXAM_YEAR=@{EXAM_YEAR__old}
			AND EXAM_Q=@{EXAM_Q__old}
			AND EMP_ID=@{EMP_ID__old}
			AND STUS='1'
			
			and PSTN_TYPE='04'
			]]>
	</update>
</sql>
<buttons>
	<button name="button2" label="提交" position="title"
		refreshpage="true" aftercallbackmethod="refreshPage"
		confirmessage="提交后数据将不能修改，是否确认提交?" successprompt="提交成功"
		failedprompt="提交失败" positionorder="2" extends="${save.button.default}">

		saveEditableReportData({pageid:'emp_exsXz_verNo',savingReportIds:[{reportid:'report',updatetype:'save',}]});

	</button>
</buttons>
</report>
</vpanel>
</page>

