<?xml version="1.0" encoding="UTF-8"?>
<applications xmlns="http://www.wabacus.com"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.wabacus.com ../xsd/wabacus.applications.xsd">
<!-- 分行部门有权人 员工存量维护薪酬 -->
<page id="emp_exsXz_mod" js="/webresources/script/validate.js,/js/demo.js,/js/common.js">
	<interceptor>
		<imports>
			<import>com.ljbank.market.Util</import>
		</imports>
		<preaction>
	<![CDATA[
	]]>
</preaction>
	</interceptor>

	<header>${top.header}</header>

	<vpanel id="common_vpanel" width="1200px" align="center" title="">
		<report id="title" extends="title.report1" width="1200px"></report>
		<report id="select" type="listform" title="员工存量维护薪酬" width="1200px" pagesize="15|20|-1" dataexport="richexcel" 
		servervalidateclass="com.ljbank.market.Util; "
			top="10px" personalizeclass="default" rowselect="single" interceptor="com.customer.interceptor.InterceptorEmpExsXzMod">
			<buttons align="right">
				<button name="subButn" position="title" positionorder="2" label="提交 " 
					confirmessage="提交前请先保存，提交后数据将不能修改，是否确认提交?" extends="${wabacus.button.default}">
					invokeServerActionForReportData('emp_exsXz_mod','select','com.customer.interceptor.EmpExsXzSubmitServerCallBack',null,null,true,null,null);
				</button>
			</buttons>
			
			<display>
				<!--  <col column="{col-rowselect}" label="选择" width="50px" />-->
				<col column="{sequence:1}" label="序号" width="40px"></col>
				<col column="EXAM_YEAR" label="考核年度" width="70px"></col>
				<col column="QTD_NM" label="季度" width="100px"></col>
				<col column="BRANCH_ORG_ID" label="分行机构号"  displaytype="hidden"></col>
				<col column="BRANCH_ORG_NM" label="分行" ></col>
				<col column="ORG_ID" label="机构号" displaytype="hidden"></col>
				<col column="ORG_NM" label="支行" ></col>
				<!-- 
				<col column="PSTN_TYPE" label="主考核类别" displaytype="hidden"></col>
				<col column="PSTN_TYPE_NM" label="主考核类别名称" ></col>
				<col column="SUB_PSTN_TYPE" label="子考核类别" displaytype="hidden"></col>
				<col column="SUB_PSTN_TYPE_NM" label="子考核类别名称"></col>
				 -->
				<col column="EMP_ID" label="工号" width="100px" valuestyleproperty="style='mso-number-format:\@'"></col>
				<col column="EMP_NM" label="姓名" width="90px"></col>
				<col column="EMP_TYPE" label="岗位状态" width="110px"></col>
				<col column="EXS_XZ" label="实发存量维护薪酬" width="120px" clickorderby="true" datatype="double{#,##0.00}">
					<inputbox styleproperty="style='width:90%'" 
							jsvalidate="isNotEmpty(#label# 不允许为空);">
					</inputbox>
				</col>
				
				<col column="STUS" label="状态" clickorderby="true"></col>
				<col column="MEASURE_DT" label="日期" displaytype="hidden"></col>
			</display>
			<subdisplay>
				<statitems>
					<statitem property="item1" value="sum(EXS_XZ)" datatype="float" statiscope="page|report"/>
				</statitems>
				<subrow>
					<subcol property="sprop1" colspan="8"
						valuestyleproperty="bgcolor='#CCFAFF' align='center'" />
					<subcol property="sprop2" colspan="1"
						valuestyleproperty="bgcolor='#CCFAFF' align='left'" />
					<subcol property="sprop3" colspan="1"
						valuestyleproperty="bgcolor='#CCFAFF' align='center'" />
					</subrow>
				<format>
					<value>
					<![CDATA[
						sprop1="合计";
						sprop2=String.valueOf(item1);
						sprop3="";
					]]>
					</value>
				</format>
			</subdisplay>
			<sql>
				<select>
					<value><![CDATA[
							select 
							 xz.MEASURE_DT
							,xz.EXAM_YEAR
							,xz.EXAM_Q
							,xz.EMP_TYPE
							,xz.EMP_ID
							,xz.EMP_NM
							,xz.ORG_ID
							,xz.ORG_NM
							,xz.BRANCH_ORG_ID
							,xz.BRANCH_ORG_NM
							,xz.BZJX
							,xz.HEAD_ORG_ID
							,xz.HEAD_ORG_NM
							,xz.PSTN_TYPE
							,xz.PSTN_TYPE_NM
							,xz.SUB_PSTN_TYPE
							,xz.SUB_PSTN_TYPE_NM
							,xz.EXS_XZ
							,xz.MODIFY_PEOPLE
							,xz.MODIFY_TIME
							,xz.MODIFY_IP
							,xz.VERIFY_PEOPLE
							,xz.VERIFY_TIME
							,xz.VERIFY_IP
							,xz.VERIFY_REMARK
							,xz.STUS
							,q.QTD_NM
						from IBS.T5_EMP_BZJX xz
						left join ibs.T9_YEAR_Q q on q.QTD=xz.EXAM_Q
						where xz.PSTN_TYPE='04'
						and xz.EMP_TYPE<>'过渡期'
						and {#condition#}
						order by xz.MEASURE_DT desc,xz.BRANCH_ORG_ID,xz.ORG_ID,xz.EMP_ID 						       
					]]>
					</value>
					<condition name="ORG_ID0" labelposition="left" label="用户机构" source="session{org_id}" hidden="true">
						<value>
						<![CDATA[(xz.ORG_ID='#data#' or xz.BRANCH_ORG_ID='#data#')]]>
						</value>
					</condition>
					<condition name="EXAM_YEAR" label="考核年度" labelposition="left" defaultvalue="session{exam_year}">
						<value> 
							<![CDATA[xz.EXAM_YEAR = '#data#']]>
						</value>
						   <inputbox type="datepicker" styleproperty="style='width:100px'" dateformat="yyyy" jsvalidate="isNotEmpty(#label# 不允许为空);" ></inputbox>
					</condition>
					<condition name="EXAM_Q" label="考核季度"
						labelposition="left">
						<value> 
 									<![CDATA[xz.EXAM_Q = '#data#']]>
						</value>
						<inputbox type="selectbox" styleproperty="style='width:120px'">
							<option label="全部" value=""></option>
							<option label="一季度" value="01"></option>
							<option label="二季度" value="02"></option>
							<option label="三季度" value="03"></option>
							<option label="四季度" value="04"></option>
						</inputbox>
					</condition>
					<condition name="ORG_ID1" labelposition="left" label="分行">
						<value>
						<![CDATA[xz.BRANCH_ORG_ID='#data#']]>
						</value>
						<inputbox type="selectbox" styleproperty="style='width:150px'" depends="ORG_ID0">
							<option label="全部" value=""></option>
							<option
								source="@{SELECT DISTINCT BRANCH_ORG_ID , CASE WHEN ORG_LEVEL_ID='2' THEN BRANCH_ORG_NM ELSE BRANCH_ORG_NM||'机关' END AS BRANCH_ORG_NM 
								FROM IBS.T5_ORG 
								WHERE ORG_TYPE_ID='EO' AND ORG_LEVEL_ID IN ('2','3') and (ORG_ID='#ORG_ID0#' or HEAD_ORG_ID='#ORG_ID0#')  
								ORDER BY BRANCH_ORG_ID}"
								label="BRANCH_ORG_NM" value="BRANCH_ORG_ID" />
						</inputbox>
					</condition>
					<condition name="ORG_ID2" labelposition="left" label="支行">
					<value>
					<![CDATA[xz.ORG_ID='#data#']]>
					</value>
					<inputbox type="selectbox" depends="ORG_ID1"
						styleproperty="style='width:140px'">
						<option label="全部" value=""></option>
						<option label="无" value="" type="false"></option>
						<option
							source="@{SELECT DISTINCT ORG_ID, ORG_NM FROM IBS.T5_ORG WHERE BRANCH_ORG_ID='#ORG_ID1#' and ORG_TYPE_ID='EO' AND ORG_LEVEL_ID IN ('1','2') ORDER BY ORG_ID}"
							label="ORG_NM" value="ORG_ID" />
					</inputbox>
				</condition>
				</select>
				<update >
					<params>
						<param name="user_id" value="session{user_id}"></param>
						<param name="current_time" value="now{}"
							datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
						<param name="ip" value="session{ip}"></param>

					</params>
					<value>
						<![CDATA[
						
							UPDATE IBS.T5_EMP_BZJX
							SET	
								EXS_XZ=@{EXS_XZ}
						       ,MODIFY_PEOPLE=#{user_id}
						       ,MODIFY_TIME=#{current_time}
						       ,MODIFY_IP=#{ip}
						       ,STUS='0'
							WHERE MEASURE_DT=@{MEASURE_DT__old}
							AND EMP_ID=@{EMP_ID__old}
							and STUS in ('0','2')
							and EMP_TYPE='E'
							and PSTN_TYPE='04'
							;
						]]>
					</value>
				</update>
			</sql>
			<format>
				<value>
				<![CDATA[
					if(STUS.equals("0")) STUS="已保存";
					if(STUS.equals("1")) STUS="已提交分行有权人";
					if(STUS.equals("2")) STUS="分行有权人审核不通过";
					if(STUS.equals("3")) STUS="分行有权人审核审核通过";
				]]>
			</value>
			</format>
		</report>
	</vpanel>
</page>

