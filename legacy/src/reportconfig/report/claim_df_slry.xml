<?xml version="1.0" encoding="UTF-8"?>
<applications xmlns="http://www.wabacus.com"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.wabacus.com ../xsd/wabacus.applications.xsd">
	<!--代发工资认领 -->
<page id="claim_dfSlry"
	js="/webresources/script/validate.js,/js/demo.js,/js/common.js"><!-- /webresources/script/validate.js -->

	<header>${top.header}</header>
	
	<vpanel id="common_vpanel" width="1300px" align="center" title="">
		
		<!-- 按凭证号查询 -->
		<report id="list" title="签约信息" type="listform" personalizeclass="default" width="1300px" scrollwidth="1300px"  pagesize="10|20|-1"
			interceptor="com.customer.interceptor.InterceptorClaimDfSlry" 
			top="10px"
			>
		
			<display>
			    <col column="{sequence:1}" label="序号" width="40px"></col>
				<col column="AGENT_NO" label="代理业务号"></col>
				<col column="ENT_ID" label="企业编号" ></col>
				<col column="ENT_NM" label="企业名称" ></col>
				<col column="ORG_ID" label="签约机构号"  displaytype="hidden"></col>
				<col column="ORG_NM" label="签约机构" ></col>					
				<col column="BIZ_STS_NM" label="业务状态" ></col>
				<col column="RGST_DT" label="注册日期"></col>
				<col column="OPEN_DT" label="开通日期"></col>
				<col column="CNL_DT" label="取消日期"></col>
				<col column="DEP_LINE_NM" label="归属部门"></col>
				<col column="EMP_ID" label="认领人工号" ></col>
				<col column="EMP_NM" label="认领人姓名"></col>	
				<col column="EMP_ORG_ID" label="认领人机构号" displaytype="hidden"></col>
				<col column="EMP_ORG_NM" label="认领人机构名称"></col>
				<col column="RATIO" label="*认领比例(%)"></col>
				<col column="CLAIM_STATUS_ID" label="认领状态ID" displaytype="hidden"></col>
				<col column="CLAIM_STATUS_NM" label="认领状态"></col>
				<col column="CLAIM_DT" label="认领日期" br="true"></col>
				<col column="VERIFY_DT" label="审批日期" displaytype="hidden"></col>
				<col column="VERIFY_EMP_ID" label="审批人" displaytype="hidden"></col>
			</display>

			<sql datasource="ds_db2">
				<select>
					<value><![CDATA[
						Select RE.*,S.CLAIM_STATUS_NM
						from IBS.T1_DF_SLRY_EMP_RELA re
						left join IBS.T9_CLAIM_STATUS_TYPE S ON S.CLAIM_STATUS_ID=RE.CLAIM_STATUS_ID	
						WHERE {#condition#}
						order by ENT_NM ,RE.CLAIM_STATUS_ID, RGST_DT DESC
					    ]]>
					</value>
					<condition name="ENT_NM" label="企业名称" >
						<value><![CDATA[ENT_NM like '%#data#%']]></value>
						<inputbox styleproperty="style='width:300px'"></inputbox>
					</condition>
					<condition name="ENT_ID" label="企业编号" >
						<value><![CDATA[ENT_ID like '%#data#%']]></value>
						<inputbox styleproperty="style='width:150px'"></inputbox>
					</condition>
				</select>
			</sql>

			<format>
				<imports>
					<import>com.ljbank.util.*</import>
					<import>java.util.*</import>
					<import>java.text.*</import>
					<import>com.wabacus.system.*</import>
				</imports>
				<value>
				<![CDATA[
						
				]]>
		  		</value>
			</format>
		</report>
        <!-- 填写认领信息 -->
		<report id="dtl" title="认领信息" type="form" personalizeclass="default"
			servervalidateclass="com.ljbank.market.Servervalidate_ClaimDfSlry;com.ljbank.market.Util"
			depends="list" dependsparams="AGENT_NO=@{AGENT_NO};EMP_ID=@{EMP_ID};ENT_ID=@{ENT_ID}" top="10px"
			>
			<buttons align="right">
				<button name="sub" position="title" positionorder="2"
					extends="${wabacus.button2.default}" label="提交"
					confirmessage="提交前请确认数据已经保存。提交后数据将不能修改，是否确认提交?" >
					<params>
						<param name="user_id" value="session{user_id}"></param>
					</params>
					invokeServerActionForComponent('claim_dfSlry', 'dtl',
					'com.customer.util.SubmitClaimDfSlry',
					{},true,refreshComponentDisplay('claim_dfSlry','dtl',true))
				</button>
			</buttons>
			<display>
				<col column="AGENT_NO" label="代理业务号" ></col>
				<col column="ENT_ID" label="企业编号" valuestyleproperty="style='mso-number-format:\@'"></col>
				<col column="ENT_NM" label="企业名称"></col>
				<col column="ORG_ID" label="签约机构号"  displaytype="hidden"></col>
				<col column="ORG_NM" label="签约机构" ></col>					
				<col column="RGST_DT" label="注册日期" br="true"></col>
				<col column="EMP_ID" label="认领人工号" ></col>
				<col column="EMP_ID_Hid" label="认领人工号2" displaytype="hidden"></col>
				<col column="EMP_NM" label="认领人姓名"></col>	
				<col column="EMP_ORG_ID" label="认领人机构号" displaytype="hidden"></col>
				<col column="EMP_ORG_NM" label="认领人机构名称"></col>
				<col column="RATIO" label="*认领比例(%)" br="true">
					<inputbox styleproperty="style='width:90%'"
						jsvalidate="isNumeric(不是合法数字);isNotEmpty(不可以为空值)"
						servervalidate="isClaimRatio()" 
						/><!--  -->
				</col>
				<!--<col column="CLAIM_DT" label="认领日期" br="true"></col>-->
				<col column="REMARK1" label="备注" datatype="varchar"
						valuestyleproperty="colspan='9';align='left'" br="true">
					<inputbox type="textareabox" styleproperty="style='width:99%',rows='3'"/>		
				</col>
				<col column="VERIFY_DT" label="审批日期" displaytype="hidden"></col>
				<col column="VERIFY_EMP_ID" label="审批人" displaytype="hidden"></col>
			</display>

			<sql datasource="ds_db2" aftersave="doPostSave|true">
				<select>
				
					<value><![CDATA[
						Select RE.*,S.CLAIM_STATUS_NM,re.EMP_ID as EMP_ID_Hid
						from IBS.T1_DF_SLRY_EMP_RELA re
						left join IBS.T9_CLAIM_STATUS_TYPE S ON S.CLAIM_STATUS_ID=RE.CLAIM_STATUS_ID	
						WHERE RE.CLAIM_STATUS_ID in ('0','7','3','31','4') AND {#condition#}
						
						
					    ]]>
					</value>
					<condition name="AGENT_NO" hidden="true">
						<value><![CDATA[AGENT_NO='#data#']]></value>
					</condition>
					<condition name="EMP_ID" hidden="true" >
						<value><![CDATA[EMP_ID = '#data#']]></value>
					</condition>
					<condition name="ENT_ID" hidden="true" >
						<value><![CDATA[ENT_ID = '#data#']]></value>
					</condition>
					 
				</select>

				<update confirmessage="保存" >
					<params>
						<param name="user_id" value="session{user_id}"></param>
						<param name="user_name" value="session{user_name}"></param>
						<param name="usr_org_id" value="session{usr_org_id}"></param>
						<param name="usr_org_nm" value="session{usr_org_nm}"></param>
						<param name="current_time" value="now{}" datatype="timestamp{yyyy-MM-dd}"></param>
						<param name="current_time1" value="now{}"
							datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
					</params>
					<value>
						<![CDATA[
							update IBS.T1_DF_SLRY_EMP_RELA
							set RATIO = @{RATIO}
								,CLAIM_STATUS_ID='0'
								,EMP_ID = #{user_id}
								,EMP_NM = #{user_name}
								,EMP_ORG_ID = #{usr_org_id}
								,EMP_ORG_NM = #{usr_org_nm}
								,CLAIM_DT=#{current_time}
								,REMARK1=@{REMARK1}
							where AGENT_NO=@{AGENT_NO__old}
							and EMP_ID=@{EMP_ID_Hid__old}
							
						]]>
					</value>
				</update>
			</sql>
			
			<format>
				<imports>
					<import>com.ljbank.util.*</import>
					<import>java.util.*</import>
					<import>java.text.*</import>
					<import>com.wabacus.system.*</import>
				</imports>
				<value>
				<![CDATA[
					String user_id = (String) rrequest.getRequest().getSession().getAttribute("user_id");
					String user_name = (String) rrequest.getRequest().getSession().getAttribute("user_name");
					String usr_org_nm = (String) rrequest.getRequest().getSession().getAttribute("usr_org_nm");
		        	EMP_ID=user_id;
		        	EMP_NM=user_name;
		        	EMP_ORG_NM=usr_org_nm;
				    rrequest.getRequest().getSession().setAttribute("AGENT_NO", AGENT_NO);
				    rrequest.getRequest().getSession().setAttribute("EMP_ID", EMP_ID);
				    rrequest.getRequest().getSession().setAttribute("RATIO", RATIO);
				]]>
		  		</value>
			</format>
			<!-- 
				    rrequest.getRequest().getSession().setAttribute("TXN_DT", TXN_DT);
				    rrequest.getRequest().getSession().setAttribute("VUCH_NBR", VUCH_NBR);
			
			 -->
		</report>
		<footer><![CDATA[
			<tr><td height="20px"></td></tr>
			<div style='float:left'>
				<font color='green'>提示：1-只能够填写本人认领信息，不可以代人认领。</font>
			</div>
			<tr><td height="20px"></td></tr>
			]]>
			</footer>
		</vpanel>
	</page>


</applications>
