				<import>java.util.Date</import>
				<import>java.text.SimpleDateFormat</import>
				<import>com.ljbank.market.Util</import>
			</imports>
			<preaction>
				<![CDATA[
						String beginTime = rrequest.getStringAttribute("MEASURE_DT", "");// 取出输入的查询时间
						System.out.println("beginTime:" + beginTime);
						if (beginTime.equals("")) 
						{
							Util u = new Util();
							String date=u.getDate();
							rrequest.setAttribute("MEASURE_DT", date);
							System.out.println("beginTime处理后时间为:" + beginTime);
                        }
                    
				]]>
			</preaction>
		</interceptor>
		<vpanel id="common_vpanel" width="1350px" align="center" title="">

			<report id="title" extends="title.report1" width="1350px"></report>
			<report id="select" title="员工销售保险汇总表" type="editablelist"
				scrollwidth="1350px"  top="10px" align="center"
				pagesize="15|20|-1" dataexport="richexcel" personalizeclass="default">

				<display>
					<col column="MEASURE_DT" label="统计日期" width="80px" displaytype="hidden"></col>
					<col column="EMP_ID" label="员工号" width="60px"
						valuestyleproperty="style='mso-number-format:\@'"></col>
					<col column="EMP_NM" label="员工姓名" width="60px"></col>
					<col column="ORG_ID" label="机构号" width="60px" clickorderby="false"
						valuestyleproperty="style='mso-number-format:\@'"></col>
					<col column="ORG_NM" label="机构名" width="100px"></col>
					<col column="BRANCH_ORG_ID" label="分行机构号" width="60px"
						displaytype="hidden"></col>
					<col column="BRANCH_ORG_NM" label="分行机构名" width="100px"></col>
					<col column="PSTN_TYPE" label="主考核类别" width="80px" displaytype="hidden"></col>
					<col column="PSTN_TYPE_NM" label="主考核类别" width="100px"></col>
					<col column="SUB_PSTN_TYPE" label="子考核类别" width="40px"
						displaytype="hidden"></col>
					<col column="SUB_PSTN_TYPE_NM" label="子考核类别" width="120px"></col>
					<col column="HR_ORG_NAME" label="员工归属部门" width="120px"></col>
					<col column="INSUR_PREMIUM_M" label="月保费" width="120px"></col>
					<col column="INSUR_PREMIUM_Q" label="季保费" width="120px"></col>
					<col column="INSUR_PREMIUM_Y" label="年保费" width="120px"></col>
					<col column="INSUR_BONUS_M" label="月保险奖金" width="120px"></col>
					

				</display>
				<sql>
					<select>
						<value><![CDATA[
							SELECT
							      MEASURE_DT
							      ,EMP_ID
							      ,EMP_NM
							      ,ORG_ID
							      ,ORG_NM
							      ,BRANCH_ORG_ID
							      ,BRANCH_ORG_NM
							      ,PSTN_TYPE
							      ,PSTN_TYPE_NM
							      ,SUB_PSTN_TYPE
							      ,SUB_PSTN_TYPE_NM
							      ,HR_ORG_NAME
							      ,INSUR_PREMIUM_M
							      ,INSUR_PREMIUM_Q
							      ,INSUR_PREMIUM_Y
							      ,INSUR_BONUS_M
							FROM IBS.T2_EMP_INSUR_BONUS_SMY
							WHERE   {#condition#}
							ORDER BY INSUR_PREMIUM_Q desc
						    ]]>
						</value>
						<condition name="EMP_ID" label="认领工号" labelposition="left">
							<value>
							 		<![CDATA[EMP_ID='#data#']]>
							</value>
							<inputbox styleproperty="style='width:100px'">
								<typeprompt width="300" count="10">
									<promptcol label="EMP_ID" value="EMP_ID" title="认领工号"
										matchmode="anywhere" casesensitive="false" />
									<promptcol label="EMP_NM" value="EMP_NM" title="姓名"
										matchmode="anywhere" casesensitive="false" />
									<datasource>
										<option
											source="@{Select DISTINCT EMP_ID, EMP_NM from IBS.T5_EMP  WHERE   {#matchcondition#}} " />
									</datasource>
								</typeprompt>
							</inputbox>
						</condition>
						<condition name="EMP_NM" label="姓名" labelposition="left">
							<value>
							 		<![CDATA[EMP_NM='#data#']]>
							</value>
							<inputbox styleproperty="style='width:100px'">
								<typeprompt width="300" count="10">
									<promptcol label="EMP_ID" value="EMP_ID" title="认领工号"
										matchmode="anywhere" casesensitive="false" />
									<promptcol label="EMP_NM" value="EMP_NM" title="姓名"
										matchmode="anywhere" casesensitive="false" />
									<datasource>
										<option
											source="@{Select DISTINCT EMP_ID, EMP_NM from IBS.T5_EMP  WHERE   {#matchcondition#}} " />
									</datasource>
								</typeprompt>
							</inputbox>
						</condition>
						<condition name="PSTN_TYPE" labelposition="left" label="主考核类别">
							<value>
								<![CDATA[(PSTN_TYPE='#data#')]]>
							</value>
							<inputbox type="selectbox" styleproperty="style='width:100px'">
								<option label="全部" value=""></option>
								<option
									source="@{Select distinct PSTN_TYPE , PSTN_TYPE_NM from PUB.PERSONNEL group by PSTN_TYPE, PSTN_TYPE_NM , SUB_PSTN_TYPE , SUB_PSTN_TYPE_NM order by PSTN_TYPE }"
									label="PSTN_TYPE_NM" value="PSTN_TYPE" />
							</inputbox>
						</condition>
						<condition name="SUB_PSTN_TYPE" labelposition="left"
							label="子考核类别">
							<value>
							<![CDATA[(SUB_PSTN_TYPE='#data#')]]>
							</value>
							<inputbox type="selectbox" depends="PSTN_TYPE"
								styleproperty="style='width:150px'">
								<option label="全部" value=""></option>
								<option label="无" value="" type="false"></option>
								<option
									source="@{Select distinct SUB_PSTN_TYPE , SUB_PSTN_TYPE_NM from PUB.PERSONNEL where PSTN_TYPE='#PSTN_TYPE#' group by PSTN_TYPE, PSTN_TYPE_NM , SUB_PSTN_TYPE , SUB_PSTN_TYPE_NM order by SUB_PSTN_TYPE }"
									label="SUB_PSTN_TYPE_NM" value="SUB_PSTN_TYPE" />
							</inputbox>
						</condition>

						<condition name="ORG_ID1" labelposition="left" label="分行">
							<value>
							<![CDATA[(BRANCH_ORG_ID='#data#')]]>
							</value>
							<inputbox type="selectbox" styleproperty="style='width:150px'">
								<option label="全部" value=""></option>
								<option
									source="@{SELECT DISTINCT BRANCH_ORG_ID , CASE WHEN ORG_LEVEL_ID='2' THEN BRANCH_ORG_NM ELSE BRANCH_ORG_NM||'机关' END AS BRANCH_ORG_NM FROM IBS.T5_ORG WHERE ORG_TYPE_ID='EO' AND ORG_LEVEL_ID IN ('2','3') ORDER BY BRANCH_ORG_ID}"
									label="BRANCH_ORG_NM" value="BRANCH_ORG_ID" />
							</inputbox>
						</condition>
						<condition name="ORG_ID2" labelposition="left" label="支行">
							<value>
							<![CDATA[(ORG_ID='#data#')]]>
							</value>
							<inputbox type="selectbox" depends="ORG_ID1"
								styleproperty="style='width:150px'">
								<option label="全部" value=""></option>
								<option label="无" value="" type="false"></option>
								<option
									source="@{SELECT DISTINCT ORG_ID, ORG_NM FROM IBS.T5_ORG WHERE BRANCH_ORG_ID='#ORG_ID1#' and ORG_TYPE_ID='EO' AND ORG_LEVEL_ID IN ('1','2') ORDER BY ORG_ID}"
									label="ORG_NM" value="ORG_ID" />
							</inputbox>
						</condition>

						<condition name="MEASURE_DT" label="日期" labelposition="left">
							<value>
						 	<![CDATA[(MEASURE_DT='#data#')]]>
							</value>
							<inputbox type="datepicker" styleproperty="style='width:120px'"
								jsvalidate="isDate(#label#格式为yyyy-MM-dd)">
							</inputbox>
						</condition>

					</select>
				</sql>
				<format>
					<imports>
						<import>com.ljbank.util.*</import>
						<import>com.wabacus.util.*</import>
						<import>java.util.*</import>
						<import>java.text.*</import>
						<import>com.wabacus.system.*</import>
					</imports>
					<value>
					<![CDATA[
						
						BRANCH_ORG_NM=BRANCH_ORG_NM==null?"":BRANCH_ORG_NM.trim();
						String branch_org_nm=BRANCH_ORG_NM;
		        		branch_org_nm=branch_org_nm.replaceAll("XX银行","");
		        		if(!branch_org_nm.equals("")) BRANCH_ORG_NM=branch_org_nm;
				
				
						ORG_NM=ORG_NM==null?"":ORG_NM.trim();
						String org_nm=ORG_NM;
						org_nm=org_nm.replaceAll(branch_org_nm,"");
						org_nm=org_nm.replaceAll("XX银行","");
						if(!org_nm.equals("")) ORG_NM=org_nm;
				
				
						SUB_PSTN_TYPE_NM=SUB_PSTN_TYPE_NM==null?"":SUB_PSTN_TYPE_NM.trim();
						String sub_pstn_type_nm=SUB_PSTN_TYPE_NM;
						sub_pstn_type_nm=sub_pstn_type_nm.replaceAll(PSTN_TYPE_NM+"-","");
						if(!sub_pstn_type_nm.equals("")) SUB_PSTN_TYPE_NM=sub_pstn_type_nm;
											
					    EMP_NM="<a style='TEXT-DECORATION:underline' href='ShowReport.wx?PAGEID=insur_bonus_detail&EMP_ID="+EMP_ID +"&MEASURE_DT="+MEASURE_DT+"'>"+EMP_NM+"</a>"; 
	
						
					]]>
					</value>
				</format>
				<footer><![CDATA[<div style='float:left'><font color='blue'>提示:点击员工姓名,可以查询其“保险产品奖励明细”功能页面</font></div>]]></footer>
			</report>
		</vpanel>
	</page>

