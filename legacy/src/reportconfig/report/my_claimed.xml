			 <!-- 
			<vpanel id="vp4" width="1300px" align="center" parenttitle="我的第三方存管认领" margin_top="10px">
				<report id="select4" title="" type="editablelist" width="1300px" scrollwidth="1300px"
					align="center" pagesize="15|20|-1" personalizeclass="default" rowselect="multiple">

					<display>
						<col column="{sequence:1}" label="序号" width="40px"></col>
						
						<col column="SCURT_AC" label="证券资金账号"></col>
						<col column="VUCH_NBR" label="凭证号" ></col>
						<col column="BIZ_TYPE_NM" label="业务类型"></col>
						<col column="CST_NM" label="客户名"></col>
						<col column="ORG_NM" label="签约机构"></col>
						<col column="OPEN_DT" label="签约日期"></col>
						<col column="CLAIM_STATUS_NM" label="认领状态"></col>
						<col column="CLAIM_DT" label="认领日期" ></col>
						<col column="VERIFY_DT" label="审批日期" ></col>
						<col column="VERIFY_EMP_ID" label="审批人" ></col>
