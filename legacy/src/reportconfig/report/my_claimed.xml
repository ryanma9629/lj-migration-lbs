				<sql datasource="ds_db2">
					<select>
						<value><![CDATA[
							SELECT 
								A.VUCH_NBR                      
								,B.BIZ_TYPE_ID     	            
								     	            
								,B.CST_NM             
								,B.ORG_ID AS ACC_ORG_ID         
								,B.ORG_NM AS ACC_ORG_NM         
								,B.OPEN_DT                      
								,B.CLOSE_DT                     
								,A.OLD_EMP_ID                   
								,A.OLD_RATIO                    
								,A.OLD_CLAIM_DT                 
								,A.OLD_VERIFY_DT             
								,A.OLD_VERIFY_EMP_ID            
								,A.OLD_REMARK                   
								,A.NEW_EMP_ID                   
								,C.EMP_NM	AS NEW_EMP_NM         
								,C.ORG_ID AS NEW_EMP_ORG_ID     
								,C.ORG_NM AS NEW_EMP_ORG_NM     
								,A.NEW_RATIO  
								,A.NEW_CLAIM_DT  
								,A.NEW_VERIFY_DT 
								,A.NEW_FIN_VERIFY_DT      
								,A.NEW_VERIFY_EMP_ID   
								,A.NEW_FIN_VERIFY_EMP_ID      
								,A.NEW_CLAIM_STATUS_ID 
								,(A.OLD_REMARK ||A.NEW_REMARK) as REMARK 
						FROM	IBS.T6_VUCH_EMP_RELA_CHANGE_LOG		A 
						inner JOIN	IBS.T1_VUCH_DETAIL					B
						ON		A.VUCH_NBR=B.VUCH_NBR
						inner JOIN	IBS.T5_EMP							C
						ON		A.NEW_EMP_ID=C.EMP_ID
						
						WHERE {#condition#}
						    ]]>
						</value>
						<condition name="VUCH_NBR" hidden="true">
							<value><![CDATA[A.VUCH_NBR='#data#']]></value>
						</condition>
						<condition name="OLD_EMP_ID" hidden="true">
							<value><![CDATA[A.OLD_EMP_ID='#data#']]></value>
						</condition>
						<condition name="NEW_EMP_ID" hidden="true">
							<value><![CDATA[A.NEW_EMP_ID='#data#']]></value>
						</condition>
						<condition name="OLD_RATIO" hidden="true">
							<value><![CDATA[A.OLD_RATIO='#data#']]></value>
						</condition>
						<condition name="NEW_RATIO" hidden="true">
							<value><![CDATA[A.NEW_RATIO='#data#']]></value>
						</condition>
