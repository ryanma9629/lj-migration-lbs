	<!--认领查询（有权人） -->
		<page id="claimed_info"
			js="/webresources/script/validate.js,/js/demo.js,/js/common.js"><!-- /webresources/script/validate.js -->

			<header>${top.header}</header>
			<vpanel id="common_vpanel" width="1300px" align="center" title="">
				<html id="claimed_info_title"><![CDATA[
					<div style="width:1300px;margin:0 auto;padding:8px 0 4px 0;color:#154BA0;font-weight:bold;">认领查询</div>
				]]></html>

				<report id="select" type="listform" personalizeclass="default" rowselect="multiple"
				pagesize="15|20|-1" top="10px"  dataexport="plainexcel" title="认领信息" interceptor="com.customer.interceptor.InterceptorClaimedInfo"> <!--  -->
				<display>
					<col column="{sequence:1}" label="序号" width="40px"></col>
					<col column="BIZ_TYPE_NM" label="业务类型名称" width="90px"></col>
					
					<col column="VUCH_NBR" label="凭证号" width="150px"
						valuestyleproperty="style='mso-nubmer-format:\@'"></col>
					<col column="CST_NM" label="客户名" width="250px"></col>
					
					<col column="EMP_ID" label="认领工号" width="80px"
						valuestyleproperty="style='mso-nubmer-format:\@'"></col>
					<col column="EMP_NM" label="姓名" width="80px"></col>

					<col column="RATIO" label="认领比例（%）" width="80px"></col>
					<col column="CLAIM_DT" label="认领日期" width="80px"></col>
					<col column="CLAIM_STATUS_NM" label="审核方式" width="80px"></col>
					<col column="VERIFY_DT" label="审批日期" width="80px"></col>
					<col column="VERIFY_EMP_ID" width="80px" label="审批工号"></col>
					<col column="VERIFY_EMP_NM" width="80px" label="审批人"></col>
				</display>

				<sql datasource="ds_db2">
					<select>
						<value><![CDATA[
							SELECT   
									 re.BIZ_TYPE_NM     	
									,re.VUCH_NBR     		
									,re.CST_NM     			
									,re.EMP_ID
									,re.EMP_NM    	
									,re.CLAIM_DT
									,(case when coalesce(re.RVS_STATUS_ID,'') in ('2','21') then RVS_RATIO else re.RATIO end) as RATIO
									,(case when coalesce(re.RVS_STATUS_ID,'') in ('2','21') then rs.EMP_NM else B.EMP_NM end) as VERIFY_EMP_NM
									,(case when coalesce(re.RVS_STATUS_ID,'') in ('2','21') then rs.EMP_ID else B.EMP_ID end) as VERIFY_EMP_ID 
									,(case when coalesce(re.RVS_STATUS_ID,'') in ('2','21') then RVS_CLAIM_DT else re.VERIFY_DT end) as VERIFY_DT 
									,(case when coalesce(re.RVS_STATUS_ID,'') in ('2','21') then rstp.RVS_STATUS_NM else ctp.CLAIM_STATUS_NM end) as CLAIM_STATUS_NM
							FROM    IBS.T1_VUCH_EMP_RELA re
							
							inner join ibs.T5_EMP emp on emp.EMP_ID=re.EMP_ID
					        inner join IBS.T5_ORG pog on pog.ORG_ID=emp.ORG_ID and pog.ORG_TYPE_ID='EO'
							inner join IBS.T5_ORG cog on cog.ORG_ID=re.ORG_ID and cog.ORG_TYPE_ID='AO'
							%sqlinner%
							LEFT JOIN IBS.T5_EMP B ON re.VERIFY_EMP_ID=B.EMP_ID
							LEFT JOIN IBS.T5_EMP rs ON re.RVS_CLAIM_EMP_ID=rs.EMP_ID
							left join ibs.T9_RVS_STATUS_TYPE rstp on rstp.RVS_STATUS_ID=re.RVS_STATUS_ID
							left join ibs.T9_CLAIM_STATUS_TYPE ctp on ctp.CLAIM_STATUS_ID=re.CLAIM_STATUS_ID
							WHERE 	re.CLAIM_STATUS_ID IN ('2','5','6') 
							AND 	COALESCE(re.MARKETING_NO,'') not in ('2016qq') 
							and {#condition#} %sqlcon%
							ORDER BY re.CLAIM_DT desc, re.BIZ_TYPE_NM, re.VUCH_NBR
							
						    ]]>
						</value>
						<!-- 
						<condition name="ORG_ID" source="session{org_id}"
							hidden="true">
							<value><![CDATA[(A.ORG_ID='#data#' or org.BRANCH_ORG_ID='#data#' or org.HEAD_ORG_ID='#data#') ]]></value>
						</condition>
						 -->
						<condition name="VUCH_NBR" label="凭证号" labelposition="left">
							<value><![CDATA[re.VUCH_NBR='#data#']]></value>
						</condition>
						<condition name="EMP_ID" label="认领工号" labelposition="left">
							<value>
							 		<![CDATA[re.EMP_ID='#data#']]>
							</value>
							<inputbox styleproperty="style='width:100px'">
								<typeprompt width="300" count="10">
									<promptcol label="EMP_ID" value="EMP_ID" title="认领工号"
										matchmode="anywhere" casesensitive="false" />
									<promptcol label="EMP_NM" value="EMP_NM" title="姓名"
										matchmode="anywhere" casesensitive="false" />
									<datasource>
										<option
											source="@{Select DISTINCT EMP_ID, EMP_NM from IBS.T5_EMP  WHERE   {#matchcondition#}} " />
									</datasource>
								</typeprompt>
							</inputbox>
						</condition>
						<condition name="EMP_NM" label="姓名" labelposition="left">
							<value>
							 		<![CDATA[re.EMP_NM='#data#']]>
							</value>
							<inputbox styleproperty="style='width:100px'">
								<typeprompt width="300" count="10">
									<promptcol label="EMP_ID" value="EMP_ID" title="认领工号"
										matchmode="anywhere" casesensitive="false" />
									<promptcol label="EMP_NM" value="EMP_NM" title="姓名"
										matchmode="anywhere" casesensitive="false" />
									<datasource>
										<option
											source="@{Select DISTINCT EMP_ID, EMP_NM from IBS.T5_EMP  WHERE   {#matchcondition#}} " />
									</datasource>
								</typeprompt>
							</inputbox>
						</condition>
						<condition name="BIZ_TYPE_NM" labelposition="left"
							label="业务类型">
							<value>
							<![CDATA[re.BIZ_TYPE_NM='#data#']]>
							</value>
							<inputbox type="selectbox" styleproperty="style='width:100px'">
								<option label="全部" value=""></option>
								<option
									source="@{Select distinct BIZ_TYPE_NM from IBS.T9_BIZ_TYPE order by BIZ_TYPE_NM}"
									label="BIZ_TYPE_NM" value="BIZ_TYPE_NM" />

