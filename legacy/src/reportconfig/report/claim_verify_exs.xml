<?xml version="1.0" encoding="UTF-8"?>
<applications xmlns="http://www.wabacus.com"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.wabacus.com ../xsd/wabacus.applications.xsd">
	<!--存量客户支行认领审核 -->
	<page id="claim_verify_exs"
		js="/webresources/script/validate.js,/js/demo.js,/js/common.js"><!-- /webresources/script/validate.js -->

		<header>${top.header}</header>
		<vpanel id="common_vpanel" width="1300px" align="center" title="">
			<html id="claim_verify_exs_title"><![CDATA[
				<div style="width:1300px;margin:0 auto;padding:8px 0 4px 0;color:#154BA0;font-weight:bold;">存量客户支行认领审核</div>
			]]></html>
			<report id="select" type="editablelist" width="1300px" top="10px"
				rowselect="multiple-checkbox" pagesize="15|20|-1" personalizeclass="default">

				<display>
					<col column="{col-rowselect}" label="选择" width="50px" />
					<col column="{sequence:1}" label="序号" width="40px"></col>
					<col column="BIZ_TYPE_NM" label="业务类型名称" width="90px"></col>
					<col column="VUCH_NBR" label="凭证号" width="150px"
						valuestyleproperty="style='mso-nubmer-format:\@'" rowselectvalue="true"></col>
					<col column="CST_NM" label="客户名" width="250px"></col>
					<col column="OPEN_DT" label="开户日期" width="80px"></col>
					<col column="CLAIM_DT" label="认领时间" width="80px" displaytype="hidden"></col>
					<col column="EMP_ID" label="认领工号" width="80px"
						valuestyleproperty="style='mso-nubmer-format:\@'" rowselectvalue="true"></col>
					<col column="EMP_NM" label="姓名" width="80px"></col>
					<col property="CLAIM_INFO" column="{non-fromdb}" label="认领信息查询" />
					<col property="sh_zt_btn" column="{non-fromdb}" label="审核" />



				</display>
				<sql datasource="ds_db2">
					<select>
						<value><![CDATA[
							SELECT   BIZ_TYPE_NM     	
									,VUCH_NBR  
									,CST_NM   		
									,OPEN_DT     
								    ,CLAIM_DT			
									,RATIO AS CLAIM_INFO     	
									,EMP_ID
									,EMP_NM 
							FROM  	IBS.T1_VUCH_EMP_RELA	
							
							WHERE 	CLAIM_STATUS_ID = '1' 
							AND coalesce(CST_OPEN_DT,'2018-01-01')<'2018-01-01'
							AND BIZ_TYPE_NM = '储蓄存款'
							AND {#condition#}
							ORDER BY CLAIM_DT, BIZ_TYPE_NM, VUCH_NBR
						
						    ]]>
						</value>
						<!-- 测试 关闭org_id 暂时将org_id='2703' A.CLAIM_STATUS_ID = '2' (原值为1) -->
						<condition name="ORG_ID" source="session{org_id}" hidden="true">
							<value><![CDATA[ORG_ID='#data#']]></value>
						</condition>

						<condition name="VUCH_NBR" label="凭证号" labelposition="left">
							<value><![CDATA[VUCH_NBR='#data#']]></value>
						</condition>
						<condition name="EMP_ID" label="认领工号" labelposition="left">
							<value>
							 		<![CDATA[EMP_ID='#data#']]>
							</value>
							<inputbox>
								<typeprompt width="300" count="10">
									<promptcol label="EMP_ID" value="EMP_ID" title="认领工号"
										matchmode="anywhere" casesensitive="false" />
									<promptcol label="EMP_NM" value="EMP_NM" title="姓名"
										matchmode="anywhere" casesensitive="false" />
									<datasource>
										<option
											source="@{Select DISTINCT EMP_ID, EMP_NM from IBS.T5_EMP  WHERE   {#matchcondition#}} " />
									</datasource>
								</typeprompt>
							</inputbox>
						</condition>
						<condition name="EMP_NM" label="姓名" labelposition="left">
							<value>
							 		<![CDATA[EMP_NM='#data#']]>
							</value>
							<inputbox styleproperty="style='width:100px'">
								<typeprompt width="300" count="10">
									<promptcol label="EMP_ID" value="EMP_ID" title="认领工号"
										matchmode="anywhere" casesensitive="false" />
									<promptcol label="EMP_NM" value="EMP_NM" title="姓名"
										matchmode="anywhere" casesensitive="false" />
									<datasource>
										<option
											source="@{Select DISTINCT EMP_ID, EMP_NM from IBS.T5_EMP  WHERE   {#matchcondition#}} " />
									</datasource>
								</typeprompt>
							</inputbox>
						</condition>
						<condition name="BIZ_TYPE_NM" labelposition="left"
							label="业务类型">
							<value>
							<![CDATA[(BIZ_TYPE_NM='#data#')]]>
							</value>
							<inputbox type="selectbox">
								<option label="全部" value=""></option>
								<option
									source="@{Select distinct BIZ_TYPE_NM from IBS.T9_BIZ_TYPE order by BIZ_TYPE_NM}"
									label="BIZ_TYPE_NM" value="BIZ_TYPE_NM" />

							</inputbox>
						</condition>
					</select>
				</sql>
				<buttons >
					<button name="button1" position="other" autoreportdata="false"
						positionorder="2" class="com.wabacus.system.buttons.ServerSQLActionButton"
						successprompt="提交成功" failedprompt="提交失败">
						<params>
							<param name="user_id" value="session{user_id}"></param>
							<param name="current_time" value="now{}" datatype="timestamp{yyyy-MM-dd}"></param>
							<param name="current_time1" value="now{}"
								datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>

						</params>

						<value datasource="ds_db2">
							<![CDATA[

								UPDATE IBS.T1_VUCH_EMP_RELA
								SET CLAIM_STATUS_ID='21'
									, VERIFY_DT=#{current_time}
									, VERIFY_EMP_ID=#{user_id}     
									, REMARK=CONCAT(COALESCE(REMARK,''),'审批时间',#{current_time1},'审批工号',#{user_id},'审批理由页面批复存量客户支行审核通过。')                        
								WHERE CLAIM_STATUS_ID='1' 
								AND coalesce(CST_OPEN_DT,'2018-01-01')<'2018-01-01'
								AND BIZ_TYPE_NM = '储蓄存款'
								AND VUCH_NBR=@{param_vuch} AND EMP_ID=@{param_emp}
								;
								
							]]>
						</value>
					</button>




					<button name="sub" position="title" positionorder="2" label="选中数据批量通过"
						confirmessage="提交后数据将不能修改，是否确认提交?">
						invokeServerActionForReportData('claim_verify_exs','select','com.customer.interceptor.ClaimVerifyExsServerCallBack',{name:'SELECTEDROW',value:true},null,true,null,null);


					</button><!-- extends="${wabacus.button2.default}" confirmessage="提交后数据将不能修改，是否确认提交?" -->





				</buttons>


				<format>
					<imports>
						<import>com.ljbank.util.*</import>
						<import>java.util.*</import>
						<import>java.text.*</import>
						<import>com.wabacus.system.*</import>
					</imports>
					<value>
						<![CDATA[
							String btnsh_ztCls="cls-button2";
							String btnUnsh_ztCls="cls-button2";
							
							//String btnsh_ztEvent="invokeComponentSqlActionButton('claim_verify_acc','select','button1',{param_vuch:'"+VUCH_NBR+"', param_emp:'"+EMP_ID+"'},true,refreshPage)";
					
							
							String btnsh_ztEvent="if(confirm('提交后数据将不能修改，是否确认提交?')){invokeComponentSqlActionButton('claim_verify_exs','select','button1',{param_vuch:'"+VUCH_NBR+"', param_emp:'"+EMP_ID+"'},true,refreshPage)}";
							String btnUnsh_ztEvent="wx_winpage('ShowReport.wx?PAGEID=verify_no_exs&VUCH_NBR="+VUCH_NBR+"&EMP_ID="+EMP_ID+"',{width:550,height:350});art.dialog.close();";
						
							
							sh_zt_btn="<input type=\"button\" class=\""+btnsh_ztCls+"\" value=\"通过\" onclick=\""+btnsh_ztEvent+"\">";
							sh_zt_btn=sh_zt_btn+"<input type=\"button\" class=\""+btnUnsh_ztCls+"\" value=\"不通过\"   onclick=\""+btnUnsh_ztEvent+"\">";
							
							
							CLAIM_INFO="<a style='TEXT-DECORATION:underline' href='ShowReport.wx?PAGEID=claim_info&VUCH_NBR="+VUCH_NBR+"&EMP_ID="+EMP_ID+"'>点击进入查询详细</a>";
						]]>
					</value>
				</format>
				<footer><![CDATA[
				<div style='float:left'>
					<font color='red'>*审核不通过需逐条处理，并输入不通过理由。</font>
				</div>]]>
				</footer>


			</report>



		</vpanel>
	</page>

	<!-- 认领审核不通过弹窗页面 -->
	<page id="verify_no_exs"
		js="/webresources/script/validate.js,/js/demo.js,/js/common.js">
		<vpanel id="common_vpanel" align="center" width="300px">
			<report id="report" title="" type="form"
				interceptor="com.customer.interceptor.InterceptorClaimVerifyNo"><!-- form editabledetail -->
				<display valuetdwidth="300px" labeltdwidth="200px"
					labelbgcolor="#f0f0f0" labelalign="right" valuealign="left">

					<col column="VUCH_NBR" label="凭证号" br="true"
						valuestyleproperty="style='mso-nubmer-format:\@'"></col><!-- displaytype="hidden" -->
					<col column="EMP_ID" label="认领工号" br="true"
						valuestyleproperty="style='mso-nubmer-format:\@'"></col>
					<col column="EMP_NM" label="姓名" br="true"></col>
					
					<col column="ORG_NM" label="人员机构" br="true"></col>
					<col column="RATIO" label="认领比例(%)" br="true"></col>
					
					<col column="CLAIM_DT" label="认领日期" br="true"></col>
					
					<col column="REMARK" label="备注(认领理由)" datetype="clob" align="left"
						displaytype="hidden"></col>
					<col column="REMARK1" label="备注(不通过理由)" datatype="varchar"
						align="left"><!-- label="备注(不通过理由)" -->
						<inputbox type="textareabox" jsvalidate="isNotEmpty(审核不通过的理由为必输项)"
							styleproperty="style='width:99%',rows='6'"></inputbox>
					</col>

				</display>



				<sql aftersave="saveUpdate" datasource="ds_db2">

					<select>
						<value><![CDATA[
									
									SELECT   VUCH_NBR
									         ,EMP_ID
									         ,EMP_NM
									         
									         ,ORG_NM
									         ,RATIO
									      
									         ,CLAIM_DT
									         
									         ,REMARK
									         ,REMARK1
									FROM IBS.T1_VUCH_EMP_RELA	
									WHERE  	{#condition#}
									
								    ]]>
								</value>
						<condition name="VUCH_NBR" hidden="true">
							<value><![CDATA[VUCH_NBR='#data#']]></value>
						</condition>
						<condition name="EMP_ID" hidden="true">
							<value><![CDATA[EMP_ID='#data#']]></value>
						</condition>
					</select>
					<update crosspage="true"><!--CLAIM_STATUS_ID 认领状态（0-暂存；1-待审核；2-已审核；3-未通过；4-撤销; 
							5-超时自动审批; 6-事中认领自动审核通过;） confirmessage="提交后数据将不能修改，是否确认提交?" -->
						<params>
							<param name="user_id" value="session{user_id}"></param>
							<param name="current_time" value="now{}" datatype="timestamp{yyyy-MM-dd}"></param>
							<param name="current_time1" value="now{}"
								datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param><!-- datatype="timestamp{yyyy-MM-dd}" -->
						</params>
					
							<![CDATA[
							UPDATE IBS.T1_VUCH_EMP_RELA
							SET CLAIM_STATUS_ID='31'
								, VERIFY_DT=#{current_time}
								, VERIFY_EMP_ID=#{user_id}       
								, REMARK1=@{REMARK1}      
							WHERE CLAIM_STATUS_ID='1'
							AND coalesce(CST_OPEN_DT,'2018-01-01')<'2018-01-01'
							AND BIZ_TYPE_NM = '储蓄存款' 
							AND VUCH_NBR=@{VUCH_NBR__old} AND EMP_ID=@{EMP_ID__old}
							;
							
							UPDATE IBS.T1_VUCH_EMP_RELA   
							SET	 REMARK=CONCAT(COALESCE(REMARK,''),'审批时间',#{current_time1},'审批工号',#{user_id},'审批理由支行审批不通过',COALESCE(REMARK1,''))
								, REMARK1=''    
							WHERE CLAIM_STATUS_ID='31' 
							AND VUCH_NBR=@{VUCH_NBR__old} AND EMP_ID=@{EMP_ID__old}
							;
							
							]]>
					</update>

				</sql>
				<buttons><!-- refreshParentEditableListReport(pageid,reportid,edittype,closeme) -->
					<button name="button2" label="提交" position="title"
						refreshpage="true" aftercallbackmethod="refreshPage"
						confirmessage="提交后数据将不能修改，是否确认提交?" successprompt="提交成功"
						failedprompt="提交失败" positionorder="2" extends="${save.button.default}">

						saveEditableReportData({pageid:'verify_no_exs',savingReportIds:[{reportid:'report',updatetype:'save',}]});

					</button>
				</buttons>


			</report>



		</vpanel>
	</page>


</applications>
