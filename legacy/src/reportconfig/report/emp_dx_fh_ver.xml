<vpanel id="common_vpanel" align="center" width="300px">
<report id="report" title="" type="form" ><!-- form editabledetail -->
<display valuetdwidth="300px" labeltdwidth="200px" labelbgcolor="#f0f0f0" labelalign="right" valuealign="left">

	<col column="EMP_ID" label="员工号" valuestyleproperty="style='mso-number-format:\@'" br="true" labelstyleproperty="style='width:120px;'"></col>
	<col column="EMP_NM" label="员工姓名" br="true"></col>
	<col column="ORG_NM" label="机构" br="true"></col>
	<col column="EXAM_YEAR" label="考核年" br="true"></col>
	<col column="EXAM_Q" label="考核季度" br="true"></col>
	<col column="SCORE" label="得分"  br="true"></col>
	<col column="ZB_SCORE" label="满分"  br="true"></col>
	<col column="VER_REMARK" label="备注" >
		<inputbox type="textbox" jsvalidate="isNotEmpty(#label#列不允许为空)" styleproperty="style='width:99%'" />
	</col>
	<col column="MSR_PRD_DT" label="日期" displaytype="hidden"></col>
</display>

<sql aftersave="saveUpdate" datasource="ds_db2">
	<select>
		<value>
		<![CDATA[
			select distinct sc.MSR_PRD_DT,sc.EMP_ID,sc.EMP_NM,sc.EXAM_YEAR,sc.EXAM_Q
			,sc.ORG_ID
			,sc.ORG_NM
			,sc.VER_REMARK
			,sc.SCORE
			,sc.ZB_SCORE
			from ibs.T2_EMP_DX_SCORE sc
			where {#condition#} 
		 ]]>
		</value>
		<condition name="EMP_ID" label="员工号" labelposition="left" hidden="true">
			<value> 
				<![CDATA[sc.EMP_ID ='#data#']]>
			</value>
		</condition>
		<condition name="MSR_PRD_DT" label="日期" labelposition="left" hidden="true" defaultvalue="session{exam_msr_dt}">
			<value> 
				<![CDATA[sc.MSR_PRD_DT ='#data#']]>
			</value>
		</condition>
		
	</select>
	<update crosspage="true">
		<params>
			<param name="user_id" value="session{user_id}"></param>
			<param name="current_time" value="now{}"
				datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param><!-- datatype="timestamp{yyyy-MM-dd}" -->
			<param name="ip" value="session{ip}"></param>
			<param name="exam_msr_dt" value="session{exam_msr_dt}"></param>	
		</params>
			<![CDATA[
			UPDATE IBS.T2_EMP_DX_SCORE
			SET	VER_REMARK =@{VER_REMARK}
		       ,VERIFY_PEOPLE=#{user_id}
			   ,VERIFY_TIME=#{current_time}
			   ,VERIFY_IP=#{ip}
			   ,STUS='3'
			WHERE EMP_ID = @{EMP_ID__old} 
			AND EXAM_YEAR=@{EXAM_YEAR__old}
			AND EXAM_Q=@{EXAM_Q__old}
			AND MSR_PRD_DT=#{exam_msr_dt}
			
			]]>
	</update>
</sql>
<buttons>
	<button name="button2" label="提交" position="title"
		refreshpage="true" aftercallbackmethod="refreshPage"
		confirmessage="提交后数据将不能修改，是否确认提交?" successprompt="提交成功"
		failedprompt="提交失败" positionorder="2" extends="${save.button.default}">

		saveEditableReportData({pageid:'emp_dx_fh_verNo',savingReportIds:[{reportid:'report',updatetype:'save',}]});

	</button>
</buttons>
</report>
</vpanel>
</page>
</applications>
