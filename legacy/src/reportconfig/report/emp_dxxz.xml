<!-- 二次分配查询 -->
<page id="emp_dxxz_query" js="/webresources/script/validate.js,/js/demo.js,/js/common.js">
	<interceptor>
		<imports>
			<import>com.ljbank.market.Util</import>
		</imports>
		<preaction>
			<![CDATA[
			]]>
		</preaction>
	</interceptor>

	<header>${top.header}</header>
	<vpanel id="common_vpanel" width="1200px" align="center" title="">
	<report id="title" extends="title.report1" width="1200px"></report>
		
	<report id="select" type="listform" title="定性差额二次分配" width="1200px" pagesize="15|20|-1" dataexport="richexcel"
		top="10px" personalizeclass="default" servervalidateclass="" rowselect="single"  interceptor="com.customer.interceptor.InterceptorEmpDxxzSecVer">
		<display>
			
			<col column="EXAM_YEAR" label="考核年度" width="70px"></col>
			<col column="QTD_NM" label="季度" ></col>
			<col column="BRANCH_ORG_NM" label="分行"  ></col>
			<col column="BZJX" label="应发定性薪酬总额" datatype="double{0.00}"></col>
			<col column="DXXZ" label="实发定性薪酬总额" datatype="double{0.00}"></col>
			<col column="CHA_E" label="差额" datatype="double{0.00}"></col>
			<col column="DIS_SCORE" label="二次分配额" datatype="double{0.00}"></col>
			<col column="DIS_TYP_NM" label="二次分配类型" ></col>
			<col column="STUS" label="状态" width="150px" displaytype="hidden"></col>
			<col column="MEASURE_DT" label="日期" displaytype="hidden"></col>
			<col column="BRANCH_ORG_ID" label="分行号" displaytype="hidden"></col>
			
		</display>
		<sql>
			<select>
				<value><![CDATA[
						select dis.MEASURE_DT
							,dis.EXAM_YEAR
							,dis.EXAM_Q
							,q.QTD_NM
							,dis.BRANCH_ORG_ID
							,dis.BRANCH_ORG_NM
							,dis.DIS_TYP_CD
							,dis.DIS_TYP_NM
							,dis.DIS_SCORE
							,dis.MODIFY_PEOPLE
							,dis.MODIFY_TIME
							,dis.MODIFY_IP
							,dis.VERIFY_PEOPLE
							,dis.VERIFY_TIME
							,dis.VERIFY_MODIFY_IP
							,dis.VERIFY_REMARK
							,dis.STUS
							,sum(mx.DXXZ) as DXXZ
				         	,sum(mx.BZJX) as BZJX
				         	,sum(mx.BZJX-mx.DX_SCORE) as CHA_E
						from IBS.T3_BRANCH_SEC_DISTRIBUTION dis
						inner join (select distinct BRANCH_ORG_ID, HEAD_ORG_ID from ibs.T5_ORG where ORG_TYPE_ID='EO') ou on ou.BRANCH_ORG_ID=dis.BRANCH_ORG_ID 
						inner join ibs.T5_EMP_DXJX_MX mx on dis.BRANCH_ORG_ID=mx.BRANCH_ORG_ID and dis.MEASURE_DT=mx.MEASURE_DT
						left join ibs.T9_YEAR_Q q on q.QTD=dis.EXAM_Q
						where dis.STUS='3' and {#condition#}
						group by dis.MEASURE_DT
							,dis.EXAM_YEAR
							,dis.EXAM_Q
							,dis.BRANCH_ORG_ID
							,dis.BRANCH_ORG_NM
							,dis.DIS_TYP_CD
							,dis.DIS_TYP_NM
							,dis.DIS_SCORE
							,dis.MODIFY_PEOPLE
							,dis.MODIFY_TIME
							,dis.MODIFY_IP
							,dis.VERIFY_PEOPLE
							,dis.VERIFY_TIME
							,dis.VERIFY_MODIFY_IP
							,dis.VERIFY_REMARK
							,dis.STUS		       
				]]>
				</value>

				<condition name="EXAM_YEAR" label="考核年度"
					labelposition="left" defaultvalue="session{exam_year}">
					<value> 
						<![CDATA[dis.EXAM_YEAR = '#data#']]>
					</value>
					   <inputbox type="datepicker" styleproperty="style='width:100px'" dateformat="yyyy" jsvalidate="isNotEmpty(#label# 不允许为空);" ></inputbox>
				</condition>
				<condition name="EXAM_Q" label="考核季度"
					labelposition="left">
					<value> 
							<![CDATA[dis.EXAM_Q = '#data#']]>
					</value>
					<inputbox type="selectbox" styleproperty="style='width:100px'">
						<option label="全部" value=""></option>
						<option
							source="@{select QTD , QTD_NM from ibs.T9_YEAR_Q order by QTD}"
							label="QTD_NM" value="QTD" />
					</inputbox>
				</condition>
				<condition name="ORG_ID0" labelposition="left" label="用户机构" source="session{org_id}" hidden="true">
					<value>
					<![CDATA[(dis.BRANCH_ORG_ID='#data#' or ou.HEAD_ORG_ID='#data#' )]]>
					</value>
				</condition>
				<condition name="ORG_ID1" labelposition="left" label="分行">
					<value>
					<![CDATA[dis.BRANCH_ORG_ID='#data#']]>
					</value>
					<inputbox type="selectbox" styleproperty="style='width:160px'" depends="ORG_ID0">
						<option label="全部" value=""></option>
						<option
							source="@{SELECT DISTINCT BRANCH_ORG_ID , CASE WHEN ORG_LEVEL_ID='2' THEN BRANCH_ORG_NM ELSE BRANCH_ORG_NM||'机关' END AS BRANCH_ORG_NM FROM IBS.T5_ORG 
							WHERE ORG_TYPE_ID='EO' AND ORG_LEVEL_ID IN ('2','3') and (ORG_ID='#ORG_ID0#' or HEAD_ORG_ID='#ORG_ID0#') ORDER BY BRANCH_ORG_ID}"
							label="BRANCH_ORG_NM" value="BRANCH_ORG_ID" />
					</inputbox>
				</condition>
			</select>
			
		</sql>
		<subdisplay>
			<statitems>
				<statitem property="item1" value="sum(BZJX)" datatype="float" statiscope="page|report" />
				<statitem property="item2" value="sum(DXXZ)" datatype="float" statiscope="page|report"/>
				<statitem property="item3" value="sum(CHA_E)" datatype="float" statiscope="page|report" />
				<statitem property="item4" value="sum(DIS_SCORE)" datatype="float" statiscope="page|report"/>
				
			</statitems>
			<subrow>
				<subcol property="sprop1" colspan="3" valuestyleproperty="bgcolor='#CCFAFF' align='center'" />
				<subcol property="sprop2" colspan="1" valuestyleproperty="bgcolor='#CCFAFF' align='center'" />
				<subcol property="sprop3" colspan="1" valuestyleproperty="bgcolor='#CCFAFF' align='center'" />
				<subcol property="sprop4" colspan="1" valuestyleproperty="bgcolor='#CCFAFF' align='center'" />	
				<subcol property="sprop5" colspan="1" valuestyleproperty="bgcolor='#CCFAFF' align='center'" />
					
				<subcol property="sprop6" colspan="1" valuestyleproperty="bgcolor='#CCFAFF' align='center'" />	
			</subrow>
			<format>
			<imports>
				<import>com.wabacus.util.*</import>
			</imports>
				<value>
				<![CDATA[
					
					sprop1="合计";
					sprop2=Tools.formatDouble(String.valueOf(item1),"#,##0.00");
					sprop3=Tools.formatDouble(String.valueOf(item2),"#,##0.00");
					sprop4=Tools.formatDouble(String.valueOf(item3),"#,##0.00");
					sprop5=Tools.formatDouble(String.valueOf(item4),"#,##0.00");
					sprop6="";
				]]>
				</value>
			</format>
		</subdisplay>
		<format>
		<imports>
			<import>com.customer.util.*</import>
			<import>java.util.*</import>
			<import>java.text.*</import>
			<import>com.wabacus.system.*</import>
		</imports>
		<value>
			<![CDATA[
				if(STUS.equals(""))  STUS="未修改";
				if(STUS.equals("0")) STUS="已保存";
				if(STUS.equals("1")) STUS="分行部门有权人已提交";
				if(STUS.equals("2")) STUS="分行有权人审核不通过";
				if(STUS.equals("3")) STUS="分行有权人审核通过";
			]]>
		</value>
		</format>
		<footer>
		<![CDATA[
			<tr><td height="20px"></td></tr>
			<div style='float:left'>
				<font color='green'>提示：</font>
			</div>
			<tr><td height="20px"></td></tr>
			<div style='float:left'>	
				 <font color='green'>审核通过的数据。</font>
			</div>
			<tr><td height="20px"></td></tr>
			<div style='float:left'>	
				 <font color='green'></font>
			</div>
			]]>
	</footer>
	</report>
	</vpanel>
</page>
</applications>
