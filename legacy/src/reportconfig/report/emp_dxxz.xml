<?xml version="1.0" encoding="UTF-8"?>
<applications xmlns="http://www.wabacus.com"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.wabacus.com ../xsd/wabacus.applications.xsd">
<!-- 定性薪酬查询  -->
<page id="emp_dxxz" js="/webresources/script/validate.js">
	<interceptor>
		<imports>
			<import>com.ljbank.market.Util</import>
		</imports>
		<preaction>
			<![CDATA[
			]]>
		</preaction>
	</interceptor>

	<header>${top.header}</header>
	<vpanel id="common_vpanel" width="1200px" align="center" title="">
	<report id="title" extends="title.report1" width="1200px"></report>
	<report id="select" type="listform" title="定性薪酬明细" width="1200px" pagesize="15|20|-1" dataexport="richexcel"
		top="10px" personalizeclass="default" servervalidateclass="" rowselect="single">

		<display>
			<col column="{sequence:1}" label="序号" width="70px"></col>
			<col column="EXAM_YEAR" label="考核年度" width="70px"></col>
			<col column="QTD_NM" label="季度" ></col>
			<col column="BRANCH_ORG_NM" label="分行"  ></col>
			<col column="ORG_NM" label="支行" ></col>
			<col column="EMP_ID" label="工号" valuestyleproperty="style='mso-number-format:\@'"></col>
			<col column="EMP_NM" label="姓名" ></col>
			<col column="EMP_TYPE" label="岗位状态" ></col>
			<col column="BZJX" label="应发定性薪酬" datatype="double{0.00}"></col>
			<col column="DX_SCORE" label="定性打分" datatype="double{0.00}"></col>
			<col column="DXXZ" label="实发定性薪酬" datatype="double{0.00}"></col>
		</display>
		<subdisplay>
				<statitems>
					<statitem property="item1" value="sum(BZJX)" datatype="float" statiscope="page|report" />
					<statitem property="item2" value="sum(DXXZ)" datatype="float" statiscope="page|report"/>
					
					<statitem property="item3" value="sum(DX_SCORE)" datatype="float" statiscope="page|report" />
				</statitems>
				<subrow>
					<subcol property="sprop1" colspan="8"
						valuestyleproperty="bgcolor='#CCFAFF' align='center'" />
					<subcol property="sprop2" colspan="1"
						valuestyleproperty="bgcolor='#CCFAFF' align='center'" />
					<subcol property="sprop3" colspan="1"
						valuestyleproperty="bgcolor='#CCFAFF' align='center'" />
					<subcol property="sprop4" colspan="1"
						valuestyleproperty="bgcolor='#CCFAFF' align='center'" />
						
					</subrow>
				<format>
				<imports>
					<import>com.wabacus.util.*</import>
				</imports>
					<value>
					<![CDATA[
						
						sprop1="合计";
						sprop2=Tools.formatDouble(String.valueOf(item3),"#,##0.00");
						sprop3=Tools.formatDouble(String.valueOf(item1),"#,##0.00");
						sprop4=Tools.formatDouble(String.valueOf(item2),"#,##0.00");
						
					]]>
					</value>
				</format>
			</subdisplay>
		<sql>
			<select>
				<value><![CDATA[
						select mx.MEASURE_DT
							,mx.EXAM_YEAR
							,mx.EXAM_Q
							,q.QTD_NM
							,mx.BRANCH_ORG_ID
							,mx.BRANCH_ORG_NM
							,mx.ORG_ID
							,mx.ORG_NM
							,mx.EMP_ID
							,mx.EMP_NM
							,mx.DX_SCORE
							,(case when mx.EMP_TYPE='过渡期' then mx.ACT_BZJX else mx.BZJX end) as BZJX
							,mx.DXXZ 
							,mx.EMP_TYPE
						from ibs.T5_EMP_DXJX_MX mx
						inner join ibs.T5_ORG ou on ou.ORG_TYPE_ID='EO' and ou.ORG_ID=mx.ORG_ID
						left join ibs.T9_YEAR_Q q on q.QTD=mx.EXAM_Q
						where {#condition#}
						order by mx.MEASURE_DT,mx.BRANCH_ORG_ID,mx.ORG_ID,mx.EMP_ID						       
				]]>
				</value>

				<condition name="EXAM_YEAR" label="考核年度"
					labelposition="left" defaultvalue="session{exam_year}">
					<value> 
						<![CDATA[mx.EXAM_YEAR = '#data#']]>
					</value>
					   <inputbox type="datepicker" styleproperty="style='width:100px'" dateformat="yyyy" jsvalidate="isNotEmpty(#label# 不允许为空);" ></inputbox>
				</condition>
				<condition name="EXAM_Q" label="考核季度"
					labelposition="left">
					<value> 
							<![CDATA[mx.EXAM_Q = '#data#']]>
					</value>
					<inputbox type="selectbox" styleproperty="style='width:100px'">
						<option label="全部" value=""></option>
						<option
							source="@{select QTD , QTD_NM from ibs.T9_YEAR_Q order by QTD}"
							label="QTD_NM" value="QTD" />
					</inputbox>
				</condition>
				<condition name="ORG_ID0" labelposition="left" label="用户机构" hidden="true"
						source="session{org_id}">
						<value>
						<![CDATA[(mx.ORG_ID='#data#' or mx.BRANCH_ORG_ID='#data#' or ou.HEAD_ORG_ID='#data#' )]]>
						</value>
				</condition>
				<condition name="ORG_ID1" labelposition="left" label="分行">
					<value>
					<![CDATA[(mx.BRANCH_ORG_ID='#data#')]]>
					</value>
					<inputbox type="selectbox" styleproperty="style='width:140px'" depends="ORG_ID0">
						<option label="全部" value=""></option>
						<option
							source="@{SELECT DISTINCT BRANCH_ORG_ID , CASE WHEN ORG_LEVEL_ID='2' THEN BRANCH_ORG_NM ELSE BRANCH_ORG_NM||'机关' END AS BRANCH_ORG_NM FROM IBS.T5_ORG 
							WHERE ORG_TYPE_ID='EO' AND ORG_LEVEL_ID IN ('2','3') and (ORG_ID='#ORG_ID0#' or HEAD_ORG_ID='#ORG_ID0#')  ORDER BY BRANCH_ORG_ID}"
							label="BRANCH_ORG_NM" value="BRANCH_ORG_ID" />
					</inputbox>
				</condition>
				<condition name="ORG_ID2" labelposition="left" label="支行">
					<value>
					<![CDATA[(mx.ORG_ID='#data#')]]>
					</value>
					<inputbox type="selectbox" depends="ORG_ID1"
						styleproperty="style='width:140px'">
						<option label="全部" value=""></option>
						<option label="无" value="" type="false"></option>
						<option
							source="@{SELECT DISTINCT ORG_ID, ORG_NM FROM IBS.T5_ORG WHERE BRANCH_ORG_ID='#ORG_ID1#' and ORG_TYPE_ID='EO' AND ORG_LEVEL_ID IN ('1','2') ORDER BY ORG_ID}"
							label="ORG_NM" value="ORG_ID" />
					</inputbox>
				</condition>
				<condition name="EMP_ID" label="员工号" labelposition="left">
					<value> 
						<![CDATA[mx.EMP_ID like '%#data#%']]>
					</value>
					<inputbox styleproperty="style='width:100px'"></inputbox>
				</condition>
				<condition name="EMP_NM" label="员工姓名" labelposition="left">
					<value> 
						<![CDATA[mx.EMP_NM like '%#data#%']]>
					</value>
					<inputbox styleproperty="style='width:100px'"></inputbox>
				</condition>
			</select>
			
		</sql>
	</report>
	</vpanel>
</page>
