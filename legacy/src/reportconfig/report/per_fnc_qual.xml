					<col column="MODIFY_IP" label="填写IP" displaytype="hidden"></col>
				</display>
				<sql>
					<select>
						<value>
						<![CDATA[
						SELECT 
						    PER_ID
						    , PER_NM
						    , A.ORG_ID
						    , B.ORG_NM
						    , A.BRANCH_ORG_ID
						    , B.BRANCH_ORG_NM
						    , PER_IDENT
						    , PER_POSTITION_NAME
						    , QUAL_BANK_PUB_NUMBER
						    , QUAL_BANK_OLD_FNC_NUMBER
						    , QUAL_BANK_NEW_FNC_NUMBER
						    , QUAL_AFP_NUMBER
						    , QUAL_CFP_NUMBER
						    , REMARK 
						    , MODIFY_PEOPLE
						    , MODIFY_TIME
						    , MODIFY_IP
						 from IBS.T3_PER_FNC_QUAL A
						 left join IBS.T5_ORG     B
						 on A.ORG_ID=B.ORG_ID AND A.BRANCH_ORG_ID=B.BRANCH_ORG_ID AND B.ORG_TYPE_ID='EO'
						 where {#condition#} 
						 and (QUAL_BANK_PUB_NUMBER is  not null and QUAL_BANK_PUB_NUMBER<>'' or QUAL_BANK_NEW_FNC_NUMBER is not null and QUAL_BANK_NEW_FNC_NUMBER<>'' or QUAL_AFP_NUMBER is not null and QUAL_AFP_NUMBER<>'' or QUAL_CFP_NUMBER is not null and QUAL_CFP_NUMBER<>'' or REMARK is not null and REMARK<>'')
						]]>
						</value>
						<condition name="PER_ID" label="员工号">
							<value><![CDATA[a.PER_ID like '%#data#%']]></value>
							<inputbox>
								<typeprompt width="150" count="10">
									<promptcol label="PER_ID" value="PER_ID" title="员工号"
										matchmode="anywhere" casesensitive="false" />
									<promptcol label="PER_NAME" value="PER_NAME" title="员工姓名"
										matchmode="anywhere" casesensitive="false" />
									<datasource>
										<option
											source="@{Select DISTINCT PER_ID, PER_NAME from PUB.PERSONNEL WHERE  {#matchcondition#}} " />
									</datasource>
								</typeprompt>
							</inputbox>
						</condition>
						<condition name="PER_NAME" label="员工姓名">
							<value><![CDATA[a.PER_NAME like '%#data#%']]></value>
							<inputbox>
								<typeprompt width="150" count="10">
									<promptcol label="PER_ID" value="PER_ID" title="员工号"
										matchmode="anywhere" casesensitive="false" />
									<promptcol label="PER_NAME" value="PER_NAME" title="员工姓名"
										matchmode="anywhere" casesensitive="false" />
									<datasource>
										<option
											source="@{Select DISTINCT PER_ID, PER_NAME from PUB.PERSONNEL WHERE  {#matchcondition#}} " />
									</datasource>
								</typeprompt>
							</inputbox>
						</condition>
						<condition name="ORG_ID1" labelposition="left" label="分行">
							<value>                                                                                                                                                                           
							<![CDATA[(A.BRANCH_ORG_ID='#data#')]]>
							</value>
							<inputbox type="selectbox">
								<option label="全部" value=""></option>
								<option
									source="@{Select distinct BRANCH_ORG_ID , BRANCH_ORG_NM from IBS.T5_ORG where HEAD_ORG_ID='9990' and ORG_TYPE_ID='EO' and ORG_LEVEL_ID='2'}"
									label="BRANCH_ORG_NM" value="BRANCH_ORG_ID" />

							</inputbox>
						</condition>
						<condition name="ORG_ID2" labelposition="left" label="支行">
							<value>                                                                                                                                                                           
							<![CDATA[(A.ORG_ID='#data#')]]>
							</value>
							<inputbox type="selectbox" depends="ORG_ID1">
								<option label="全部" value=""></option>
								<option label="无" value="" type="false"></option>
								<option
									source="@{Select distinct ORG_ID, ORG_NM from IBS.T5_ORG where BRANCH_ORG_ID='#ORG_ID1#' and ORG_TYPE_ID='EO' and ORG_LEVEL_ID='1'}"
									label="ORG_NM" value="ORG_ID" />
							</inputbox>
						</condition>
					</select>
				</sql>
			</report>
		</vpanel>
	</page>

