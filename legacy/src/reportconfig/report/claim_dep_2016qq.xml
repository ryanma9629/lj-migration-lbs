<?xml version="1.0" encoding="UTF-8"?>
<applications xmlns="http://www.wabacus.com"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.wabacus.com ../xsd/wabacus.applications.xsd">
	<!-- 针对蛐蛐网活动存款认领 对于卡配折情况不变 -->
	<page id="claim_dep_2016qq"
		js="/webresources/script/validate.js,/js/demo.js,/js/common.js"><!-- /webresources/script/validate.js -->

		<header>${top.header}</header>
		<vpanel id="common_vpanel" width="1300px" align="center" title="">

			<report id="title" extends="title.report1" width="1300px"></report>
			<report id="select" type="form" title="账户信息" width="1300px"
				interceptor="com.customer.interceptor.InterceptorClaimDep2016QQ"
				top="10px" personalizeclass="default">

				<display valuetdwidth="120px" labeltdwidth="80px">
					<!-- col column="{sequence:1}" label="序号"></col displaytype="hidden" 
						br="true" -->
					<col column="VUCH_NBR" label="凭证号" valuestyleproperty="style='mso-nubmer-format:\@'"></col>
					<col column="CST_ID" label="客户号" displaytype="hidden"></col>
					<col column="CST_NM" label="客户名"></col>
					<col column="VUCH_TYPE_ID" label="凭证类型代码" displaytype="hidden"></col>
					<col column="VUCH_TYPE_NM" label="凭证类型名称"></col>
					<col column="WITH_CARD_F" label="配卡标志" displaytype="hidden"></col>
					<col column="BIZ_TYPE_ID" label="业务类型代码" displaytype="hidden"></col>
					<col column="BIZ_TYPE_NM" label="业务类型名称" br="true"></col>
					<col column="ORG_ID" label="机构号" displaytype="hidden"
						valuestyleproperty="style='mso-nubmer-format:\@'"></col>
					<col column="ORG_NM" label="机构名"></col>
					<col column="BRANCH_ORG_ID" label="分行机构号" displaytype="hidden"
						valuestyleproperty="style='mso-nubmer-format:\@'"></col>
					<col column="BRANCH_ORG_NM" label="分行机构名"></col>
					<col column="OPEN_DT" label="开户日期"></col>
					<col column="CLOSE_DT" label="销户日期" displaytype="hidden"></col>
					<col column="VUCH_STATUS_ID" label="凭证状态代码" displaytype="hidden"></col>
					<col column="VUCH_STATUS_NM" label="凭证状态名称" br="true"></col>
					<col column="DEPT_ID" label="部门编号" displaytype="hidden"></col>
					<col column="MARKETING_NO" label="营销活动编号"></col>
				</display>
				<sql>
					<select>
						<value><![CDATA[
							SELECT 		VUCH_NBR      
										,CST_ID            
										,CST_NM            
										,VUCH_TYPE_ID      
										,VUCH_TYPE_NM      
										,WITH_CARD_F       
										,BIZ_TYPE_ID       
										,BIZ_TYPE_NM       
										,ORG_ID            
										,ORG_NM            
										,BRANCH_ORG_ID     
										,BRANCH_ORG_NM     
										,OPEN_DT           
										,CLOSE_DT          
										,VUCH_STATUS_ID    
										,VUCH_STATUS_NM    
										,DEPT_ID  
										,MARKETING_NO       
							FROM IBS.T1_VUCH_DETAIL		
							WHERE COALESCE(MARKETING_NO,'') in ('2016qq') 
							and {#condition#}
							%SQL% 
							WITH UR
							
							
						    ]]>
						</value>
						<condition name="VUCH_NBR" label="凭证号" labelposition="left">
							<value><![CDATA[VUCH_NBR='#data#']]></value>
						</condition>
					</select>
				</sql>
			</report>
			<!-- 个人认领信息填写 -->
			<report id="dtl" title="认领信息" type="form" personalizeclass="default"
				servervalidateclass="com.ljbank.market.Servervalidate_ClaimDep;com.ljbank.market.Util"
				depends="select" dependsparams="txtaccid=@{VUCH_NBR}" top="10px"
				refreshid="dtl"><!-- interceptor="com.customer.interceptor.InterceptorClaimDepDtl" -->


				<display valuetdwidth="60px" labeltdwidth="40px" labelalign="center">

					<col column="VUCH_NBR" label="凭证号" displaytype="hidden" align="left"
						valuestyleproperty="style='mso-nubmer-format:\@'"></col><!-- displaytype="hidden" -->
					<col column="EMP_ID" label="存款联系人" valuestyleproperty="style='mso-nubmer-format:\@'">
						<inputbox styleproperty="style='width:90%'"></inputbox>
					</col>

					<col column="VERIFY_DT" label="审批时间" displaytype="hidden"></col>
					<col column="VERIFY_EMP_ID" label="审批人" displaytype="hidden"></col>
					<col column="REMARK" label="备注" displaytype="hidden"></col>
					
					<col column="CLAIM_STATUS_ID" label="认领状态"></col>
					<col column="CLAIM_DT" label="认领日期" br="true"></col>

				</display>

				<sql datasource="ds_db2">
					<select>
						<value><![CDATA[
							SELECT   VUCH_NBR
							         ,EMP_ID
							         ,VERIFY_DT
							         ,VERIFY_EMP_ID
							         ,REMARK
							         ,CLAIM_STATUS_ID
							         ,CLAIM_DT

							FROM IBS.T1_VUCH_EMP_RELA	
						
							WHERE  	COALESCE(MARKETING_NO,'') in ('2016qq') 
							and {#condition#}
							
						    ]]>
						</value>
						<condition name="txtaccid" hidden="true">
							<value><![CDATA[VUCH_NBR='#data#']]></value>
						</condition>
					</select>

					<update confirmessage="保存">
						<params>
							<param name="user_id" value="session{user_id}"></param>
							<param name="current_time" value="now{}" datatype="timestamp{yyyy-MM-dd}"></param>
							<param name="current_time1" value="now{}"
								datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param><!-- datatype="timestamp{yyyy-MM-dd}" -->
							
						</params>
						<value><!--只可以修改存款联系人  -->
							<![CDATA[
								update IBS.T1_VUCH_EMP_RELA
								set EMP_ID = @{EMP_ID}
								    ,VERIFY_DT=#{current_time}
								    ,VERIFY_EMP_ID=#{user_id}
								    ,REMARK=#{current_time1}||'有权人:'||#{user_id}||'蛐蛐网活动认领输入界面修改存款联系人。'
								where VUCH_NBR=@{VUCH_NBR__old}
								and COALESCE(MARKETING_NO,'') in ('2016qq') 
								;
								
								Insert into IBS.T6_VUCH_EMP_RELA_CHANGE_LOG 
								(
									 VUCH_NBR              
									,OLD_EMP_ID           
									,OLD_RATIO            
									,OLD_CLAIM_STATUS_ID  
									,OLD_CLAIM_DT         
									,OLD_VERIFY_DT        
									,OLD_VERIFY_EMP_ID    
									,OLD_REMARK           
									,NEW_EMP_ID           
									,NEW_RATIO            
									,NEW_CLAIM_STATUS_ID  
									,NEW_CLAIM_DT         
									,NEW_VERIFY_DT        
									,NEW_VERIFY_EMP_ID    
									,NEW_REMARK 
									,CHANGE_TYPE
									,CHANGE_FLAG          
								)      
								Values
								(
									 @{VUCH_NBR__old}
									,@{EMP_ID__old}
									,'100'
									,'6'
									,@{CLAIM_DT__old}
									,@{VERIFY_DT__old}
									,@{VERIFY_EMP_ID__old}
									,@{REMARK__old}
									,@{EMP_ID}
									,'100'
									,'6'
									,#{current_time1}
								    ,#{current_time1}
									,#{user_id}
									,#{current_time}||'有权人:'||#{user_id}||'通过蛐蛐网认领页面调整认领,调整前认领人为：'||@{EMP_ID__old}||'调整后认领人为：'  ||@{EMP_ID} 
								    ,'U'
								    ,'0'
								)
								;
							]]>
						</value>
					</update>

				</sql>

				<format>
					<imports>
						<import>com.ljbank.util.*</import>
						<import>java.util.*</import>
						<import>java.text.*</import>
						<import>com.wabacus.system.*</import>
					</imports>
					<value>
					<![CDATA[
			        CLAIM_STATUS_ID=CLAIM_STATUS_ID==null?"":CLAIM_STATUS_ID.trim();
					if(CLAIM_STATUS_ID.equals("0")) CLAIM_STATUS_ID="0-暂存";
					else if(CLAIM_STATUS_ID.equals("1")) CLAIM_STATUS_ID="1-待审核";
					else if(CLAIM_STATUS_ID.equals("2")) CLAIM_STATUS_ID="2-已审核";
					else if(CLAIM_STATUS_ID.equals("3")) CLAIM_STATUS_ID="3-未通过";
					else if(CLAIM_STATUS_ID.equals("4")) CLAIM_STATUS_ID="4-撤销";
					else if(CLAIM_STATUS_ID.equals("5")) CLAIM_STATUS_ID="5-超时自动审批";
					else if(CLAIM_STATUS_ID.equals("6")) CLAIM_STATUS_ID="6-事中认领自动审核通过";
										
					
	
					]]>
			  		</value>
				</format>
			</report>

			<footer><![CDATA[
				<tr><td height="50px"></td></tr>
				<div style='float:left'>
					<font color='green'>提示：1-参加蛐蛐网活动的凭证只能够修改认领人信息。</font>
				</div>
				<tr><td height="20px"></td></tr>
				<div style='float:left'>	
					 <font color='green'>2-储蓄存折若关联配有银行卡，需对关联卡进行认领。</font>
				</div>
				<tr><td height="20px"></td></tr>
				<div style='float:left'>
					<font color='green'>3-参加蛐蛐网活动的凭证不能进行存款认领。</font>
				</div>
				]]>
			</footer>
		</vpanel>

	</page>


</applications>
