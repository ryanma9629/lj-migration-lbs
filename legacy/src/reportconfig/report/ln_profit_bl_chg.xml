<?xml version="1.0" encoding="UTF-8"?>
<applications xmlns="http://www.wabacus.com"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.wabacus.com ../xsd/wabacus.applications.xsd">
<!-- 贷款不良利润调整 （录入权限在分行） -->
<page id="ln_profit_bl_chg"
	js="/webresources/script/validate.js,/js/demo.js,/js/common.js">
	<header>${top.header}</header>
	
	<vpanel id="common_vpanel" align="center" width="1000px" title="">
		<report id="title" extends="title.report1" width="1300px"></report>
		<report id="ln_bl_mod_rpt" type="listform" personalizeclass="default"
			interceptor="com.customer.interceptor.InterceptorLnBlChg"
			servervalidateclass="com.ljbank.market.Util ; com.ljbank.market.TestPersonnel;com.ljbank.market.Servervalidate_lnBlChg"
			pagesize="15|20|-1" width="1800px" dataexport="richexcel" scrollwidth="1300px" rowselect="multiple">
			<display>
				<col column="{sequence:1}" label="序号" width="40px"></col>
				<col column="MEASURE_DT" label="统计日期" width="100px">
					<inputbox type="selectbox"  styleproperty="style='width:97%'">
						<option
							source="@{Select MEASURE_DT from IBS.T99_MIDDLE_INCOME_SWITCH where SWITCH_F='1'}"
							label="MEASURE_DT" value="MEASURE_DT" >
					    </option>
					</inputbox>
				</col>
				<col column="EMP_ID"  label="员工号" align="center" valuestyleproperty="style='mso-number-format:\@'" clickorderby="true">
					<inputbox jsvalidate="isNotEmpty(员工号不可以为空)"
						servervalidate="isPersonnel(必须是员工号); isSameBranchOrg(必须是本分行员工) "
						styleproperty="style='width:97%'">
						<autocomplete
							columns="EMP_NM; PSTN_TYPE; PSTN_TYPE_NM; SUB_PSTN_TYPE; SUB_PSTN_TYPE_NM"
							colvaluecondition="EMP_ID like '%#EMP_ID#%'"
							dataset="select * from (Select EMP_ID,EMP_NM, ORG_ID, ORG_NM, BRANCH_ORG_ID, BRANCH_ORG_NM, PSTN_TYPE, PSTN_TYPE_NM, SUB_PSTN_TYPE, SUB_PSTN_TYPE_NM from IBS.T5_EMP) where 1=1 {#condition#}  order by EMP_NM ">
						</autocomplete>
					</inputbox>
				</col>
				<col column="EMP_NM" label="员工姓名" ></col>
				<col column="PSTN_TYPE" label="主考核类别"  displaytype="hidden"></col>
				<col column="PSTN_TYPE_NM" label="主考核类别" displaytype="hidden"></col>
				<col column="SUB_PSTN_TYPE" label="子考核类别"  displaytype="hidden"></col>
				<col column="SUB_PSTN_TYPE_NM" label="子考核类别"  displaytype="hidden"></col>
				<col column="VUCH_NBR" label="凭证号"  valuestyleproperty="style='mso-number-format:\@'" >
					<inputbox jsvalidate="isNotEmpty(凭证号不可以为空)" servervalidate="isVUCH_NBR()"  styleproperty="style='width:97%'" >
						<autocomplete
							columns="OPEN_DT; CST_NM;ORG_CD; ORG_NM; VUCH_STS_NM; RATIO;QTD_AVG_BAL;QTD_PROFIT;PERF_STS_TP_ID;PERF_STS_TP_NM;ACG_SBJ_ID;CHG_DT"
							colvaluecondition="RE.EMP_ID = '#EMP_ID#' and re.VUCH_NBR='#VUCH_NBR#' and vdl.MEASURE_DT=date('#MEASURE_DT#') AND emp.MEASURE_DT=date('#MEASURE_DT#') AND LA.MSR_PRD_ID=INTEGER(TO_CHAR('#MEASURE_DT#','YYYYMMDD')) and re.MEASURE_DT=date('#MEASURE_DT#')"
							dataset="select RE.EMP_ID,re.VUCH_NBR,vdl.OPEN_DT,vdl.CST_NM,vdl.ORG_ID ORG_CD,vdl.ORG_NM,vdl.VUCH_STATUS_NM AS VUCH_STS_NM,RE.RATIO,vdl.QTD_AVG_BAL AS QTD_AVG_BAL, vdl.Q_PROFIT AS QTD_PROFIT,FP.PERF_STS_TP_ID,FP.PERF_STS_TP_NM,LA.ACG_SBJ_ID,'9999-12-31' as CHG_DT
									from ibs.T1_VUCH_EMP_RELA_Q re
									inner join ibs.T2_EMP_DEP_LN_VUCH_PROFIT_DETAIL vdl on vdl.VUCH_NBR=re.VUCH_NBR and re.EMP_ID=vdl.EMP_ID 
									INNER JOIN PUB.LN_AR_SMY LA ON LA.BIZ_DIL_NBR=RE.VUCH_NBR 
									INNER JOIN DIM.DIM_LN_FIVE_TIER_CL_TP FP ON FP.LN_FIVE_TIER_CL_TP_ID=LA.LN_FIVE_TIER_CL_TP_ID
									inner join ibs.T5_EMP_Q emp on emp.EMP_ID=re.EMP_ID 
									where {#condition#} 
									">
						</autocomplete>
					</inputbox>
				</col>
				<col column="OPEN_DT" label="开户日期" ></col>
				<col column="CST_NM" label="客户姓名" ></col>
				<col column="ORG_CD" label="机构" ></col>
				<col column="ORG_NM" label="机构名称" ></col>
				<col column="RATIO" label="认领比例" ></col>
				<col column="QTD_AVG_BAL" label="季日均" ></col>
				<col column="QTD_PROFIT" label="季利润" ></col>
				<col column="QTD_PROFIT_OLD" label="季利润（应计）"  >
				</col>
				<col column="VUCH_STS_NM" label="凭证状态" ></col>
				<col column="PERF_STS_TP_ID" label="正常/不良ID" displaytype="hidden"></col>
				<col column="PERF_STS_TP_NM" label="凭证状态PERF_STS_TP_NM" displaytype="hidden"></col>
				<col column="ACG_SBJ_ID" label="科目" displaytype="hidden"></col>
				
				<col column="CHG_DT" label="调整期" displaytype="hidden">
				</col>
			</display>
			<sql>
				<select>
					<value>
						<![CDATA[
						select bl.*,org.BRANCH_ORG_ID 
						from ibs.T2_EMP_LN_PROFIT_BL_CHG bl
						inner join ibs.T5_ORG org on org.ORG_ID=bl.ORG_CD and org.ORG_TYPE_ID='EO'
						WHERE {#condition#} %SQL%
						ORDER BY bl.MEASURE_DT DESC,org.BRANCH_ORG_ID,bl.ORG_CD,bl.EMP_ID
						]]>
					</value>
					<condition name="EMP_ID" label="认领工号" labelposition="left">
						<value>
						 		<![CDATA[EMP_ID='#data#']]>
						</value>
						<inputbox styleproperty="style='width:100px'">
							<typeprompt width="300" count="10">
								<promptcol label="EMP_ID" value="EMP_ID" title="认领工号"
									matchmode="anywhere" casesensitive="false" />
								<promptcol label="EMP_NM" value="EMP_NM" title="姓名"
									matchmode="anywhere" casesensitive="false" />
								<datasource>
									<option
										source="@{Select DISTINCT EMP_ID, EMP_NM from IBS.T5_EMP  WHERE   {#matchcondition#}} " />
								</datasource>
							</typeprompt>
						</inputbox>
					</condition>
					<condition name="EMP_NM" label="姓名" labelposition="left">
						<value>
						 		<![CDATA[EMP_NM='#data#']]>
						</value>
						<inputbox styleproperty="style='width:100px'">
							<typeprompt width="300" count="10">
								<promptcol label="EMP_ID" value="EMP_ID" title="认领工号"
									matchmode="anywhere" casesensitive="false" />
								<promptcol label="EMP_NM" value="EMP_NM" title="姓名"
									matchmode="anywhere" casesensitive="false" />
								<datasource>
									<option
										source="@{Select DISTINCT EMP_ID, EMP_NM from IBS.T5_EMP  WHERE   {#matchcondition#}} " />
								</datasource>
							</typeprompt>
						</inputbox>
					</condition>
					<condition name="ORG_ID0" source="session{org_id}" hidden="true">
						<value> 
 							<![CDATA[ (org.BRANCH_ORG_ID = '#data#' or org.HEAD_ORG_ID='#data#' or bl.ORG_CD='#data#' )]]>
						</value>
					</condition>
					<condition name="ORG_ID1" labelposition="left" label="分行" >
						<value>
							<![CDATA[org.BRANCH_ORG_ID='#data#']]>
						</value>
						<inputbox type="selectbox" styleproperty="style='width:150px'" depends="ORG_ID0">
							<option label="全部" value=""></option>
							<option
								source="@{SELECT DISTINCT BRANCH_ORG_ID,BRANCH_ORG_NM FROM IBS.T5_ORG WHERE ORG_TYPE_ID='EO' AND ORG_LEVEL_ID IN ('1','2','3') and (ORG_ID='#ORG_ID0#' or BRANCH_ORG_ID='#ORG_ID0#' or HEAD_ORG_ID='#ORG_ID0#') ORDER BY BRANCH_ORG_ID}"
								label="BRANCH_ORG_NM" value="BRANCH_ORG_ID" />
						</inputbox>
					</condition>
					<condition name="ORG_ID2" labelposition="left" label="支行">
						<value>
						<![CDATA[bl.ORG_CD='#data#']]>
						</value>
						<inputbox type="selectbox" depends="ORG_ID1;ORG_ID0"
							styleproperty="style='width:150px'">
							<option label="全部" value=""></option>
							<option label="无" value="" type="false"></option>
							<option
								source="@{SELECT DISTINCT ORG_ID, ORG_NM FROM IBS.T5_ORG WHERE ORG_TYPE_ID='EO' AND ORG_LEVEL_ID IN ('1','2') and BRANCH_ORG_ID='#ORG_ID1#' and (HEAD_ORG_ID='#ORG_ID0#' or BRANCH_ORG_ID='#ORG_ID0#' or ORG_ID='#ORG_ID0#') ORDER BY ORG_ID}"
								label="ORG_NM" value="ORG_ID" />
						</inputbox>
					</condition>
					<condition name="REMARK" label="调整期" labelposition="left" defaultvalue="session{exam_msr_dt_exam}">
						<value>
					 	<![CDATA[bl.CHG_DT='#data#']]>
						</value>
						<inputbox type="selectbox" styleproperty="style='width:100px'">
							<option
								source="@{Select MEASURE_DT , SWITCH_F , REMARK from IBS.T99_MIDDLE_INCOME_SWITCH ORDER BY MEASURE_DT DESC}"
								label="REMARK" value="MEASURE_DT" />
						</inputbox>
					</condition>
				</select>

				<insert >
					<params>
						<param name="ip" value="session{ip}"></param>
						<param name="user_id" value="session{user_id}"></param>
						<param name="current_time" value="now{}"
							datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
					</params>
					<value>
						insert into ibs.T2_EMP_LN_PROFIT_BL_CHG(
								 MEASURE_DT
								,EMP_ID
								,EMP_NM
								,PSTN_TYPE
								,PSTN_TYPE_NM
								,SUB_PSTN_TYPE
								,SUB_PSTN_TYPE_NM
								,VUCH_NBR
								,OPEN_DT
								,CST_NM
								,ORG_CD
								,ORG_NM
								,VUCH_STS_NM
								,RATIO
								,QTD_AVG_BAL
								,QTD_PROFIT
								
								,PERF_STS_TP_ID
								,PERF_STS_TP_NM
								,ACG_SBJ_ID
								,MODIFY_PEOPLE
								,MODIFY_TIME
								,MODIFY_IP
								,CHG_DT
								)
						  values(
								@{MEASURE_DT}
								,@{EMP_ID}
								,@{EMP_NM}
								,@{PSTN_TYPE}
								,@{PSTN_TYPE_NM}
								,@{SUB_PSTN_TYPE}
								,@{SUB_PSTN_TYPE_NM}
								,@{VUCH_NBR}
								,@{OPEN_DT}
								,@{CST_NM}
								,@{ORG_CD}
								,@{ORG_NM}
								,@{VUCH_STS_NM}
								,@{RATIO}
								,@{QTD_AVG_BAL}
								,@{QTD_PROFIT}
								
								,@{PERF_STS_TP_ID}
								,@{PERF_STS_TP_NM}
								,@{ACG_SBJ_ID}
								,#{user_id}
								,#{current_time}
								,#{ip}
								,@{CHG_DT}
								)
					</value>
				</insert>
				
				<delete>
					<params>
						<param name="user_id" value="session{user_id}"></param>
						<param name="current_time" value="now{}"
							datatype="timestamp{yyyy-MM-dd HH:mm:ss}"></param>
						<param name="ip" value="session{ip}"></param>

					</params>
					<![CDATA[
						delete from ibs.T2_EMP_LN_PROFIT_BL_CHG 
						where EMP_ID = @{EMP_ID__old}
						and MEASURE_DT = @{MEASURE_DT__old}
						and VUCH_NBR = @{VUCH_NBR__old}
						and RATIO = @{RATIO__old}
						
					]]>
				</delete>
			</sql>
			<format>
				<value>
				
		  		</value>
			</format>
			<footer><![CDATA[
			<tr><td height="20px"></td></tr>
			<div style='float:left'>
				<font color='green'>提示：</font>
			</div>
			<tr><td height="20px"></td></tr>
			<div style='float:left'>	
				 <font color='green'>1-分行有权人仅能维护录入本分行员工贷款不良清收业绩调整，不能跨行录入。</font>
			</div>
			<tr><td height="20px"></td></tr>
			<div style='float:left'>	
				 <font color='green'>2-请在考核期内对数据进行维护，过期数据不能补录。</font>
			</div>
			
			]]>
		</footer>

			
		</report>
	</vpanel>
</page>

<!-- 贷款不良利润调整 （查询） -->
<page id="ln_profit_bl_sel"
	js="/webresources/script/validate.js,/js/demo.js,/js/common.js">
	<header>${top.header}</header>
	<vpanel id="common_vpanel" align="center" width="1000px" title="">
		<report id="title" extends="title.report1" width="1300px"></report>
		<report id="ln_bl_sel_rpt" type="crosslist" personalizeclass="default"
			interceptor="com.customer.interceptor.InterceptorLnBlChgSel"
			servervalidateclass="com.ljbank.market.Util ; com.ljbank.market.TestPersonnel"
			pagesize="15|20|-1" width="1800px" dataexport="richexcel" scrollwidth="1300px" rowselect="multiple">

			<display>

				<col column="{sequence:1}" label="序号" width="40px"></col>
				<col column="MEASURE_DT" label="统计日期" width="100px"></col>
				
				<col column="EMP_ID"  label="员工号" align="center" valuestyleproperty="style='mso-number-format:\@'" clickorderby="true" rowgroup="true"></col>
				<col column="EMP_NM" label="员工姓名" rowgroup="true"></col>
				
				
				<col column="PSTN_TYPE" label="主考核类别"  displaytype="hidden"></col>
				<col column="PSTN_TYPE_NM" label="主考核类别" displaytype="hidden"></col>
				<col column="SUB_PSTN_TYPE" label="子考核类别"  displaytype="hidden"></col>
				<col column="SUB_PSTN_TYPE_NM" label="子考核类别"  displaytype="hidden"></col>
				<col column="VUCH_NBR" label="凭证号"  valuestyleproperty="style='mso-number-format:\@'" clickorderby="true"></col>
				<col column="OPEN_DT" label="开户日期" ></col>
				<col column="CST_NM" label="客户姓名" ></col>
				<col column="ORG_CD" label="机构" ></col>
				<col column="ORG_NM" label="机构名称" ></col>
				<col column="RATIO" label="认领比例" ></col>
				<col column="QTD_AVG_BAL" label="季日均" ></col>
				<col column="QTD_PROFIT" label="季利润" ></col>
				<col column="QTD_PROFIT_OLD" label="季利润（应计）"  >
				</col>
				<col column="VUCH_STS_NM" label="凭证状态" ></col>
				<col column="PERF_STS_TP_ID" label="正常/不良ID" displaytype="hidden"></col>
				<col column="PERF_STS_TP_NM" label="凭证状态PERF_STS_TP_NM" displaytype="hidden"></col>
				<col column="ACG_SBJ_ID" label="科目" displaytype="hidden"></col>
				
			</display>
			<sql>
				<select>
					<value>
						<![CDATA[
						select bl.*,org.BRANCH_ORG_ID,org.HEAD_ORG_ID
						from ibs.T2_EMP_LN_PROFIT_BL_CHG bl
						inner join ibs.T5_ORG org on org.ORG_ID=bl.ORG_CD and org.ORG_TYPE_ID='EO' %SQL%
						WHERE {#condition#}
						ORDER BY bl.MEASURE_DT DESC,org.BRANCH_ORG_ID,bl.ORG_CD,bl.EMP_ID
						]]>
					</value>
					<condition name="EMP_ID" label="认领工号" labelposition="left">
						<value>
						 		<![CDATA[EMP_ID='#data#']]>
						</value>
						<inputbox styleproperty="style='width:100px'">
							<typeprompt width="300" count="10">
								<promptcol label="EMP_ID" value="EMP_ID" title="认领工号"
									matchmode="anywhere" casesensitive="false" />
								<promptcol label="EMP_NM" value="EMP_NM" title="姓名"
									matchmode="anywhere" casesensitive="false" />
								<datasource>
									<option
										source="@{Select DISTINCT EMP_ID, EMP_NM from IBS.T5_EMP  WHERE   {#matchcondition#}} " />
								</datasource>
							</typeprompt>
						</inputbox>
					</condition>
					<condition name="EMP_NM" label="姓名" labelposition="left">
						<value>
						 		<![CDATA[EMP_NM='#data#']]>
						</value>
						<inputbox styleproperty="style='width:100px'">
							<typeprompt width="300" count="10">
								<promptcol label="EMP_ID" value="EMP_ID" title="认领工号"
									matchmode="anywhere" casesensitive="false" />
								<promptcol label="EMP_NM" value="EMP_NM" title="姓名"
									matchmode="anywhere" casesensitive="false" />
								<datasource>
									<option
										source="@{Select DISTINCT EMP_ID, EMP_NM from IBS.T5_EMP  WHERE   {#matchcondition#}} " />
								</datasource>
							</typeprompt>
						</inputbox>
					</condition>
					<condition name="ORG_ID0" source="session{org_id}" hidden="true">
						<value> 
 							<![CDATA[ (org.BRANCH_ORG_ID = '#data#' or org.HEAD_ORG_ID='#data#' or bl.ORG_CD='#data#' )]]>
						</value>
					</condition>
					<condition name="ORG_ID1" labelposition="left" label="分行" >
						<value>
							<![CDATA[(org.BRANCH_ORG_ID='#data#')]]>
						</value>
						<inputbox type="selectbox" styleproperty="style='width:150px'" depends="ORG_ID0">
							<option label="全部" value=""></option>
							<option
								source="@{SELECT DISTINCT BRANCH_ORG_ID,BRANCH_ORG_NM FROM IBS.T5_ORG WHERE ORG_TYPE_ID='EO' AND ORG_LEVEL_ID IN ('1','2','3') and (ORG_ID='#ORG_ID0#' or BRANCH_ORG_ID='#ORG_ID0#' or HEAD_ORG_ID='#ORG_ID0#') ORDER BY BRANCH_ORG_ID}"
								label="BRANCH_ORG_NM" value="BRANCH_ORG_ID" />
						</inputbox>
					</condition>
					<condition name="ORG_ID2" labelposition="left" label="支行">
						<value>
						<![CDATA[(bl.ORG_CD='#data#')]]>
						</value>
						<inputbox type="selectbox" depends="ORG_ID1;ORG_ID0"
							styleproperty="style='width:150px'">
							<option label="全部" value=""></option>
							<option label="无" value="" type="false"></option>
							<option
								source="@{SELECT DISTINCT ORG_ID, ORG_NM FROM IBS.T5_ORG WHERE ORG_TYPE_ID='EO' AND ORG_LEVEL_ID IN ('1','2') and BRANCH_ORG_ID='#ORG_ID1#' and (HEAD_ORG_ID='#ORG_ID0#' or BRANCH_ORG_ID='#ORG_ID0#' or ORG_ID='#ORG_ID0#') ORDER BY ORG_ID}"
								label="ORG_NM" value="ORG_ID" />
						</inputbox>
					</condition>
					<condition name="REMARK" label="调整期" labelposition="left" defaultvalue="session{exam_msr_dt_exam}">
						<value>
					 	<![CDATA[(CHG_DT='#data#')]]>
						</value>
						<inputbox type="selectbox" styleproperty="style='width:100px'" >
							<option label="全部" value=""></option>
							<option
								source="@{Select MEASURE_DT , SWITCH_F , REMARK from IBS.T99_MIDDLE_INCOME_SWITCH ORDER BY MEASURE_DT DESC}"
								label="REMARK" value="MEASURE_DT" />
						</inputbox>
					</condition>
				</select>
			</sql>

			<footer><![CDATA[
			<tr><td height="20px"></td></tr>
			<div style='float:left'>
				<font color='green'>提示：</font>
			</div>
			<tr><td height="20px"></td></tr>
			<div style='float:left'>	
				 <font color='green'>1-分行有权人仅能维护录入本分行员工贷款不良清收业绩调整，不能跨行录入。</font>
			</div>
			<tr><td height="20px"></td></tr>
			<div style='float:left'>	
				 <font color='green'>2-请在考核期内对数据进行维护，过期数据不能补录。</font>
			</div>
			
			]]>
		</footer>


		</report>
	</vpanel>
</page>

</applications>


